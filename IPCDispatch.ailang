// ClaudeCode.IPCDispatch.ailang — generic tool dispatcher.
//
// Speaks the cc_tools envelope to any number of tool services. Owns
// nothing tool-specific — adding a new tool is a single RegisterTool()
// call at startup, and a new cc_*_ipc.ailang on disk. The ClaudeCode
// binary itself never needs to know what Read/Bash/Grep do.
//
// Lifecycle:
//   IPCDispatch.Init()                       — alloc tool table
//   IPCDispatch.RegisterTool(name, sock)     — connect + fetch schema
//   IPCDispatch.GetToolSchemasArray()        — JSON array for tools[] in API request
//   IPCDispatch.Dispatch(name, input, id)    — fire one tool call, return content string
//   IPCDispatch.Shutdown()                   — close all sockets
//
// Each tool has a persistent connection — reused for the whole session
// rather than reconnecting per call.
//
// Copyright 2026 Sean Collins, 2 Paws Machine and Engineering. SCSL.

LibraryImport.Arena
LibraryImport.Socket
LibraryImport.JSON
LibraryImport.StringUtils

FixedPool.IPCDConst {
    "TABLE_CAP":     Initialize=2048  // 64 slots × 32 bytes — no enforced ceiling
    "ENTRY_SIZE":    Initialize=32    // 8 name + 8 fd + 8 schema + 8 sock_path
}

FixedPool.IPCDOff {
    "NAME":          Initialize=0
    "FD":            Initialize=8
    "SCHEMA":        Initialize=16
    "SOCK_PATH":     Initialize=24
}

FixedPool.IPCDState {
    "table":         Initialize=0, CanChange=True
    "count":         Initialize=0, CanChange=True
    "schemas_arr":   Initialize=0, CanChange=True   // cached JSON array of schemas
    "proxy_listen_fd":  Initialize=-1, CanChange=True  // parent's AgentProxy listen socket
    "proxy_clients":    Initialize=0,  CanChange=True  // 8-slot array of connected agent fds
    "proxy_client_cnt": Initialize=0,  CanChange=True
    "proxy_polling":    Initialize=0,  CanChange=True  // re-entrancy guard
    "proxy_mode":       Initialize=0,  CanChange=True  // 1=agent worker, route all calls to parent
    "proxy_conn_fd":    Initialize=-1, CanChange=True  // agent's connection to parent proxy
}

// =============================================================================
// INIT / SHUTDOWN
// =============================================================================
Function.IPCDispatch.Init {
    Body: {
        IPCDState.table = Allocate(IPCDConst.TABLE_CAP)
        MemorySet(IPCDState.table, 0, IPCDConst.TABLE_CAP)
        IPCDState.count = 0
        IPCDState.schemas_arr = JSON.NewArray()
    }
}

Function.IPCDispatch.Shutdown {
    Body: {
        i = 0
        WhileLoop LessThan(i, IPCDState.count) {
            base = Add(IPCDState.table, Multiply(i, IPCDConst.ENTRY_SIZE))
            fd = Dereference(Add(base, IPCDOff.FD))
            IfCondition GreaterEqual(fd, 0) ThenBlock: { Socket.Close(fd) }
            i = Add(i, 1)
        }
        IPCDState.count = 0
    }
}

// =============================================================================
// AGENT PROXY — parent side
// Opens @halcode/AgentProxy, accepts agent worker connections, routes tool
// calls through the parent's already-open tool daemon connections.
// =============================================================================

// Open the proxy listen socket. Call once after CC_BootTools().
Function.IPCDispatch.StartProxy {
    Body: {
        fd = Socket.Create(1, 1)
        IfCondition LessThan(fd, 0) ThenBlock: {
            IPCD_Log("[proxy] socket create failed\n")
            ReturnValue(0)
        }
        rc = Socket.BindUnix(fd, "@halcode/AgentProxy")
        IfCondition LessThan(rc, 0) ThenBlock: {
            Socket.Close(fd)
            IPCD_Log("[proxy] bind failed\n")
            ReturnValue(0)
        }
        Socket.Listen(fd, 8)
        Socket.SetNonBlock(fd)
        IPCDState.proxy_listen_fd = fd
        IPCDState.proxy_clients = Allocate(64)  // 8 × 8 bytes
        _pi = 0
        WhileLoop LessThan(_pi, 8) {
            StoreValue(Add(IPCDState.proxy_clients, Multiply(_pi, 8)), -1)
            _pi = Add(_pi, 1)
        }
        IPCDState.proxy_client_cnt = 0
        IPCD_Log("[proxy] AgentProxy listening\n")
    }
}

// Service any pending agent connections/requests. Non-blocking (timeout=0).
// Call from idle loops: IPCDispatch.Dispatch poll, CC_SleepAnimated, etc.
Function.IPCDispatch.PollProxy {
    Body: {
        // Re-entrancy guard: PollProxy → Dispatch → PollProxy would loop
        IfCondition EqualTo(IPCDState.proxy_polling, 1) ThenBlock: { ReturnValue(0) }
        IfCondition LessThan(IPCDState.proxy_listen_fd, 0) ThenBlock: { ReturnValue(0) }
        IPCDState.proxy_polling = 1

        // Build poll array: listen fd + up to 8 client fds
        cnt = IPCDState.proxy_client_cnt
        poll_sz = Add(cnt, 1)
        pfd = Allocate(Multiply(poll_sz, 8))

        // slot 0 = listen fd
        StoreValue(pfd, IPCDState.proxy_listen_fd, "dword")
        StoreValue(Add(pfd, 4), 1, "dword")  // POLLIN

        _ci = 0
        WhileLoop LessThan(_ci, cnt) {
            cfd = Dereference(Add(IPCDState.proxy_clients, Multiply(_ci, 8)))
            off = Multiply(Add(_ci, 1), 8)
            StoreValue(Add(pfd, off), cfd, "dword")
            StoreValue(Add(pfd, Add(off, 4)), 1, "dword")  // POLLIN
            _ci = Add(_ci, 1)
        }

        pr = SystemCall(7, pfd, poll_sz, 0, 0, 0)  // SYS_POLL, timeout=0

        // Check listen fd — accept new agent connections
        // struct pollfd: fd(4) + events(2) + revents(2); revents is at byte offset 6
        revents0 = GetByte(pfd, 6)
        IfCondition GreaterThan(BitwiseAnd(revents0, 1), 0) ThenBlock: {
            new_fd = Socket.Accept(IPCDState.proxy_listen_fd)
            IfCondition GreaterEqual(new_fd, 0) ThenBlock: {
                cur = IPCDState.proxy_client_cnt
                IfCondition LessThan(cur, 8) ThenBlock: {
                    StoreValue(Add(IPCDState.proxy_clients, Multiply(cur, 8)), new_fd)
                    IPCDState.proxy_client_cnt = Add(cur, 1)
                    IPCD_Log("[proxy] agent connected\n")
                } ElseBlock: {
                    Socket.Close(new_fd)
                    IPCD_Log("[proxy] agent rejected (max 8 clients)\n")
                }
            }
        }

        // Check client fds — service ready requests
        _si = 0
        WhileLoop LessThan(_si, cnt) {
            revents = GetByte(pfd, Add(Multiply(Add(_si, 1), 8), 6))
            IfCondition GreaterThan(BitwiseAnd(revents, 1), 0) ThenBlock: {
                cfd2 = Dereference(Add(IPCDState.proxy_clients, Multiply(_si, 8)))
                Socket.SetRecvTimeout(cfd2, 2000)
                req_str = Socket.RecvMsg(cfd2)
                IfCondition EqualTo(req_str, 0) ThenBlock: {
                    // Client disconnected — compact slot
                    Socket.Close(cfd2)
                    last = Subtract(IPCDState.proxy_client_cnt, 1)
                    last_fd = Dereference(Add(IPCDState.proxy_clients, Multiply(last, 8)))
                    StoreValue(Add(IPCDState.proxy_clients, Multiply(_si, 8)), last_fd)
                    IPCDState.proxy_client_cnt = last
                    IPCD_Log("[proxy] agent disconnected\n")
                } ElseBlock: {
                    // Parse and handle request
                    _rp = ParseJSON(req_str)
                    IfCondition NotEqual(_rp, 0) ThenBlock: {
                        _ro = JSON.AsObject(_rp)
                        IfCondition NotEqual(_ro, 0) ThenBlock: {
                            _meth = JSON.GetString(_ro, "method")
                            IfCondition And(NotEqual(_meth, 0), EqualTo(StringCompare(_meth, "schema"), 0)) ThenBlock: {
                                // Return serialized schemas array
                                _sarr = IPCDState.schemas_arr
                                _sarr_str = JSON.SerializeArray(_sarr)
                                _sresp = StringConcat("{\"method\":\"schema_response\",\"schemas\":", _sarr_str)
                                _sresp = StringConcat(_sresp, "}")
                                Socket.SendMsg(cfd2, _sresp)
                                IPCD_Log("[proxy] schema sent to agent\n")
                            }
                            IfCondition And(NotEqual(_meth, 0), EqualTo(StringCompare(_meth, "call"), 0)) ThenBlock: {
                                _tool = JSON.GetString(_ro, "tool")
                                _rid  = JSON.GetString(_ro, "id")
                                _args = JSON.GetObject(_ro, "args")
                                _perr = Allocate(8)
                                StoreValue(_perr, 0, "dword")
                                _result = IPCDispatch.Dispatch(_tool, _args, _rid, _perr)
                                _is_err = Dereference(_perr, "dword")
                                Deallocate(_perr, 8)
                                _rresp = JSON.NewObject()
                                JSON.SetBool(_rresp, "ok", 1)
                                IfCondition EqualTo(_is_err, 1) ThenBlock: { JSON.SetBool(_rresp, "ok", 0) }
                                IfCondition NotEqual(_result, 0) ThenBlock: {
                                    JSON.SetString(_rresp, "content", _result)
                                }
                                IfCondition NotEqual(_rid, 0) ThenBlock: {
                                    JSON.SetString(_rresp, "id", _rid)
                                }
                                Socket.SendMsg(cfd2, JSON.SerializeObject(_rresp))
                            }
                        }
                    }
                }
            }
            _si = Add(_si, 1)
        }

        Deallocate(pfd, Multiply(poll_sz, 8))
        IPCDState.proxy_polling = 0
    }
}

// =============================================================================
// AGENT PROXY — agent worker side
// Connect to the parent's @halcode/AgentProxy, fetch all tool schemas,
// register them in the local dispatch table with proxy_conn_fd.
// Call instead of CC_RegisterToolsOnly in --agent mode.
// =============================================================================
Function.IPCDispatch.ConnectProxy {
    Body: {
        fd = Socket.Create(1, 1)
        IfCondition LessThan(fd, 0) ThenBlock: {
            IPCD_Log("[proxy-agent] socket create failed\n")
            ReturnValue(0)
        }
        // Retry for up to 5 seconds (parent may still be booting)
        _att = 0
        _cr = -1
        WhileLoop And(LessThan(_att, 50), LessThan(_cr, 0)) {
            _cr = Socket.ConnectUnix(fd, "@halcode/AgentProxy")
            IfCondition LessThan(_cr, 0) ThenBlock: {
                Socket.Close(fd)
                fd = Socket.Create(1, 1)
                ts = Allocate(16)
                StoreValue(Add(ts, 0), 0)
                StoreValue(Add(ts, 8), 100000000)  // 100ms
                SystemCall(35, ts, 0, 0, 0, 0)
                Deallocate(ts, 16)
                _att = Add(_att, 1)
            }
        }
        IfCondition LessThan(_cr, 0) ThenBlock: {
            Socket.Close(fd)
            IPCD_Log("[proxy-agent] connect failed\n")
            ReturnValue(0)
        }
        IPCDState.proxy_conn_fd = fd
        IPCDState.proxy_mode = 1

        // Request schemas
        Socket.SendMsg(fd, "{\"method\":\"schema\"}")
        Socket.SetRecvTimeout(fd, 10000)
        _sresp = Socket.RecvMsg(fd)
        IfCondition EqualTo(_sresp, 0) ThenBlock: {
            IPCD_Log("[proxy-agent] no schema response\n")
            ReturnValue(0)
        }

        // Parse: {"method":"schema_response","schemas":[...]}
        _sp = ParseJSON(_sresp)
        IfCondition EqualTo(_sp, 0) ThenBlock: { ReturnValue(0) }
        _so = JSON.AsObject(_sp)
        IfCondition EqualTo(_so, 0) ThenBlock: { ReturnValue(0) }
        _sarr = JSON.GetArray(_so, "schemas")
        IfCondition EqualTo(_sarr, 0) ThenBlock: {
            IPCD_Log("[proxy-agent] no schemas in response\n")
            ReturnValue(0)
        }

        // Register each schema as a fake tool entry pointing to proxy_conn_fd
        _scount = JSON.ArrayLength(_sarr)
        _si2 = 0
        WhileLoop LessThan(_si2, _scount) {
            _sch = JSON.AsObject(JSON.ArrayGet(_sarr, _si2))
            IfCondition NotEqual(_sch, 0) ThenBlock: {
                _tname2 = JSON.GetString(_sch, "name")
                IfCondition NotEqual(_tname2, 0) ThenBlock: {
                    idx2 = IPCDState.count
                    base2 = Add(IPCDState.table, Multiply(idx2, IPCDConst.ENTRY_SIZE))
                    StoreValue(Add(base2, IPCDOff.NAME),   _tname2)
                    StoreValue(Add(base2, IPCDOff.FD),     fd)         // proxy fd
                    StoreValue(Add(base2, IPCDOff.SCHEMA), _sch)
                    StoreValue(Add(base2, IPCDOff.SOCK_PATH), 0)
                    IPCDState.count = Add(idx2, 1)
                    JSON.PushObject(IPCDState.schemas_arr, _sch)
                }
            }
            _si2 = Add(_si2, 1)
        }

        IPCD_Log("[proxy-agent] connected, schemas loaded\n")
        ReturnValue(1)
    }
}

// =============================================================================
// File logger — writes to /tmp/cc-ipcd.log so the TUI doesn't eat the output.
// O_WRONLY|O_CREAT|O_APPEND = 1|64|1024 = 1089, mode 0644 = 420.
// =============================================================================
Function.IPCD_Log {
    Input: msg: Address
    Body: {
        fd = SystemCall(2, "/tmp/cc-ipcd.log", 1089, 420, 0, 0)
        IfCondition GreaterEqual(fd, 0) ThenBlock: {
            SystemCall(1, fd, msg, StringLength(msg), 0, 0)
            SystemCall(3, fd, 0, 0, 0, 0)
        }
    }
}

// =============================================================================
// REGISTER A TOOL — connect to its socket, fetch its schema, cache.
// Returns 1 on success, 0 on failure (tool service not running).
// =============================================================================
Function.IPCDispatch.RegisterTool {
    Input: name: Address
    Input: sock_path: Address
    Output: Integer
    Body: {
        IPCD_Log("[ipcd] BEGIN ")
        IPCD_Log(name)
        IPCD_Log("\n")

        fd = Socket.Create(1, 1)
        IfCondition LessThan(fd, 0) ThenBlock: {
            IPCD_Log("[ipcd] FAIL socket_create ")
            IPCD_Log(name)
            IPCD_Log("\n")
            ReturnValue(0)
        }

        // Retry connect — there's a race between fork/exec of cc_*_ipc and
        // its bind+listen. The 2s global sleep covers most cases but not
        // ALL 7 services on slower hosts. Up to 100 tries × 100ms = 10s extra.
        attempts = 0
        cr = -1
        WhileLoop LessThan(attempts, 100) {
            
            log_msg = StringConcat("[ipcd] attempt ", NumberToString(attempts))
            log_msg = StringConcat(log_msg, " to connect to ")
            log_msg = StringConcat(log_msg, name)
            log_msg = StringConcat(log_msg, " at ")
            log_msg = StringConcat(log_msg, sock_path)
            log_msg = StringConcat(log_msg, "\n")
            IPCD_Log(log_msg)

            cr = Socket.ConnectUnix(fd, sock_path)
            
            IfCondition GreaterEqual(cr, 0) ThenBlock: {
                BreakLoop
            } ElseBlock: {
                // Need a fresh socket for each retry attempt — a failed
                // connect can leave the fd in an unusable state.
                IPCD_Log("[ipcd] connect failed, retrying...\n")
                Socket.Close(fd)
                fd = Socket.Create(1, 1)
                ts = Allocate(16)
                StoreValue(Add(ts, 0), 0)
                StoreValue(Add(ts, 8), 100000000)   // 100ms
                SystemCall(35, ts, 0, 0, 0, 0)
                Deallocate(ts, 16)
                attempts = Add(attempts, 1)
            }
        }
        IfCondition LessThan(cr, 0) ThenBlock: {
            IPCD_Log("[ipcd] FAIL connect ")
            IPCD_Log(name)
            IPCD_Log(" at ")
            IPCD_Log(sock_path)
            IPCD_Log(" (after retries)\n")
            Socket.Close(fd)
            ReturnValue(0)
        }

        // Request schema
        req = JSON.NewObject()
        JSON.SetString(req, "method", "schema")
        req_str = JSON.SerializeObject(req)
        Socket.SendMsg(fd, req_str)

        resp_str = Socket.RecvMsg(fd)
        IfCondition EqualTo(resp_str, 0) ThenBlock: {
            IPCD_Log("[ipcd] FAIL no_response ")
            IPCD_Log(name)
            IPCD_Log("\n")
            Socket.Close(fd)
            ReturnValue(0)
        }

        parsed = ParseJSON(resp_str)
        IfCondition EqualTo(parsed, 0) ThenBlock: {
            IPCD_Log("[ipcd] FAIL parse ")
            IPCD_Log(name)
            IPCD_Log("\n")
            Socket.Close(fd)
            ReturnValue(0)
        }
        obj = JSON.AsObject(parsed)
        IfCondition EqualTo(obj, 0) ThenBlock: {
            IPCD_Log("[ipcd] FAIL as_object ")
            IPCD_Log(name)
            IPCD_Log("\n")
            Socket.Close(fd)
            ReturnValue(0)
        }
        schema_obj = JSON.GetObject(obj, "schema")
        IfCondition EqualTo(schema_obj, 0) ThenBlock: {
            IPCD_Log("[ipcd] FAIL get_schema ")
            IPCD_Log(name)
            IPCD_Log("\n")
            Socket.Close(fd)
            ReturnValue(0)
        }

        // Store entry
        idx = IPCDState.count
        base = Add(IPCDState.table, Multiply(idx, IPCDConst.ENTRY_SIZE))
        StoreValue(Add(base, IPCDOff.NAME),      name)
        StoreValue(Add(base, IPCDOff.FD),        fd)
        StoreValue(Add(base, IPCDOff.SCHEMA),    schema_obj)
        StoreValue(Add(base, IPCDOff.SOCK_PATH), sock_path)
        IPCDState.count = Add(idx, 1)

        // Append schema to cached schemas array
        JSON.PushObject(IPCDState.schemas_arr, schema_obj)

        IPCD_Log("[ipcd] OK ")
        IPCD_Log(name)
        IPCD_Log("\n")
        ReturnValue(1)
    }
}

// =============================================================================
// SCHEMA ARRAY — feed straight into Anthropic.BuildRequest tools_arr arg
// =============================================================================
Function.IPCDispatch.GetToolSchemasArray {
    Output: Address
    Body: {
        new_arr = JSON.NewArray()
        i = 0
        WhileLoop LessThan(i, IPCDState.count) {
            base = Add(IPCDState.table, Multiply(i, IPCDConst.ENTRY_SIZE))
            name = Dereference(Add(base, IPCDOff.NAME))
            fd = Dereference(Add(base, IPCDOff.FD))
            
            IfCondition LessThan(fd, 0) ThenBlock: {
                sch = Dereference(Add(base, IPCDOff.SCHEMA))
                IfCondition NotEqual(sch, 0) ThenBlock: {
                    JSON.PushObject(new_arr, sch)
                }
                i = Add(i, 1)
                ContinueLoop
            }

            req = JSON.NewObject()
            JSON.SetString(req, "method", "schema")
            req_str = JSON.SerializeObject(req)
            
            sr = Socket.SendMsg(fd, req_str)
            IfCondition LessThan(sr, 0) ThenBlock: {
                IPCDispatch_Reconnect(name)
                fd = Dereference(Add(base, IPCDOff.FD))
                sr = Socket.SendMsg(fd, req_str)
            }
            
            IfCondition GreaterEqual(sr, 0) ThenBlock: {
                Socket.SetRecvTimeout(fd, 5000)
                resp_str = Socket.RecvMsg(fd)
                IfCondition EqualTo(resp_str, 0) ThenBlock: {
                    IPCDispatch_Reconnect(name)
                    fd = Dereference(Add(base, IPCDOff.FD))
                    Socket.SendMsg(fd, req_str)
                    resp_str = Socket.RecvMsg(fd)
                }
                IfCondition NotEqual(resp_str, 0) ThenBlock: {
                    IfCondition NotEqual(resp_str, -1) ThenBlock: {
                        parsed = ParseJSON(resp_str)
                        IfCondition NotEqual(parsed, 0) ThenBlock: {
                            obj = JSON.AsObject(parsed)
                            IfCondition NotEqual(obj, 0) ThenBlock: {
                                sch = JSON.GetObject(obj, "schema")
                                IfCondition NotEqual(sch, 0) ThenBlock: {
                                    JSON.PushObject(new_arr, sch)
                                    StoreValue(Add(base, IPCDOff.SCHEMA), sch)
                                }
                            }
                        }
                    }
                }
            }
            i = Add(i, 1)
        }
        IPCDState.schemas_arr = new_arr
        ReturnValue(new_arr)
    }
}

// =============================================================================
// RECONNECT — close stale fd and re-connect to recover from a timeout desync.
// After a timeout, the tool service may have sent a response that is still
// buffered on the socket.  Rather than corrupt the next call with that stale
// data, we drop the connection and open a fresh one.
// =============================================================================
Function.IPCDispatch_Reconnect {
    Input: name: Address
    Body: {
        i = 0
        WhileLoop LessThan(i, IPCDState.count) {
            base     = Add(IPCDState.table, Multiply(i, IPCDConst.ENTRY_SIZE))
            stored   = Dereference(Add(base, IPCDOff.NAME))
            IfCondition EqualTo(StringCompare(stored, name), 0) ThenBlock: {
                old_fd    = Dereference(Add(base, IPCDOff.FD))
                sock_path = Dereference(Add(base, IPCDOff.SOCK_PATH))

                Socket.Close(old_fd)

                attempts = 0
                new_fd   = -1
                WhileLoop LessThan(attempts, 2) {
                    tmp_fd = Socket.Create(1, 1)
                    
                    cr = Socket.ConnectUnix(tmp_fd, sock_path)
                    
                    IfCondition GreaterEqual(cr, 0) ThenBlock: {
                        new_fd   = tmp_fd
                        BreakLoop
                    } ElseBlock: {
                        Socket.Close(tmp_fd)
                        ts = Allocate(16)
                        StoreValue(ts,        0)
                        StoreValue(Add(ts,8), 200000000)
                        SystemCall(35, ts, 0, 0, 0, 0)
                        Deallocate(ts, 16)
                        attempts = Add(attempts, 1)
                    }
                }

                StoreValue(Add(base, IPCDOff.FD), new_fd)
                IPCD_Log("[ipcd] reconnect ")
                IPCD_Log(name)
                IfCondition LessThan(new_fd, 0) ThenBlock: {
                    IPCD_Log(" FAILED\n")
                } ElseBlock: {
                    IPCD_Log(" OK\n")
                }
                ReturnValue(0)
            }
            i = Add(i, 1)
        }
    }
}

// =============================================================================
// LOOKUP — find a tool's fd by name, return -1 if missing
// =============================================================================
Function.IPCDispatch_FindFd {
    Input: name: Address
    Output: Integer
    Body: {
        i = 0
        WhileLoop LessThan(i, IPCDState.count) {
            base = Add(IPCDState.table, Multiply(i, IPCDConst.ENTRY_SIZE))
            stored = Dereference(Add(base, IPCDOff.NAME))
            IfCondition NotEqual(stored, 0) ThenBlock: {
                IfCondition EqualTo(StringCompare(stored, name), 0) ThenBlock: {
                    ReturnValue(Dereference(Add(base, IPCDOff.FD)))
                }
            }
            i = Add(i, 1)
        }
        ReturnValue(-1)
    }
}

// =============================================================================
// DISPATCH — send a tool call, await response, return content/error string.
// Always returns a non-null string suitable for embedding in a tool_result.
// On error, the string is the error message and out_is_error_ptr is set to 1.
// =============================================================================
Function.IPCDispatch.Dispatch {
    Input: name: Address
    Input: input_obj: Address
    Input: tool_use_id: Address
    Input: out_is_error_ptr: Address
    Output: Address
    Body: {
        StoreValue(out_is_error_ptr, 0, "dword")

        fd = IPCDispatch_FindFd(name)
        IfCondition LessThan(fd, 0) ThenBlock: {
            StoreValue(out_is_error_ptr, 1, "dword")
            ReturnValue(StringConcat("tool not registered: ", name))
        }

        // Build request. In proxy mode include "tool":name so the parent knows
        // which daemon to forward to; direct-mode daemons don't need it.
        req = JSON.NewObject()
        JSON.SetString(req, "method", "call")
        IfCondition EqualTo(IPCDState.proxy_mode, 1) ThenBlock: {
            JSON.SetString(req, "tool", name)
        }
        IfCondition NotEqual(tool_use_id, 0) ThenBlock: {
            JSON.SetString(req, "id", tool_use_id)
        }
        IfCondition NotEqual(input_obj, 0) ThenBlock: {
            JSON.SetObject(req, "args", input_obj)
        }
        req_str = JSON.SerializeObject(req)

        sr = Socket.SendMsg(fd, req_str)
        IfCondition LessThan(sr, 0) ThenBlock: {
            IfCondition EqualTo(IPCDState.proxy_mode, 0) ThenBlock: {
                IPCDispatch_Reconnect(name)
                fd = IPCDispatch_FindFd(name)
                IfCondition GreaterEqual(fd, 0) ThenBlock: {
                    sr = Socket.SendMsg(fd, req_str)
                }
            }
            IfCondition LessThan(sr, 0) ThenBlock: {
                StoreValue(out_is_error_ptr, 1, "dword")
                ReturnValue(StringConcat("send failed to: ", name))
            }
        }

        // Per-tool timeout. Default 60s covers real work (relmem indexing, web fetches)
        // and unblocks hangs. Sleep is special: it intentionally waits up to 310s
        // (300s max + 10s buffer) so agents can use Sleep seconds=300 safely.
        tool_timeout = 60
        IfCondition EqualTo(StringCompare(name, "Sleep"), 0) ThenBlock: { tool_timeout = 310 }
        t_start = SystemCall(201, 0, 0, 0, 0, 0)   // SYS_TIME — Unix epoch seconds

        // Non-blocking poll loop: keep UI alive + service agent proxy requests
        pfd = Allocate(8)
        StoreValue(pfd, fd, "dword")
        StoreValue(Add(pfd, 4), 1, "dword") // POLLIN
        WhileLoop 1 {
            pr = SystemCall(7, pfd, 1, 15, 0, 0) // SYS_POLL = 7, 15ms timeout
            IfCondition NotEqual(pr, 0) ThenBlock: { BreakLoop }
            UI.AnimTick()
            // While waiting for a tool result, service any pending agent requests
            IfCondition EqualTo(IPCDState.proxy_mode, 0) ThenBlock: {
                IPCDispatch.PollProxy()
            }
            t_now = SystemCall(201, 0, 0, 0, 0, 0)
            IfCondition GreaterEqual(Subtract(t_now, t_start), tool_timeout) ThenBlock: { BreakLoop }
        }
        Deallocate(pfd, 8)

        Socket.SetRecvTimeout(fd, 1000)
        resp_str = Socket.RecvMsg(fd)
        t_end = SystemCall(201, 0, 0, 0, 0, 0)
        elapsed = Subtract(t_end, t_start)

        IfCondition EqualTo(resp_str, 0) ThenBlock: {
            StoreValue(out_is_error_ptr, 1, "dword")
            IPCDispatch_Reconnect(name)
            IfCondition GreaterEqual(elapsed, tool_timeout) ThenBlock: {
                ReturnValue(StringConcat("tool TIMED OUT: ", name))
            }
            ReturnValue(StringConcat("tool crashed or connection lost: ", name))
        }
        // -1 = bad length prefix (e.g. tool returned a payload bigger than
        // the 64KB IPC envelope sanity check). Socket.RecvMsg already
        // drained the buffer to resync. Treat as a tool-level error so
        // the model sees something useful instead of us hanging.
        IfCondition EqualTo(resp_str, -1) ThenBlock: {
            StoreValue(out_is_error_ptr, 1, "dword")
            ReturnValue(StringConcat("tool response too large (>64KB): ", name))
        }
        // Slow-tool flag: only emit if we crossed 5s, so fast tools stay quiet.
        IfCondition GreaterEqual(elapsed, 5) ThenBlock: {
            slow_msg = StringConcat("[slow tool: ", name)
            slow_msg = StringConcat(slow_msg, " took ")
            slow_msg = StringConcat(slow_msg, NumberToString(elapsed))
            slow_msg = StringConcat(slow_msg, "s]")
            UI.ChatPrintln(slow_msg)
        }

        parsed = ParseJSON(resp_str)
        IfCondition EqualTo(parsed, 0) ThenBlock: {
            StoreValue(out_is_error_ptr, 1, "dword")
            ReturnValue("invalid JSON response from tool")
        }
        obj = JSON.AsObject(parsed)
        IfCondition EqualTo(obj, 0) ThenBlock: {
            StoreValue(out_is_error_ptr, 1, "dword")
            ReturnValue("tool response was not an object")
        }

        ok = JSON.GetBool(obj, "ok")
        IfCondition EqualTo(ok, 1) ThenBlock: {
            content = JSON.GetString(obj, "content")
            IfCondition EqualTo(content, 0) ThenBlock: {
                // No "content" field — ops like search/tree/task_list return
                // {"ok":true,"rows":[...]} or {"ok":true,"tasks":[...]} instead.
                // Pass the full response string so the model sees the data.
                ReturnValue(resp_str)
            }
            ReturnValue(content)
        }

        // ok = false  -> error path
        StoreValue(out_is_error_ptr, 1, "dword")
        err = JSON.GetString(obj, "error")
        IfCondition EqualTo(err, 0) ThenBlock: { ReturnValue("tool returned error (no detail)") }
        ReturnValue(err)
    }
}
