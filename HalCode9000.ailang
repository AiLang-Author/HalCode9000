// HalCode9000.ailang — native AILang Claude Code, Phase 1 entry point.
//
// A terminal chat client against the Anthropic Messages API. Streams text
// deltas to stdout in real time, dispatches tool calls to cc_tools/* IPC
// services, and loops until the model stops asking for tools.
//
// No JS, no Bun, no Node, no MCP, no hooks. ~150 lines of glue plus
// generic libraries (HTTP, SSE, JSON, Socket, UtilArgs) and Anthropic-
// specific helpers (.History, .Anthropic, .IPCDispatch).
//
// Build: ./ailang.x Applications/HalCode9000/HalCode9000.ailang HalCode9000.x
// Run:   ANTHROPIC_API_KEY=sk-... ./HalCode9000.x
//
// Prerequisites at runtime:
//   - cc_read_ipc.x (and other cc_*_ipc.x services) running
//   - curl on PATH
//   - ANTHROPIC_API_KEY env var set
//
// Copyright 2026 Sean Collins, 2 Paws Machine and Engineering. SCSL.

LibraryImport.Arena
LibraryImport.JSON
LibraryImport.StringUtils
LibraryImport.HTTP
LibraryImport.SSE
LibraryImport.OAuth
LibraryImport.ANSICanvas
Import.Applications.HalCode9000.History
Import.Applications.HalCode9000.UI
Import.Applications.HalCode9000.IPCDispatch
Import.Applications.HalCode9000.backends.Backend
Import.Applications.HalCode9000.Auth

FixedPool.CCSys {
    "SYS_READ":      Initialize=0
    "SYS_WRITE":     Initialize=1
    "SYS_OPEN":      Initialize=2
    "SYS_CLOSE":     Initialize=3
    "SYS_DUP":       Initialize=32
    "SYS_DUP2":      Initialize=33
    "SYS_NANOSLEEP": Initialize=35
    "SYS_FORK":      Initialize=57
    "SYS_EXECVE":    Initialize=59
    "SYS_EXIT":      Initialize=60
    "SYS_KILL":      Initialize=62
    "SYS_CHDIR":     Initialize=80
    "SYS_MKDIR":     Initialize=83
    "SYS_READLINK":  Initialize=89
    "SYS_WAIT4":     Initialize=61
    "SYS_PRCTL":     Initialize=157
    "SYS_TIME":      Initialize=201
    "SYS_RENAME":    Initialize=82
    "SYS_UNLINK":    Initialize=87
    "SIGTERM":       Initialize=15
    "SIGKILL":       Initialize=9
    "PR_SET_PDEATHSIG": Initialize=1
}

FixedPool.CCConst {
    "MODEL":          Initialize=0, CanChange=True
    "SYSTEM_PROMPT":  Initialize=0, CanChange=True
    "PROJ_PROMPT":    Initialize=0, CanChange=True
    "INPUT_BUF_SZ":   Initialize=1048576      // 1MB
    "LINE_BUF_SZ":    Initialize=1048576      // 1MB - prevents Buffer Bound overflows
    "SSE_STATE_SZ":   Initialize=88
    "MAX_CHILDREN":   Initialize=16
    "BIND_WAIT_NS":   Initialize=5000000000   // 5s — allows slower tools like relmem to bind
    "PARK_THRESHOLD": Initialize=32768        // 32KB — fixes PGMEM SPILL PANIC
}

FixedPool.CCRunState {
    "running":       Initialize=1, CanChange=True
    "go_home":       Initialize=0, CanChange=True
    "child_pids":    Initialize=0, CanChange=True
    "child_count":   Initialize=0, CanChange=True
    "auto_approve":  Initialize=0, CanChange=True
    "session_turn":  Initialize=0, CanChange=True
    "auth_mode":     Initialize=0, CanChange=True
    "auth_cred":     Initialize=0, CanChange=True
}

FixedPool.QuoteState {
    "arr":           Initialize=0, CanChange=True   // JSON array of quote strings
    "count":         Initialize=0, CanChange=True
    "rng":           Initialize=42, CanChange=True  // LCG state
    "last_sec":      Initialize=0, CanChange=True   // absolute second tracker for quotes
}

// =============================================================================
// I/O HELPERS
// =============================================================================
Function.CC_WriteStdout {
    Input: s: Address
    Body: {
        len = StringLength(s)
        IfCondition GreaterThan(len, 0) ThenBlock: {
            SystemCall(CCSys.SYS_WRITE, 1, s, len, 0, 0)
        }
    }
}

// Blocking read of one line from stdin into buf. Returns length read
// (excluding the trailing newline). Reads byte-at-a-time so we don't
// over-consume into next prompt. Returns -1 on EOF.
Function.CC_ReadStdinLine {
    Input: buf: Address
    Input: maxlen: Integer
    Output: Integer
    Body: {
        used = 0
        WhileLoop LessThan(used, Subtract(maxlen, 1)) {
            n = SystemCall(CCSys.SYS_READ, 0, Add(buf, used), 1, 0, 0)
            IfCondition LessEqual(n, 0) ThenBlock: {
                IfCondition EqualTo(used, 0) ThenBlock: { ReturnValue(-1) }
                BreakLoop
            }
            ch = GetByte(buf, used)
            IfCondition EqualTo(ch, 10) ThenBlock: { BreakLoop }
            used = Add(used, 1)
        }
        // Strip trailing CR if present (Windows copy-paste)
        IfCondition GreaterThan(used, 0) ThenBlock: {
            last = GetByte(buf, Subtract(used, 1))
            IfCondition EqualTo(last, 13) ThenBlock: {
                used = Subtract(used, 1)
            }
        }
        SetByte(buf, used, 0)
        ReturnValue(used)
    }
}

// Read $VAR from /proc/self/environ. Returns 0 if not set.
Function.CC_GetEnv {
    Input: var_name: Address
    Output: Address
    Body: {
        fd = SystemCall(CCSys.SYS_OPEN, "/proc/self/environ", 0, 0, 0, 0)
        IfCondition LessThan(fd, 0) ThenBlock: { ReturnValue(0) }
        buf = Allocate(65536)
        n = SystemCall(CCSys.SYS_READ, fd, buf, 65536, 0, 0)
        SystemCall(CCSys.SYS_CLOSE, fd, 0, 0, 0, 0)
        IfCondition LessEqual(n, 0) ThenBlock: {
            Deallocate(buf, 65536)
            ReturnValue(0)
        }
        var_len = StringLength(var_name)
        i = 0
        WhileLoop LessThan(i, n) {
            match = 1
            j = 0
            WhileLoop LessThan(j, var_len) {
                IfCondition NotEqual(GetByte(buf, Add(i, j)), GetByte(var_name, j)) ThenBlock: {
                    match = 0
                    BreakLoop
                }
                j = Add(j, 1)
            }
            IfCondition EqualTo(match, 1) ThenBlock: {
                IfCondition EqualTo(GetByte(buf, Add(i, var_len)), 61) ThenBlock: {
                    val_start = Add(i, Add(var_len, 1))
                    val_end = val_start
                    WhileLoop LessThan(val_end, n) {
                        IfCondition EqualTo(GetByte(buf, val_end), 0) ThenBlock: { BreakLoop }
                        val_end = Add(val_end, 1)
                    }
                    val_len = Subtract(val_end, val_start)
                    out = Allocate(Add(val_len, 1))
                    k = 0
                    WhileLoop LessThan(k, val_len) {
                        SetByte(out, k, GetByte(buf, Add(val_start, k)))
                        k = Add(k, 1)
                    }
                    SetByte(out, val_len, 0)
                    Deallocate(buf, 65536)
                    ReturnValue(out)
                }
            }
            WhileLoop LessThan(i, n) {
                IfCondition EqualTo(GetByte(buf, i), 0) ThenBlock: { BreakLoop }
                i = Add(i, 1)
            }
            i = Add(i, 1)
        }
        Deallocate(buf, 65536)
        ReturnValue(0)
    }
}

Function.CC_SleepMs {
    Input: ms: Integer
    Body: {
        IfCondition LessEqual(ms, 0) ThenBlock: { ReturnValue(0) }
        ts = Allocate(16)
        sec = Divide(ms, 1000)
        rem_ms = Subtract(ms, Multiply(sec, 1000))
        ns = Multiply(rem_ms, 1000000)
        StoreValue(Add(ts, 0), sec)
        StoreValue(Add(ts, 8), ns)
        SystemCall(CCSys.SYS_NANOSLEEP, ts, 0, 0, 0, 0)
        Deallocate(ts, 16)
    }
}

// Full-jitter helper: returns a random ms value in [0, max_ms].
// Uses 2 bytes from /dev/urandom for 16-bit entropy.
Function.CC_RandomMs {
    Input: max_ms: Integer
    Output: Integer
    Body: {
        IfCondition LessEqual(max_ms, 0) ThenBlock: { ReturnValue(0) }
        fd = SystemCall(CCSys.SYS_OPEN, "/dev/urandom", 0, 0, 0, 0)
        IfCondition LessThan(fd, 0) ThenBlock: { ReturnValue(Divide(max_ms, 2)) }
        buf = Allocate(2)
        SystemCall(CCSys.SYS_READ, fd, buf, 2, 0, 0)
        SystemCall(CCSys.SYS_CLOSE, fd, 0, 0, 0, 0)
        lo = GetByte(buf, 0)
        hi = GetByte(buf, 1)
        Deallocate(buf, 2)
        rnd = BitwiseOr(lo, LeftShift(hi, 8))
        ReturnValue(Divide(Multiply(rnd, max_ms), 65535))
    }
}

// Verbose debug logger. Appends to /tmp/hal9000_debug.log
Function.CC_DebugLog {
    Input: msg: Address
    Body: {
        // O_WRONLY | O_CREAT | O_APPEND = 1 | 64 | 1024 = 1089
        fd = SystemCall(CCSys.SYS_OPEN, "/tmp/hal9000_debug.log", 1089, 420, 0, 0) // 0644
        IfCondition GreaterEqual(fd, 0) ThenBlock: {
            SystemCall(CCSys.SYS_WRITE, fd, msg, StringLength(msg), 0, 0)
            SystemCall(CCSys.SYS_CLOSE, fd, 0, 0, 0, 0)
        }
    }
}

// Check for agent completion flag written by cc_agent_ipc daemon worker.
// Non-blocking: open returns -1 immediately if file absent.
Function.CC_CheckAgentNotify {
    Body: {
        fd = SystemCall(CCSys.SYS_OPEN, "/tmp/hal_agent_notify.txt", 0, 0, 0, 0)
        IfCondition LessThan(fd, 0) ThenBlock: { ReturnValue(0) }
        buf = Allocate(256)
        n = SystemCall(CCSys.SYS_READ, fd, buf, 255, 0, 0)
        SystemCall(CCSys.SYS_CLOSE, fd, 0, 0, 0, 0)
        SystemCall(CCSys.SYS_UNLINK, "/tmp/hal_agent_notify.txt", 0, 0, 0, 0)
        IfCondition GreaterThan(n, 0) ThenBlock: {
            SetByte(buf, n, 0)
            IfCondition EqualTo(GetByte(buf, Subtract(n, 1)), 10) ThenBlock: {
                SetByte(buf, Subtract(n, 1), 0)
            }
            UI.ChatTag("◆", buf, 6)
        }
        Deallocate(buf, 256)
    }
}

// Turn log — appends tool name, arg summary, and first 4096 chars of result
// to /tmp/hal_turn_log.txt immediately after each tool completes, so work
// is never silently lost when the stream drops mid-turn.
Function.CC_TurnLog {
    Input: tname: Address
    Input: argsummary: Address
    Input: content: Address
    Body: {
        fd = SystemCall(CCSys.SYS_OPEN, "/tmp/hal_turn_log.txt", 1089, 420, 0, 0)
        IfCondition LessThan(fd, 0) ThenBlock: { ReturnValue(0) }
        hdr = StringConcat("[", tname)
        hdr = StringConcat(hdr, "] ")
        hdr = StringConcat(hdr, argsummary)
        hdr = StringConcat(hdr, "\n")
        SystemCall(CCSys.SYS_WRITE, fd, hdr, StringLength(hdr), 0, 0)
        IfCondition NotEqual(content, 0) ThenBlock: {
            cap = 4096
            clen = StringLength(content)
            IfCondition LessThan(clen, cap) ThenBlock: { cap = clen }
            IfCondition GreaterThan(cap, 0) ThenBlock: {
                SystemCall(CCSys.SYS_WRITE, fd, content, cap, 0, 0)
            }
        }
        sep = "\n---\n"
        SystemCall(CCSys.SYS_WRITE, fd, sep, StringLength(sep), 0, 0)
        SystemCall(CCSys.SYS_CLOSE, fd, 0, 0, 0, 0)
    }
}


// =============================================================================
// SESSION LOG — /tmp/hal_session.txt
// Comprehensive per-turn record: user input, full COT, full response.
// =============================================================================

// Append a labeled section to the session log.
Function.CC_SessionLog {
    Input: label: Address
    Input: content: Address
    Body: {
        fd = SystemCall(CCSys.SYS_OPEN, "/tmp/hal_session.txt", 1089, 420, 0, 0)
        IfCondition LessThan(fd, 0) ThenBlock: { ReturnValue(0) }
        IfCondition NotEqual(label, 0) ThenBlock: {
            SystemCall(CCSys.SYS_WRITE, fd, label, StringLength(label), 0, 0)
        }
        IfCondition NotEqual(content, 0) ThenBlock: {
            clen = StringLength(content)
            IfCondition GreaterThan(clen, 0) ThenBlock: {
                SystemCall(CCSys.SYS_WRITE, fd, content, clen, 0, 0)
            }
        }
        SystemCall(CCSys.SYS_WRITE, fd, "\n", 1, 0, 0)
        SystemCall(CCSys.SYS_CLOSE, fd, 0, 0, 0, 0)
    }
}

// Write the turn header + user message to the session log.
Function.CC_SessionLogUser {
    Input: user_msg: Address
    Body: {
        CCRunState.session_turn = Add(CCRunState.session_turn, 1)
        hdr = StringConcat("=== TURN ", NumberToString(CCRunState.session_turn))
        hdr = StringConcat(hdr, " ===\n[USER]\n")
        CC_SessionLog(hdr, user_msg)
        CC_SessionLog("[/USER]\n", 0)
    }
}

// Write COT + response sections to the session log (call before Backend.Reset).
Function.CC_SessionLogResponse {
    Body: {
        cot = Backend.GetReasoning()
        resp = Backend.GetResponseText()
        IfCondition NotEqual(cot, 0) ThenBlock: {
            IfCondition GreaterThan(StringLength(cot), 0) ThenBlock: {
                CC_SessionLog("[THINKING]\n", cot)
                CC_SessionLog("[/THINKING]\n", 0)
            }
        }
        IfCondition NotEqual(resp, 0) ThenBlock: {
            CC_SessionLog("[RESPONSE]\n", resp)
            CC_SessionLog("[/RESPONSE]\n", 0)
        }
    }
}

// Called at exit. If /tmp/hal_session.txt exists, ask user to keep (timestamped)
// or delete it. Runs after UI.Shutdown so terminal is back in cooked mode.
Function.CC_SessionCleanup {
    Body: {
        fd = SystemCall(CCSys.SYS_OPEN, "/tmp/hal_session.txt", 0, 0, 0, 0)
        IfCondition LessThan(fd, 0) ThenBlock: { ReturnValue(0) }
        SystemCall(CCSys.SYS_CLOSE, fd, 0, 0, 0, 0)

        CC_WriteStdout("\nSession log: /tmp/hal_session.txt\nKeep it? [y/N] ")
        kbuf = Allocate(8)
        CC_ReadStdinLine(kbuf, 8)
        ch = GetByte(kbuf, 0)
        Deallocate(kbuf, 8)

        IfCondition Or(EqualTo(ch, 121), EqualTo(ch, 89)) ThenBlock: {
            ts = SystemCall(CCSys.SYS_TIME, 0, 0, 0, 0, 0)
            newpath = StringConcat("/tmp/hal_session_", NumberToString(ts))
            newpath = StringConcat(newpath, ".txt")
            SystemCall(CCSys.SYS_RENAME, "/tmp/hal_session.txt", newpath, 0, 0, 0)
            CC_WriteStdout("Saved to: ")
            CC_WriteStdout(newpath)
            CC_WriteStdout("\n")
        } ElseBlock: {
            SystemCall(CCSys.SYS_UNLINK, "/tmp/hal_session.txt", 0, 0, 0, 0)
        }
    }
}

// =============================================================================
// =============================================================================
// PROJECT PROMPT — load/build/apply per-project system prompt addon
// =============================================================================

// Fetch the project prompt from pgmem key __prompt__. Returns text or 0.
Function.CC_LoadProjectPrompt {
    Output: Address
    Body: {
        args = JSON.NewObject()
        JSON.SetString(args, "op", "pickup")
        JSON.SetString(args, "key", "__prompt__")
        perr = Allocate(8)
        StoreValue(perr, 0, "dword")
        result = IPCDispatch.Dispatch("Pgmem", args, 0, perr)
        err_flag = Dereference(perr, "dword")
        Deallocate(perr, 8)
        IfCondition EqualTo(err_flag, 1) ThenBlock: { ReturnValue(0) }
        IfCondition EqualTo(result, 0) ThenBlock: { ReturnValue(0) }
        IfCondition EqualTo(StringLength(result), 0) ThenBlock: { ReturnValue(0) }
        ReturnValue(result)
    }
}

// Build the combined system prompt (base rules + project addon if set).
Function.CC_BuildFullPrompt {
    Output: Address
    Body: {
        IfCondition EqualTo(CCConst.PROJ_PROMPT, 0) ThenBlock: {
            ReturnValue(CCConst.SYSTEM_PROMPT)
        }
        full = StringConcat(CCConst.SYSTEM_PROMPT, "\n\nPROJECT PROMPT:\n")
        full = StringConcat(full, CCConst.PROJ_PROMPT)
        ReturnValue(full)
    }
}

// Re-initialize backend with current combined prompt. Clears history.
// Call UI.Shutdown/Init/SessionHeader in the caller after this.
Function.CC_ApplyProjectPrompt {
    Body: {
        History.Init()
        Backend.Init(CCRunState.auth_mode, CCRunState.auth_cred, CC_BuildFullPrompt())
    }
}

// =============================================================================
// PROJECT COMMAND — /project slash command handler
// =============================================================================
// Calls project.info on pgmem and prints the human-readable content field.
Function.CC_ProjectCommand {
    Body: {
        args = JSON.NewObject()
        JSON.SetString(args, "op", "project.info")
        perr = Allocate(8)
        StoreValue(perr, 0, "dword")
        resp = IPCDispatch.Dispatch("Pgmem", args, 0, perr)
        err_flag = Dereference(perr, "dword")
        Deallocate(perr, 8)
        IfCondition EqualTo(err_flag, 1) ThenBlock: {
            UI.ChatTag("✗", "Pgmem unavailable — start cc_pgmem_ipc.x first.", 1)
            ReturnValue(0)
        }
        IfCondition NotEqual(resp, 0) ThenBlock: {
            UI.ChatPrintln(resp)
        }
        UI.ChatPrintln("  project.list | project.create name=<n> | project.select name=<n> | project.layout")
    }
}

// =============================================================================
// PATH HELPERS — expand "~/..." to "$HOME/..."
// =============================================================================
Function.CC_ExpandHome {
    Input: path: Address
    Output: Address
    Body: {
        IfCondition EqualTo(path, 0) ThenBlock: { ReturnValue(0) }
        // If first char is not '~', return path unchanged
        IfCondition NotEqual(GetByte(path, 0), 126) ThenBlock: { ReturnValue(path) }
        home = CC_GetEnv("HOME")
        IfCondition EqualTo(home, 0) ThenBlock: { ReturnValue(path) }
        // ~/foo  ->  $HOME/foo
        rest = Add(path, 1)   // skip '~'
        ReturnValue(StringConcat(home, rest))
    }
}

Function.CC_MkdirP {
    Input: path: Address
    Body: {
        // Best-effort mkdir; ignore EEXIST
        SystemCall(83, path, 448, 0, 0, 0)   // 0700
    }
}

// =============================================================================
// AUTH MODE PROMPT — 1=subscription OAuth, 2=API key
// =============================================================================
Function.CC_ClearScreenCooked {
    Body: {
        buf = Allocate(8)
        SetByte(buf, 0, 27) SetByte(buf, 1, 91) SetByte(buf, 2, 50) SetByte(buf, 3, 74)
        SetByte(buf, 4, 27) SetByte(buf, 5, 91) SetByte(buf, 6, 72) SetByte(buf, 7, 0)
        CC_WriteStdout(buf)
        Deallocate(buf, 8)
    }
}

Function.CC_PrintStepHeader {
    Input: step_name: Address
    Body: {
        CC_ClearScreenCooked()
        CC_WriteStdout("\n")
        buf = Allocate(16)
        SetByte(buf,0,27) SetByte(buf,1,91) SetByte(buf,2,51) SetByte(buf,3,56) SetByte(buf,4,59)
        SetByte(buf,5,53) SetByte(buf,6,59) SetByte(buf,7,50) SetByte(buf,8,48) SetByte(buf,9,56) SetByte(buf,10,109) SetByte(buf,11,0)
        CC_WriteStdout(buf)
        
        CC_WriteStdout(" ┌───┐\n")
        CC_WriteStdout(" ─┤ ")
        SetByte(buf,0,226) SetByte(buf,1,151) SetByte(buf,2,137) SetByte(buf,3,0)
        CC_WriteStdout(buf)
        CC_WriteStdout(" ├─  HAL Code 9000\n")
        CC_WriteStdout(" └───┘\n")
        
        SetByte(buf,0,27) SetByte(buf,1,91) SetByte(buf,2,48) SetByte(buf,3,109) SetByte(buf,4,0)
        CC_WriteStdout(buf)
        Deallocate(buf, 16)
        
        CC_WriteStdout("\n ")
        CC_WriteStdout(step_name)
        CC_WriteStdout("\n ────────────────────────────────────────────────────────\n\n")
    }
}

// Returns 1 or 2. Reads a single-line answer; first char wins.
Function.CC_PromptAuthMode {
    Output: Integer
    Body: {
        CC_PrintStepHeader("STEP 1: Authentication")
        CC_WriteStdout("  1) Subscription (claude.ai OAuth — Pro/Max/Team)\n")
        CC_WriteStdout("  2) Console API key (sk-ant-... from console.anthropic.com)\n")
        CC_WriteStdout("  0) Quit\n\n")
        CC_WriteStdout(" Choice [2]: ")
        buf = Allocate(64)
        n = CC_ReadStdinLine(buf, 64)
        choice = 2
        IfCondition GreaterThan(n, 0) ThenBlock: {
            first = GetByte(buf, 0)
            IfCondition EqualTo(first, 49) ThenBlock: { choice = 1 }    // '1'
            IfCondition EqualTo(first, 50) ThenBlock: { choice = 2 }    // '2'
            IfCondition EqualTo(first, 48) ThenBlock: { choice = -1 }   // '0'
            IfCondition EqualTo(first, 113) ThenBlock: { choice = -1 }  // 'q'
        }
        Deallocate(buf, 64)
        ReturnValue(choice)
    }
}

// =============================================================================
// CHILD PROCESS MANAGEMENT
// =============================================================================
// Fork+exec a tool service binary. Redirects child stdout+stderr to
// /dev/null so the chat output stays clean. Stores PID for cleanup.
// Returns child PID, or -1 on failure.
// Read /proc/self/environ and build a NULL-terminated envp array of
// pointers into a heap buffer. AILang runtime crashes on minimal env
// (just PATH+HOME etc isn't enough), so the right thing is to inherit
// whatever env ClaudeCode itself was launched with.
Function.CC_BuildInheritedEnvp {
    Output: Address
    Body: {
        fd = SystemCall(CCSys.SYS_OPEN, "/proc/self/environ", 0, 0, 0, 0)
        IfCondition LessThan(fd, 0) ThenBlock: { ReturnValue(0) }
        buf = Allocate(16384)
        n = SystemCall(0, fd, buf, 16384, 0, 0)         // SYS_READ = 0
        SystemCall(CCSys.SYS_CLOSE, fd, 0, 0, 0, 0)
        IfCondition LessEqual(n, 0) ThenBlock: { ReturnValue(0) }

        // Walk the NUL-separated entries, build a pointer array.
        envp = Allocate(4096)                            // up to 512 entries
        idx = 0
        StoreValue(Add(envp, 0), buf)                    // first entry = buf
        i = 0
        WhileLoop LessThan(i, n) {
            IfCondition EqualTo(GetByte(buf, i), 0) ThenBlock: {
                next_pos = Add(i, 1)
                IfCondition LessThan(next_pos, n) ThenBlock: {
                    idx = Add(idx, 1)
                    StoreValue(Add(envp, Multiply(idx, 8)), Add(buf, next_pos))
                }
            }
            i = Add(i, 1)
        }
        // NULL-terminate the envp array
        StoreValue(Add(envp, Multiply(Add(idx, 1), 8)), 0)
        ReturnValue(envp)
    }
}

// Quick file logger for CC_LaunchTool diagnostics — same file as IPCDispatch.
Function.CC_LaunchLog {
    Input: msg: Address
    Body: {
        fd = SystemCall(2, "/tmp/cc-ipcd.log", 1089, 420, 0, 0)
        IfCondition GreaterEqual(fd, 0) ThenBlock: {
            SystemCall(1, fd, msg, StringLength(msg), 0, 0)
            SystemCall(3, fd, 0, 0, 0, 0)
        }
    }
}

Function.CC_LaunchTool {
    Input: binary_path: Address
    Output: Integer
    Body: {
        CC_LaunchLog("[launch] BEGIN ")
        CC_LaunchLog(binary_path)
        CC_LaunchLog("\n")
        // Build envp BEFORE fork so the child inherits the buffer (COW).
        envp = CC_BuildInheritedEnvp()
        IfCondition EqualTo(envp, 0) ThenBlock: {
            CC_LaunchLog("[launch] FAIL build_envp\n")
        }
        pid = SystemCall(CCSys.SYS_FORK, 0, 0, 0, 0, 0)
        IfCondition LessThan(pid, 0) ThenBlock: {
            CC_LaunchLog("[launch] FAIL fork ")
            CC_LaunchLog(binary_path)
            CC_LaunchLog("\n")
            ReturnValue(-1)
        }
        IfCondition EqualTo(pid, 0) ThenBlock: {
            // Child — log BEFORE dup2 so logger still has stderr if needed.
            CC_LaunchLog("[launch] CHILD pre_exec ")
            CC_LaunchLog(binary_path)
            CC_LaunchLog("\n")
            // Die automatically when parent exits for any reason (crash, kill, etc.)
            SystemCall(CCSys.SYS_PRCTL, CCSys.PR_SET_PDEATHSIG, CCSys.SIGTERM, 0, 0, 0)
            // Silence stdout/stderr, exec
            devnull = SystemCall(CCSys.SYS_OPEN, "/dev/null", 1, 0, 0, 0)
            IfCondition GreaterEqual(devnull, 0) ThenBlock: {
                SystemCall(CCSys.SYS_DUP2, devnull, 1, 0, 0, 0)
                SystemCall(CCSys.SYS_DUP2, devnull, 2, 0, 0, 0)
                SystemCall(CCSys.SYS_CLOSE, devnull, 0, 0, 0, 0)
            }
            argv = Allocate(16)
            StoreValue(Add(argv, 0), binary_path)
            StoreValue(Add(argv, 8), 0)
            ret = SystemCall(CCSys.SYS_EXECVE, binary_path, argv, envp)
            // execve returned -> failed
            CC_LaunchLog("[launch] CHILD EXECVE_FAILED ret=")
            CC_LaunchLog(NumberToString(ret))
            CC_LaunchLog(" for ")
            CC_LaunchLog(binary_path)
            CC_LaunchLog("\n")
            SystemCall(CCSys.SYS_EXIT, 127, 0, 0, 0, 0)
        }
        // Parent — record PID
        IfCondition LessThan(CCRunState.child_count, CCConst.MAX_CHILDREN) ThenBlock: {
            slot = Multiply(CCRunState.child_count, 8)
            StoreValue(Add(CCRunState.child_pids, slot), pid)
            CCRunState.child_count = Add(CCRunState.child_count, 1)
        }
        ReturnValue(pid)
    }
}

// SIGTERM every child we spawned. Best-effort; if a service is already
// gone, kill returns -ESRCH and we ignore it.
Function.CC_KillAllChildren {
    Body: {
        i = 0
        WhileLoop LessThan(i, CCRunState.child_count) {
            slot = Multiply(i, 8)
            pid = Dereference(Add(CCRunState.child_pids, slot))
            IfCondition GreaterThan(pid, 0) ThenBlock: {
                SystemCall(CCSys.SYS_KILL, pid, CCSys.SIGTERM, 0, 0, 0)
            }
            i = Add(i, 1)
        }
    }
}

// Kill any cc_*_ipc.x workers left over from a previous session.
// PR_SET_PDEATHSIG is unreliable on WSL2 — sockets stay held and the new
// launch hangs. fork+exec pkill cleans everything up in one shot.
Function.CC_KillStaleTools {
    Body: {
        pkill_path = "/usr/bin/pkill"
        arg1 = "-9"
        arg2 = "-f"
        arg3 = "cc_.*_ipc"
        argv = Allocate(40)
        StoreValue(Add(argv, 0),  pkill_path)
        StoreValue(Add(argv, 8),  arg1)
        StoreValue(Add(argv, 16), arg2)
        StoreValue(Add(argv, 24), arg3)
        StoreValue(Add(argv, 32), 0)
        pid = SystemCall(CCSys.SYS_FORK, 0, 0, 0, 0, 0)
        IfCondition EqualTo(pid, 0) ThenBlock: {
            envp = Allocate(8)
            StoreValue(envp, 0)
            SystemCall(CCSys.SYS_EXECVE, pkill_path, argv, envp)
            SystemCall(CCSys.SYS_EXIT, 0, 0, 0, 0, 0)
        }
        IfCondition GreaterThan(pid, 0) ThenBlock: {
            status = Allocate(8)
            StoreValue(status, 0)
            SystemCall(CCSys.SYS_WAIT4, pid, status, 0, 0, 0)
            Deallocate(status, 8)
            ts = Allocate(16)
            StoreValue(Add(ts, 0), 0)
            StoreValue(Add(ts, 8), 200000000)
            SystemCall(CCSys.SYS_NANOSLEEP, ts, 0, 0, 0, 0)
            Deallocate(ts, 16)
        }
        Deallocate(argv, 40)
    }
}

// Brief sleep (nanosleep) so services have time to bind their sockets
// before we try to connect. Sleeps for CCConst.BIND_WAIT_NS nanoseconds.
Function.CC_SleepShort {
    Body: {
        // This is a source of race conditions. It has been disabled in favor
        // of a robust retry loop in IPCDispatch.RegisterTool.
    }
}

// =============================================================================
// INTRUSIVE THOUGHTS — rotating dystopian quotes during TTFT wait.
// File has two concatenated JSON objects; we parse only the first.
// =============================================================================
Function.CC_LoadQuotes {
    Input: path: Address
    Body: {
        fd = SystemCall(CCSys.SYS_OPEN, path, 0, 0, 0, 0)
        IfCondition LessThan(fd, 0) ThenBlock: { ReturnValue(0) }
        buf = Allocate(32768)
        n = SystemCall(CCSys.SYS_READ, fd, buf, 32767, 0, 0)
        SystemCall(CCSys.SYS_CLOSE, fd, 0, 0, 0, 0)
        IfCondition LessEqual(n, 0) ThenBlock: {
            Deallocate(buf, 32768)
            ReturnValue(0)
        }
        // Null-terminate after first top-level '}' so ParseJSON sees one object.
        // Pattern: }\n\n{ separates the two concatenated objects in the file.
        i = 0
        WhileLoop LessThan(i, Subtract(n, 3)) {
            IfCondition EqualTo(GetByte(buf, i), 125) ThenBlock: {       // '}'
                IfCondition EqualTo(GetByte(buf, Add(i, 1)), 10) ThenBlock: {   // '\n'
                    IfCondition EqualTo(GetByte(buf, Add(i, 2)), 10) ThenBlock: {  // '\n'
                        IfCondition EqualTo(GetByte(buf, Add(i, 3)), 123) ThenBlock: { // '{'
                            SetByte(buf, Add(i, 1), 0)
                            i = n
                        }
                    }
                }
            }
            i = Add(i, 1)
        }
        SetByte(buf, n, 0)
        // buf is NOT freed — JSON parser stores raw pointers into it.
        parsed = ParseJSON(buf)
        IfCondition EqualTo(parsed, 0) ThenBlock: { ReturnValue(0) }
        obj = JSON.AsObject(parsed)
        IfCondition EqualTo(obj, 0) ThenBlock: { ReturnValue(0) }
        arr = JSON.GetArray(obj, "main_set")
        IfCondition EqualTo(arr, 0) ThenBlock: { ReturnValue(0) }
        QuoteState.arr = arr
        QuoteState.count = JSON.ArrayLength(arr)
        // Seed RNG with current Unix time for variety each session
        QuoteState.rng = SystemCall(CCSys.SYS_TIME, 0, 0, 0, 0, 0)
        QuoteState.last_sec = QuoteState.rng
    }
}

Function.CC_NextQuote {
    Output: Address
    Body: {
        IfCondition EqualTo(QuoteState.count, 0) ThenBlock: { ReturnValue(0) }
        // Classic 32-bit Numerical Recipes LCG
        QuoteState.rng = Add(Multiply(QuoteState.rng, 1664525), 1013904223)
        rng_val = QuoteState.rng
        IfCondition LessThan(rng_val, 0) ThenBlock: { rng_val = Subtract(0, rng_val) }
        idx = Modulo(rng_val, QuoteState.count)
        q_tag = JSON.ArrayGet(QuoteState.arr, idx)
        ReturnValue(JSON.AsString(q_tag))
    }
}

Function.CC_ShowQuote {
    Body: {
        q = CC_NextQuote()
        IfCondition NotEqual(q, 0) ThenBlock: {
            UI.SetQuote(q)
        }
    }
}

// Called every 100ms while waiting for TTFT. Ticks the mascot every call,
// shows a new quote exactly every 10 seconds using wall-clock time.
Function.CC_AnimTick {
    Body: {
        UI.AnimTick()
        
        now_sec = SystemCall(CCSys.SYS_TIME, 0, 0, 0, 0, 0)
        elapsed = Subtract(now_sec, QuoteState.last_sec)
        IfCondition LessThan(elapsed, 0) ThenBlock: { QuoteState.last_sec = now_sec }
        IfCondition GreaterEqual(elapsed, 10) ThenBlock: { 
            CC_ShowQuote()
            QuoteState.last_sec = now_sec
        }
    }
}

// =============================================================================
// AGENT TURN — one user-message-to-final-response cycle.
// Runs the request->stream->maybe-dispatch-tools loop until the model
// stops calling tools.
// =============================================================================
Function.CC_RunTurn {
    Body: {
        keep_going = 1
        chain_count = 0
        CC_DebugLog("\n\n==================== NEW TURN ====================\n")
        WhileLoop EqualTo(keep_going, 1) {
            keep_going = 0

            IfCondition And(GreaterEqual(chain_count, 25), EqualTo(CCRunState.auto_approve, 0)) ThenBlock: {
                UI.ChatTag("?", "Agent has chained 25 tools. Continue? [Y/n/a (always) or type to steer]", 3) // 3 = ORANGE
                ans = UI.ReadLine()
                ans_len = StringLength(ans)
                steering = 0
                
                IfCondition EqualTo(ans_len, 0) ThenBlock: {
                    chain_count = 0
                } ElseBlock: {
                    first = GetByte(ans, 0)
                    IfCondition And(EqualTo(ans_len, 1), Or(EqualTo(first, 110), EqualTo(first, 78))) ThenBlock: {
                        UI.ChatTag("✗", "Execution paused.", 1) // 1 = RED
                        BreakLoop
                    } ElseBlock: {
                        IfCondition And(EqualTo(ans_len, 1), Or(EqualTo(first, 97), EqualTo(first, 65))) ThenBlock: {
                            CCRunState.auto_approve = 1
                            UI.ChatTag("✓", "Autonomy approved for the rest of this session.", 2) // 2 = GREEN
                            chain_count = 0
                        } ElseBlock: {
                            IfCondition And(EqualTo(ans_len, 1), Or(EqualTo(first, 121), EqualTo(first, 89))) ThenBlock: {
                                chain_count = 0
                            } ElseBlock: {
                                steering = 1
                            }
                        }
                    }
                }
                IfCondition EqualTo(steering, 1) ThenBlock: {
                    dummy = JSON.NewObject()
                    JSON.SetString(dummy, "role", "assistant")
                    JSON.SetString(dummy, "content", "[System: Awaiting user steering]")
                    IfCondition NotEqual(SelectedProvider.reasoning_effort, 0) ThenBlock: {
                        JSON.SetString(dummy, "reasoning_content", "")
                    }
                    History.AppendRaw(dummy)
                    
                    History.AppendUser(ans)
                    keep_going = 1
                    chain_count = 0
                    ContinueLoop
                }
            }
            chain_count = Add(chain_count, 1)

            // --- Retry Loop for API calls ---
            max_retries = 30
            retry_count = 0
            request_ok = 0
            retry_delay_ms = 2000
            is_interrupted_turn = 0

            WhileLoop And(LessThan(retry_count, max_retries), EqualTo(request_ok, 0)) {

            CC_DebugLog("Building request...\n")

            messages = History.GetMessagesArray()
            tools = IPCDispatch.GetToolSchemasArray()
            body = Backend.BuildRequest(messages, tools)

            body_len_str = StringConcat("Request body size: ", NumberToString(StringLength(body)))
            body_len_str = StringConcat(body_len_str, " bytes\n")
            CC_DebugLog(body_len_str)
            dbg_body_len = StringLength(body)
            IfCondition GreaterThan(dbg_body_len, 256) ThenBlock: { dbg_body_len = 256 }
            dbg_body_buf = Allocate(Add(dbg_body_len, 1))
            MemoryCopy(dbg_body_buf, body, dbg_body_len)
            SetByte(dbg_body_buf, dbg_body_len, 0)
            CC_DebugLog(StringConcat("Request body (first 256 bytes):\n", dbg_body_buf))
            CC_DebugLog("\n---\n")
            Deallocate(dbg_body_buf, Add(dbg_body_len, 1))

            IfCondition EqualTo(body, 0) ThenBlock: { BreakLoop }
            url = Backend.GetURL()

            base_headers = Backend.BuildHeaders()
            // Empty Expect header prevents curl from hanging on 100-continue for >1KB bodies
            ua_header = "User-Agent: HalCode9000/1.0\nExpect:\n"
            
            clen_header = StringConcat("Content-Length: ", NumberToString(StringLength(body)))
            clen_header = StringConcat(clen_header, "\n")
            
            headers = StringConcat(base_headers, ua_header)
            headers = StringConcat(headers, clen_header)

            // DBG: dump full body to /tmp/hal_body.json for forensics
            _bfd = SystemCall(2, "/tmp/hal_body.json", BitwiseOr(BitwiseOr(1,64),512), 420, 0, 0)
            IfCondition GreaterEqual(_bfd, 0) ThenBlock: {
                _bfull = StringLength(body)
                SystemCall(1, _bfd, body, _bfull, 0, 0)
                SystemCall(3, _bfd, 0, 0, 0, 0)
            }
            // DBG: log url + headers to /tmp/hal_turn.log
            _dfd = SystemCall(2, "/tmp/hal_turn.log", BitwiseOr(BitwiseOr(1,64),512), 420, 0, 0)
            IfCondition GreaterEqual(_dfd, 0) ThenBlock: {
                SystemCall(1, _dfd, "URL: ", 5, 0, 0)
                SystemCall(1, _dfd, url, StringLength(url), 0, 0)
                SystemCall(1, _dfd, "\n", 1, 0, 0)
                SystemCall(1, _dfd, "HDR: ", 5, 0, 0)
                _hlen = StringLength(headers)
                IfCondition GreaterThan(_hlen, 60) ThenBlock: { _hlen = 60 }
                SystemCall(1, _dfd, headers, _hlen, 0, 0)
                SystemCall(1, _dfd, "\n", 1, 0, 0)
                SystemCall(1, _dfd, "BODY_LEN: ", 10, 0, 0)
                _bnum = NumberToString(StringLength(body))
                SystemCall(1, _dfd, _bnum, StringLength(_bnum), 0, 0)
                SystemCall(1, _dfd, "\n", 1, 0, 0)
                SystemCall(3, _dfd, 0, 0, 0, 0)
            }

            UI.SetState(1)
            CC_ShowQuote()
            QuoteState.last_sec = SystemCall(CCSys.SYS_TIME, 0, 0, 0, 0, 0)
            CC_DebugLog("Sending HTTP POST request...\n")

            IfCondition GreaterThan(retry_count, 0) ThenBlock: {
                retry_msg = StringConcat("Retrying request (", NumberToString(Add(retry_count, 1)))
                retry_msg = StringConcat(retry_msg, "/")
                retry_msg = StringConcat(retry_msg, NumberToString(max_retries))
                retry_msg = StringConcat(retry_msg, ")...")
                UI.ChatPrintDim(retry_msg)
            }

            handle = HTTP.PostStream(url, headers, body, 10000, 900000)
            IfCondition EqualTo(handle, 0) ThenBlock: {
                CC_DebugLog("HTTP.PostStream FAILED (curl spawn error).\n")
                UI.ChatTag("✗", "HTTP request failed (curl spawn)", 1)
                CC_SleepMs(CC_RandomMs(retry_delay_ms))
                retry_delay_ms = Multiply(retry_delay_ms, 2)
                IfCondition GreaterThan(retry_delay_ms, 30000) ThenBlock: { retry_delay_ms = 30000 }
                retry_count = Add(retry_count, 1)
                ContinueLoop
            }

            sse_state = Allocate(CCConst.SSE_STATE_SZ)
            SSE.Init(sse_state, CCConst.SSE_STATE_SZ)
            line_buf = Allocate(CCConst.LINE_BUF_SZ)
            CC_DebugLog("Starting API stream read. See /tmp/hal_turn.log for raw line data.\n")

            stream_done = 0
            line_count = 0
            is_api_error = 0
            clean_stop = 0
            consecutive_timeouts = 0
            WhileLoop EqualTo(stream_done, 0) {
                CC_AnimTick()
                
                IfCondition EqualTo(UI.HasInterrupt(), 1) ThenBlock: {
                    CC_DebugLog("User interrupted stream.\n")
                    stream_done = 1
                    is_interrupted_turn = 1
                    BreakLoop
                }

                // Read up to SZ-1 so we can safely null-terminate the buffer for UI/String functions
                line_len = HTTP.ReadLineTimeout(handle, line_buf, Subtract(CCConst.LINE_BUF_SZ, 1), 15)
                IfCondition EqualTo(line_len, -2) ThenBlock: {
                    IfCondition EqualTo(UI.HasInterrupt(), 1) ThenBlock: {
                        CC_DebugLog("User interrupted stream.\n")
                        stream_done = 1
                        is_interrupted_turn = 1
                        BreakLoop
                    }
                    consecutive_timeouts = Add(consecutive_timeouts, 1)
                    IfCondition GreaterThan(consecutive_timeouts, 6000) ThenBlock: {
                        CC_DebugLog("Stream timed out (no data for 90s).\n")
                        stream_done = 1
                        BreakLoop
                    }
                    ContinueLoop
                }
                consecutive_timeouts = 0
                IfCondition GreaterEqual(line_len, 0) ThenBlock: {
                    SetByte(line_buf, line_len, 0)
                }
                    _lfd = SystemCall(2, "/tmp/hal_turn.log", BitwiseOr(BitwiseOr(1,64),1024), 420, 0, 0)
                    IfCondition GreaterEqual(_lfd, 0) ThenBlock: {
                        SystemCall(1, _lfd, "LINE(", 5, 0, 0)
                        _lln = Allocate(8)
                        _ll2 = NumberToString(line_len)
                        SystemCall(1, _lfd, _ll2, StringLength(_ll2), 0, 0)
                        SystemCall(1, _lfd, "): ", 3, 0, 0)
                        IfCondition GreaterThan(line_len, 0) ThenBlock: {
                            SystemCall(1, _lfd, line_buf, line_len, 0, 0)
                        }
                        SystemCall(1, _lfd, "\n", 1, 0, 0)
                        SystemCall(3, _lfd, 0, 0, 0, 0)
                        Deallocate(_lln, 8)
                    }
                    line_count = Add(line_count, 1)
                IfCondition LessThan(line_len, 0) ThenBlock: {
                    stream_done = 1
                } ElseBlock: {
                    // Catch raw JSON errors (429 Rate Limit, 400 Bad Request) that aren't SSE
                    first_b = GetByte(line_buf, 0)
                    is_err_fmt = 0
                    IfCondition Or(EqualTo(first_b, 123), EqualTo(first_b, 60)) ThenBlock: { is_err_fmt = 1 } // { or <
                    IfCondition And(EqualTo(is_api_error, 0), EqualTo(is_err_fmt, 1)) ThenBlock: {
                        is_api_error = 1
                        UI.SetState(0)
                        UI.ChatTag("✗", "API Error (Rate Limit / Bad Request):", 1) // 1 = RED_FG
                    }
                    
                    IfCondition EqualTo(is_api_error, 1) ThenBlock: {
                        IfCondition GreaterThan(line_len, 0) ThenBlock: {
                            UI.ChatPrintln(line_buf)
                        }
                    } ElseBlock: {
                        ready = SSE.FeedLine(sse_state, line_buf, line_len)
                        IfCondition EqualTo(ready, 1) ThenBlock: {
                            evt_type = SSE.GetEventType(sse_state)
                            evt_data = SSE.GetEventData(sse_state)
                            signal = Backend.OnEvent(evt_type, evt_data)
                            SSE.Reset(sse_state)
                            IfCondition NotEqual(signal, 0) ThenBlock: {
                                stream_done = 1
                                clean_stop = 1
                            }
                        }
                    }
                }
            }

            HTTP.CloseStream(handle)
            Deallocate(line_buf, CCConst.LINE_BUF_SZ)
            Deallocate(sse_state, CCConst.SSE_STATE_SZ)

            // Check if the backend saw a finish_reason before the connection dropped
            IfCondition EqualTo(clean_stop, 0) ThenBlock: {
                clean_stop = Backend.IsCleanStop()
            }

            // Check for mid-stream drop
            IfCondition And(EqualTo(clean_stop, 0), EqualTo(is_api_error, 0)) ThenBlock: {
                IfCondition EqualTo(is_interrupted_turn, 1) ThenBlock: {
                    UI.ChatTag("✗", "Turn interrupted by user.", 3) // 3 = ORANGE_FG
                    
                    user_msg = UI.ConsumeInterrupt()
                    UI.ChatTag("›", user_msg, 6) // 6 = CYAN_FG
                    History.AppendUser(user_msg)
                    Deallocate(user_msg, Add(StringLength(user_msg), 1))
                    
                    // Sever the turn and command the outer loop to start a fresh API call
                    keep_going = 1
                    BreakLoop
                } ElseBlock: {
                    CC_DebugLog("API stream DROPPED without clean stop.\n")
                    UI.ChatTag("✗", "API connection dropped mid-stream (Overload / Timeout)", 1)
                    UI.SetState(0)
                    is_api_error = 1
                }
            } ElseBlock: {
                IfCondition EqualTo(is_api_error, 0) ThenBlock: {
                    CC_DebugLog("API stream finished with clean stop.\n")
                }
            }

            // If there was any API error, retry with backoff. Otherwise, mark as success.
            IfCondition EqualTo(is_api_error, 1) ThenBlock: {
                CC_DebugLog(StringConcat("API error detected. Retry ", NumberToString(Add(retry_count, 1))))
                CC_DebugLog("\n")
                retry_count = Add(retry_count, 1)
                IfCondition LessThan(retry_count, max_retries) ThenBlock: {
                    CC_SleepMs(CC_RandomMs(retry_delay_ms))
                    retry_delay_ms = Multiply(retry_delay_ms, 2)
                    IfCondition GreaterThan(retry_delay_ms, 30000) ThenBlock: { retry_delay_ms = 30000 }
                    Backend.Reset()
                    UI.SetReasoning("")
                }
            } ElseBlock: {
                request_ok = 1
                CC_DebugLog("Request OK.\n")
            }

            } // --- End of Retry Loop ---

            UI.SetState(2)
            UI.ChatPrintln("")
            IfCondition EqualTo(request_ok, 0) ThenBlock: {
                UI.ChatTag("✗", "All retries exhausted. Any completed tool work is in /tmp/hal_turn_log.txt", 1)
            }

            // Only commit to history and dispatch tools if the final request was successful
            IfCondition EqualTo(request_ok, 1) ThenBlock: {
                CC_DebugLog("Committing assistant message to history.\n")
                Backend.CommitAssistantToHistory()
                CC_SessionLogResponse()
                Backend.PrintUsage()

                // Pending tools?
                pending = Backend.GetPendingTools()
                n_tools = JSON.ArrayLength(pending)
                IfCondition GreaterThan(n_tools, 0) ThenBlock: {
                    log_nt = StringConcat("Model requested ", NumberToString(n_tools))
                    log_nt = StringConcat(log_nt, " tool calls.\n")
                    CC_DebugLog(log_nt)
                    UI.ToolGroupStart(n_tools)
                    results = JSON.NewArray()
                    i = 0
                    WhileLoop LessThan(i, n_tools) {
                        tu_tag = JSON.ArrayGet(pending, i)
                        tu = JSON.AsObject(tu_tag)
                        IfCondition NotEqual(tu, 0) ThenBlock: {
                            // Use stable accessors that bypass the JSON-lib
                            // hash-collision bug. Name/id come from a parallel
                            // string-pointer array stashed at content_block_start.
                            tname = Backend.GetToolName(i)
                            tid   = Backend.GetToolId(i)
                            tinput = JSON.GetObject(tu, "input")

                            // Build a short arg summary for display.
                            // Use "path" if present, else the first JSON value, else "".
                            arg_sum = ""
                            IfCondition NotEqual(tinput, 0) ThenBlock: {
                                ps = JSON.GetString(tinput, "path")
                                IfCondition NotEqual(ps, 0) ThenBlock: { arg_sum = ps }
                                IfCondition EqualTo(StringLength(arg_sum), 0) ThenBlock: {
                                    cs = JSON.GetString(tinput, "command")
                                    IfCondition NotEqual(cs, 0) ThenBlock: { arg_sum = cs }
                                }
                                IfCondition EqualTo(StringLength(arg_sum), 0) ThenBlock: {
                                    us = JSON.GetString(tinput, "url")
                                    IfCondition NotEqual(us, 0) ThenBlock: { arg_sum = us }
                                }
                                IfCondition EqualTo(StringLength(arg_sum), 0) ThenBlock: {
                                    tp = JSON.GetString(tinput, "task_prompt")
                                    IfCondition NotEqual(tp, 0) ThenBlock: { arg_sum = tp }
                                }
                                IfCondition EqualTo(StringLength(arg_sum), 0) ThenBlock: {
                                    op = JSON.GetString(tinput, "op")
                                    IfCondition NotEqual(op, 0) ThenBlock: {
                                        qy = JSON.GetString(tinput, "query")
                                        IfCondition NotEqual(qy, 0) ThenBlock: { arg_sum = StringConcat(op, " ")  arg_sum = StringConcat(arg_sum, qy) }
                                        IfCondition EqualTo(qy, 0) ThenBlock: { arg_sum = op }
                                    }
                                }
                            }
                            UI.ToolCallStart(tname, arg_sum, i, n_tools)

                            log_msg = StringConcat("Dispatching tool [", tname)
                            log_msg = StringConcat(log_msg, "]\n")
                            CC_DebugLog(log_msg)

                            err_holder = Allocate(8)
                            StoreValue(err_holder, 0, "dword")
                            content = IPCDispatch.Dispatch(tname, tinput, tid, err_holder)
                            is_err = Dereference(err_holder, "dword")
                            Deallocate(err_holder, 8)
                            ok_flag = 1

                            log_msg = StringConcat("Tool [", tname)
                            log_msg = StringConcat(log_msg, "] returned. is_err=")
                            log_msg = StringConcat(log_msg, NumberToString(is_err))
                            log_msg = StringConcat(log_msg, ". Content size: ")
                            log_msg = StringConcat(log_msg, NumberToString(StringLength(content)))
                            log_msg = StringConcat(log_msg, " bytes.\n")
                            CC_DebugLog(log_msg)
                            CC_DebugLog("Tool content (first 256 bytes):\n---\n")
                            dbg_tool_len = StringLength(content)
                            IfCondition GreaterThan(dbg_tool_len, 256) ThenBlock: { dbg_tool_len = 256 }
                            CC_DebugLog(StringConcat(content, "\n---\n"))

                            IfCondition EqualTo(is_err, 1) ThenBlock: { ok_flag = 0 }
                            UI.ToolCallEnd(ok_flag, i, n_tools)
                            CC_TurnLog(tname, arg_sum, content)

                            // Park large results in pgmem — avoids stuffing 50KB bash
                            // output into context on every subsequent turn.
                            IfCondition GreaterThan(StringLength(content), CCConst.PARK_THRESHOLD) ThenBlock: {
                                park_key = StringConcat("result_", tname)
                                park_key = StringConcat(park_key, "_")
                                t_now = SystemCall(CCSys.SYS_TIME, 0, 0, 0, 0, 0)
                                park_key = StringConcat(park_key, NumberToString(t_now))
                                park_args = JSON.NewObject()
                                JSON.SetString(park_args, "op", "park")
                                JSON.SetString(park_args, "key", park_key)
                                JSON.SetString(park_args, "kind", "tool_result")
                                JSON.SetString(park_args, "content", content)
                                perr = Allocate(8)
                                StoreValue(perr, 0, "dword")
                                pgmem_ret = IPCDispatch.Dispatch("Pgmem", park_args, "", perr)
                                park_failed = Dereference(perr, "dword")
                                Deallocate(perr, 8)
                                IfCondition EqualTo(park_failed, 0) ThenBlock: {
                                    CC_DebugLog("Parked large tool output to Pgmem.\n")
                                    nbytes = NumberToString(StringLength(content))
                                    stub = StringConcat("[Output parked to memory (", nbytes)
                                    stub = StringConcat(stub, " bytes). Key: ")
                                    stub = StringConcat(stub, park_key)
                                    stub = StringConcat(stub, ". Call Pgmem with {\"op\":\"search\",\"query\":\"<text>\"} to search it. Avoid op=\"pickup\" to prevent context overflow.]")
                                    content = stub
                                } ElseBlock: {
                                    CC_DebugLog("Pgmem parking FAILED. Truncating output.\n")
                                    // Fallback: hard truncate output if Pgmem parking fails
                                    orig_len_str = NumberToString(StringLength(content))
                                    t_buf = Allocate(Add(CCConst.PARK_THRESHOLD, 1))
                                    k_cp = 0
                                    WhileLoop LessThan(k_cp, CCConst.PARK_THRESHOLD) {
                                        SetByte(t_buf, k_cp, GetByte(content, k_cp))
                                        k_cp = Add(k_cp, 1)
                                    }
                                    SetByte(t_buf, CCConst.PARK_THRESHOLD, 0)
                                    
                                    warn_msg = StringConcat("\n\n[WARNING: Output truncated to ", NumberToString(CCConst.PARK_THRESHOLD))
                                    warn_msg = StringConcat(warn_msg, " bytes. Full size: ")
                                    warn_msg = StringConcat(warn_msg, orig_len_str)
                                    warn_msg = StringConcat(warn_msg, " bytes. Pgmem parking failed!]")
                                    
                                    content = StringConcat(t_buf, warn_msg)
                                    Deallocate(t_buf, Add(CCConst.PARK_THRESHOLD, 1))
                                }
                            }

                            r = JSON.NewObject()
                            IfCondition NotEqual(tid, 0) ThenBlock: {
                                JSON.SetString(r, "tool_use_id", tid)
                            }
                            IfCondition NotEqual(content, 0) ThenBlock: {
                                JSON.SetString(r, "content", content)
                            }
                            IfCondition EqualTo(is_err, 1) ThenBlock: {
                                JSON.SetBool(r, "is_error", 1)
                            }
                            JSON.PushObject(results, r)
                        }
                        i = Add(i, 1)
                    }
                    CC_DebugLog("Appending tool results to history.\n")
                    UI.ToolGroupEnd(n_tools)
                    Backend.AppendToolResultsToHistory(results)
                    Backend.Reset()
                    UI.SetReasoning("")
                    keep_going = 1
                } ElseBlock: {
                    CC_DebugLog("No tools requested. Turn complete.\n")
                    Backend.Reset()
                    UI.SetReasoning("")
                }
            } ElseBlock: {
                IfCondition EqualTo(is_interrupted_turn, 1) ThenBlock: {
                    CC_DebugLog("Turn interrupted. Restarting with new user input.\n")
                    Backend.Reset()
                    CC_SleepMs(1000)
                } ElseBlock: {
                    CC_DebugLog("Request FAILED after retries. Turn aborted.\n")
                    UI.ChatTag("✗", "Turn failed after retries. Results saved to /tmp/hal_turn_log.txt — try again and ask the model to write in smaller chunks (<=500 lines per Write call).", 1)
                    Backend.Reset()
                }
            }
        }
    }
}

// =============================================================================
// DEMO MODE — render a sample conversation without real auth/tools.
// Now driven by the raw-mode UI primitives.
// =============================================================================
Function.CC_RunDemo {
    Body: {
        UI.Init()
        UI.SessionHeader(0, 0, 0)
        UI.ChatTag("›", "read /etc/hostname", 6)
        UI.ToolCallStart("Read", "/etc/hostname")
        UI.ToolCallEnd(1)
        UI.ChatPrintln("")
        UI.ChatPrintln("The file /etc/hostname contains: <hostname>")
        UI.ChatPrintln("")
        UI.PrintHelp()
        // Block until the user hits a key, then exit cleanly
        UI.ReadLine()
        UI.Shutdown()
    }
}

// Prompt user for a new provider connection and write it to
// ~/.halcode/connections/conn_<ts>.json.  Returns 1 on success, 0 on cancel.
Function.CC_PromptAddConnection {
    Output: Integer
    Body: {
        CC_PrintStepHeader("Add Connection")
        CC_WriteStdout("  Backend type:\n")
        CC_WriteStdout("    1) Anthropic\n")
        CC_WriteStdout("    2) OpenAI-compatible  (OpenRouter, Grok, local, etc.)\n")
        CC_WriteStdout("    0) Cancel\n\n")
        CC_WriteStdout("  Choice: ")
        kbuf = Allocate(8)
        CC_ReadStdinLine(kbuf, 8)
        kind_ch = GetByte(kbuf, 0)
        Deallocate(kbuf, 8)
        IfCondition EqualTo(kind_ch, 48) ThenBlock: { ReturnValue(0) }   // '0' cancel

        backend_str = "openai"
        base_url_default = ""
        api_path_default = "/v1/chat/completions"
        IfCondition EqualTo(kind_ch, 49) ThenBlock: {   // '1' Anthropic
            backend_str = "anthropic"
            base_url_default = "https://api.anthropic.com"
            api_path_default = "/v1/messages"
        }

        CC_WriteStdout("\n  Display name: ")
        name_buf = Allocate(64)
        CC_ReadStdinLine(name_buf, 64)
        IfCondition EqualTo(StringLength(name_buf), 0) ThenBlock: {
            Deallocate(name_buf, 64)
            ReturnValue(0)
        }

        CC_WriteStdout("  Model (e.g. grok-3, meta-llama/llama-3.3-70b-instruct:free): ")
        model_buf = Allocate(128)
        CC_ReadStdinLine(model_buf, 128)
        IfCondition EqualTo(StringLength(model_buf), 0) ThenBlock: {
            Deallocate(name_buf, 64)
            Deallocate(model_buf, 128)
            ReturnValue(0)
        }

        url_buf = Allocate(128)
        IfCondition EqualTo(kind_ch, 49) ThenBlock: {   // Anthropic — URL is fixed
            i = 0
            WhileLoop LessThan(i, StringLength(base_url_default)) {
                SetByte(url_buf, i, GetByte(base_url_default, i))
                i = Add(i, 1)
            }
            SetByte(url_buf, i, 0)
        } ElseBlock: {
            CC_WriteStdout("  Base URL (e.g. https://openrouter.ai/api  or  https://api.x.ai): ")
            CC_ReadStdinLine(url_buf, 128)
            IfCondition EqualTo(StringLength(url_buf), 0) ThenBlock: {
                Deallocate(name_buf, 64)
                Deallocate(model_buf, 128)
                Deallocate(url_buf, 128)
                ReturnValue(0)
            }
        }

        // API path defaults are correct for all known providers; skip prompt
        api_path_str = api_path_default

        hint_buf = Allocate(32)
        CC_WriteStdout("  API key env-var hint (e.g. openrouter, xai, openai): ")
        CC_ReadStdinLine(hint_buf, 32)
        IfCondition EqualTo(StringLength(hint_buf), 0) ThenBlock: {
            hint_buf = "apikey"
        }

        // Build JSON manually — avoids Library.JSON hash-collision bug on write
        json = StringConcat("{\"name\":\"", name_buf)
        json = StringConcat(json, "\",\"backend\":\"")
        json = StringConcat(json, backend_str)
        json = StringConcat(json, "\",\"base_url\":\"")
        json = StringConcat(json, url_buf)
        json = StringConcat(json, "\",\"api_path\":\"")
        json = StringConcat(json, api_path_str)
        json = StringConcat(json, "\",\"default_model\":\"")
        json = StringConcat(json, model_buf)
        json = StringConcat(json, "\",\"key_hint\":\"")
        json = StringConcat(json, hint_buf)
        json = StringConcat(json, "\"}")

        // Write ~/.halcode/connections/conn_<timestamp>.json
        t = SystemCall(CCSys.SYS_TIME, 0, 0, 0, 0, 0)
        conn_dir = CC_ExpandHome("~/.halcode/connections")
        SystemCall(CCSys.SYS_MKDIR, conn_dir, 493, 0, 0, 0)   // 0755, ignores EEXIST
        fpath = StringConcat(conn_dir, "/conn_")
        fpath = StringConcat(fpath, NumberToString(t))
        fpath = StringConcat(fpath, ".json")
        // O_WRONLY|O_CREAT|O_TRUNC = 1|64|512 = 577, mode 0644 = 420
        wfd = SystemCall(CCSys.SYS_OPEN, fpath, 577, 420, 0, 0)
        IfCondition LessThan(wfd, 0) ThenBlock: {
            CC_WriteStdout("\n  Error: could not write connection file.\n")
            ReturnValue(0)
        }
        SystemCall(CCSys.SYS_WRITE, wfd, json, StringLength(json), 0, 0)
        SystemCall(CCSys.SYS_CLOSE, wfd, 0, 0, 0, 0)
        CC_WriteStdout("\n  Saved: ")
        CC_WriteStdout(fpath)
        CC_WriteStdout("\n")
        CC_SleepMs(800)
        ReturnValue(1)
    }
}

// Provider selection menu. Writes chosen provider fields into SelectedProvider.*
// (defined in backends/Backend.ailang) so Backend.Init can read them without
// going through JSON hash lookups — avoids the Library.JSON hash-collision bug
// (task #28) that maps "key_hint" and "default_model" to wrong buckets.
// Returns 1 as a non-zero sentinel; 0 means "no choice yet" (used by the
// default-Anthropic fallback inside CC_PromptProvider).
//
// "kind" is a BackendKind integer (1=ANTHROPIC, 2=OPENAI). Stored as an integer
// so Backend.Init can dispatch without StringCompare on the "backend" string —
// which was being clobbered by arena allocations in the Auth flow between
// CC_MakeProvider() and Backend.Init(), causing all OpenAI-compat providers
// (DeepSeek, Groq, etc.) to silently fall through to the Anthropic backend.
Function.CC_MakeProvider {
    Input: name: Address
    Input: backend: Address
    Input: base_url: Address
    Input: api_path: Address
    Input: default_model: Address
    Input: key_hint: Address
    Output: Integer
    Body: {
        SelectedProvider.name             = name
        SelectedProvider.backend          = backend
        SelectedProvider.base_url         = base_url
        SelectedProvider.api_path         = api_path
        SelectedProvider.default_model    = default_model
        SelectedProvider.key_hint         = key_hint
        SelectedProvider.reasoning_effort = 0
        // Detect kind while backend string pointer is fresh (before auth arena churn)
        SelectedProvider.kind = BackendKind.OPENAI
        IfCondition EqualTo(StringCompare(backend, "anthropic"), 0) ThenBlock: {
            SelectedProvider.kind = BackendKind.ANTHROPIC
        }
        IfCondition EqualTo(StringCompare(backend, "gemini"), 0) ThenBlock: {
            SelectedProvider.kind = BackendKind.GEMINI
        }
        ReturnValue(1)
    }
}

Function.CC_PromptProvider {
    Output: Integer
    Body: {
        // Load user-defined connections once before the menu loop
        conn_dir = CC_ExpandHome("~/.halcode/connections")
        custom_arr = Backend.LoadProviders(conn_dir)
        custom_count = 0
        IfCondition NotEqual(custom_arr, 0) ThenBlock: {
            custom_count = XArray.XSize(custom_arr)
        }

        prov = 0
        done = 0
        WhileLoop EqualTo(done, 0) {
            CC_PrintStepHeader("STEP 2: Model Selection")
            CC_WriteStdout("  --- Built-in ---\n")
            CC_WriteStdout("  1. Anthropic    (claude-sonnet-4-6)\n")
            CC_WriteStdout("  2. OpenAI       (gpt-4o)\n")
            CC_WriteStdout("  3. Grok         (xAI — grok-3)\n")
            CC_WriteStdout("  4. Google       (gemini-2.5-flash)\n")
            CC_WriteStdout("  5. DeepSeek     (deepseek-v4-flash)\n")
            CC_WriteStdout("  6. OpenRouter   (300+ models)\n")

            IfCondition GreaterThan(custom_count, 0) ThenBlock: {
                CC_WriteStdout("\n  --- User Connections ---\n")
                ci = 0
                WhileLoop LessThan(ci, custom_count) {
                    cobj = XArray.XGet(custom_arr, ci)
                    cname  = JSON.GetString(cobj, "name")
                    cmodel = JSON.GetString(cobj, "default_model")
                    IfCondition EqualTo(cname, 0) ThenBlock: { cname = "?" }
                    IfCondition EqualTo(cmodel, 0) ThenBlock: { cmodel = "?" }
                    CC_WriteStdout("  ")
                    CC_WriteStdout(NumberToString(Add(ci, 7)))
                    CC_WriteStdout(". ")
                    CC_WriteStdout(cname)
                    CC_WriteStdout("  (")
                    CC_WriteStdout(cmodel)
                    CC_WriteStdout(")\n")
                    ci = Add(ci, 1)
                }
            }

            CC_WriteStdout("\n  a. Add connection\n")
            CC_WriteStdout("  0. Quit\n\n")
            CC_WriteStdout(" Choice [1]: ")

            line_buf = Allocate(16)
            CC_ReadStdinLine(line_buf, 16)
            choice = StringToNumber(line_buf)
            first_ch = GetByte(line_buf, 0)
            Deallocate(line_buf, 16)

            // Add connection — check BEFORE quit so 'a' is not misread as choice=0
            IfCondition Or(EqualTo(first_ch, 97), EqualTo(first_ch, 65)) ThenBlock: {
                added = CC_PromptAddConnection()
                IfCondition EqualTo(added, 1) ThenBlock: {
                    conn_dir2 = CC_ExpandHome("~/.halcode/connections")
                    custom_arr = Backend.LoadProviders(conn_dir2)
                    custom_count = 0
                    IfCondition NotEqual(custom_arr, 0) ThenBlock: {
                        custom_count = XArray.XSize(custom_arr)
                    }
                }
                ContinueLoop
            }

            // Quit / back
            IfCondition Or(EqualTo(choice, 0), EqualTo(first_ch, 113)) ThenBlock: {
                prov = -1
                done = 1
            }

            // 1 — Anthropic
            IfCondition EqualTo(choice, 1) ThenBlock: {
                prov = CC_MakeProvider("Anthropic","anthropic","https://api.anthropic.com",
                                       "/v1/messages",           "claude-sonnet-4-6", "anthropic")
                done = 1
            }
            // 2 — OpenAI
            IfCondition EqualTo(choice, 2) ThenBlock: {
                prov = CC_MakeProvider("OpenAI",   "openai",   "https://api.openai.com",
                                       "/v1/chat/completions",   "gpt-4o",   "openai")
                done = 1
            }
            // 3 — Grok
            IfCondition EqualTo(choice, 3) ThenBlock: {
                prov = CC_MakeProvider("Grok",     "openai",   "https://api.x.ai",
                                       "/v1/chat/completions",   "grok-3",   "xai")
                done = 1
            }
            // 4 — Google
            IfCondition EqualTo(choice, 4) ThenBlock: {
                prov = CC_MakeProvider("Google",   "gemini",   "https://generativelanguage.googleapis.com",
                                       "/v1beta/openai/chat/completions", "gemini-2.5-flash", "google")
                done = 1
            }
            // 5 — DeepSeek with model sub-menu
            IfCondition EqualTo(choice, 5) ThenBlock: {
                prov = CC_MakeProvider("DeepSeek", "openai",   "https://api.deepseek.com",
                                       "/v1/chat/completions",   "deepseek-v4-pro", "deepseek")
                SelectedProvider.reasoning_effort = "medium"
                CC_WriteStdout("\n  DeepSeek model:\n")
                CC_WriteStdout("    a) deepseek-v4-pro   (reasoning)\n")
                CC_WriteStdout("    b) deepseek-v4-flash (fast)\n")
                CC_WriteStdout("    q) Back\n\n")
                CC_WriteStdout("  Choice [a]: ")
                mbuf = Allocate(16)
                CC_ReadStdinLine(mbuf, 16)
                mch = GetByte(mbuf, 0)
                Deallocate(mbuf, 16)
                IfCondition Or(EqualTo(mch, 113), EqualTo(mch, 81)) ThenBlock: { ContinueLoop }
                IfCondition Or(EqualTo(mch, 98), EqualTo(mch, 66)) ThenBlock: {
                    SelectedProvider.default_model    = "deepseek-v4-flash"
                    SelectedProvider.reasoning_effort = 0
                }
                done = 1
            }
            // 6 — OpenRouter with model sub-menu
            IfCondition EqualTo(choice, 6) ThenBlock: {
                prov = CC_MakeProvider("OpenRouter","openai",  "https://openrouter.ai/api",
                                       "/v1/chat/completions",  "anthropic/claude-sonnet-4", "openrouter")
                CC_WriteStdout("\n  OpenRouter model:\n")
                CC_WriteStdout("    a) anthropic/claude-sonnet-4              (recommended)\n")
                CC_WriteStdout("    b) openai/gpt-4o                          (OpenAI)\n")
                CC_WriteStdout("    c) google/gemini-2.5-flash-preview        (Google)\n")
                CC_WriteStdout("    d) meta-llama/llama-3.3-70b-instruct:free (free)\n")
                CC_WriteStdout("    e) deepseek/deepseek-chat-v3-0324:free    (free)\n")
                CC_WriteStdout("    m) Enter model name manually\n")
                CC_WriteStdout("    q) Back\n\n")
                CC_WriteStdout("  Choice [a]: ")
                orbuf = Allocate(16)
                CC_ReadStdinLine(orbuf, 16)
                orch = GetByte(orbuf, 0)
                Deallocate(orbuf, 16)
                IfCondition Or(EqualTo(orch, 113), EqualTo(orch, 81)) ThenBlock: { ContinueLoop }
                IfCondition Or(EqualTo(orch, 98), EqualTo(orch, 66)) ThenBlock: {
                    SelectedProvider.default_model = "openai/gpt-4o"
                }
                IfCondition Or(EqualTo(orch, 99), EqualTo(orch, 67)) ThenBlock: {
                    SelectedProvider.default_model = "google/gemini-2.5-flash-preview"
                }
                IfCondition Or(EqualTo(orch, 100), EqualTo(orch, 68)) ThenBlock: {
                    SelectedProvider.default_model = "meta-llama/llama-3.3-70b-instruct:free"
                }
                IfCondition Or(EqualTo(orch, 101), EqualTo(orch, 69)) ThenBlock: {
                    SelectedProvider.default_model = "deepseek/deepseek-chat-v3-0324:free"
                }
                IfCondition Or(EqualTo(orch, 109), EqualTo(orch, 77)) ThenBlock: {
                    CC_WriteStdout("  Model name: ")
                    manbuf = Allocate(128)
                    CC_ReadStdinLine(manbuf, 128)
                    IfCondition GreaterThan(StringLength(manbuf), 0) ThenBlock: {
                        SelectedProvider.default_model = manbuf
                    }
                }
                done = 1
            }

            // User connections (slots 7+)
            IfCondition EqualTo(done, 0) ThenBlock: {
                max_custom = Add(custom_count, 7)
                IfCondition And(GreaterEqual(choice, 7), LessThan(choice, max_custom)) ThenBlock: {
                    ci = Subtract(choice, 7)
                    cobj = XArray.XGet(custom_arr, ci)
                    cn   = JSON.GetString(cobj, "name")
                    cbk  = JSON.GetString(cobj, "backend")
                    curl = JSON.GetString(cobj, "base_url")
                    cap  = JSON.GetString(cobj, "api_path")
                    cmdl = JSON.GetString(cobj, "default_model")
                    ckh  = JSON.GetString(cobj, "key_hint")
                    IfCondition EqualTo(cn, 0) ThenBlock: { cn = "Custom" }
                    IfCondition EqualTo(cbk, 0) ThenBlock: { cbk = "openai" }
                    IfCondition EqualTo(curl, 0) ThenBlock: { curl = "" }
                    IfCondition EqualTo(cap, 0) ThenBlock: { cap = "/v1/chat/completions" }
                    IfCondition EqualTo(cmdl, 0) ThenBlock: { cmdl = "" }
                    IfCondition EqualTo(ckh, 0) ThenBlock: { ckh = "apikey" }
                    prov = CC_MakeProvider(cn, cbk, curl, cap, cmdl, ckh)
                    done = 1
                }
            }

            // Default: unrecognised input → Anthropic
            IfCondition EqualTo(prov, 0) ThenBlock: {
                IfCondition EqualTo(done, 0) ThenBlock: {
                    prov = CC_MakeProvider("Anthropic","anthropic","https://api.anthropic.com",
                                           "/v1/messages",       "claude-sonnet-4-6", "anthropic")
                    done = 1
                }
            }
        }
        IfCondition NotEqual(prov, -1) ThenBlock: {
            CC_WriteStdout("Using: ")
            CC_WriteStdout(SelectedProvider.name)
            CC_WriteStdout(" / ")
            CC_WriteStdout(SelectedProvider.default_model)
            CC_WriteStdout("\n\n")
            CC_SleepMs(400)
        }
        ReturnValue(prov)
    }
}

// =============================================================================
// SYSTEM INITIALIZATION
// =============================================================================
Function.CC_RunAuth {
    Output: Address
    Body: {
        auth_ok = 0
        auth_result = 0
        WhileLoop EqualTo(auth_ok, 0) {
            auth_mode_choice = CC_PromptAuthMode()
            IfCondition EqualTo(auth_mode_choice, -1) ThenBlock: { ReturnValue(0) }
            chosen_provider = CC_PromptProvider()
            IfCondition EqualTo(chosen_provider, -1) ThenBlock: { ReturnValue(0) }

            CC_PrintStepHeader("STEP 3: System Initialization")
            CC_WriteStdout(" Verifying credentials and launching tool services...\n")

            // Resolve config + client + tokens paths (expand ~)
            cfg_dir = CC_ExpandHome("~/.halcode")
            CC_MkdirP(cfg_dir)
            cfg_path = CC_ExpandHome("~/.halcode/oauth_config.json")
            client_path = CC_ExpandHome("~/.halcode/oauth_client.json")
            tok_path = CC_ExpandHome("~/.halcode/oauth_tokens.json")

            prov_key_hint = SelectedProvider.key_hint

            is_google = 0
            IfCondition EqualTo(StringCompare(SelectedProvider.name, "Google"), 0) ThenBlock: { is_google = 1 }

            env_key = CC_GetEnv("ANTHROPIC_API_KEY")
            IfCondition EqualTo(is_google, 1) ThenBlock: { env_key = CC_GetEnv("GEMINI_API_KEY") }
            IfCondition EqualTo(StringCompare(SelectedProvider.name, "DeepSeek"), 0) ThenBlock: { env_key = CC_GetEnv("DEEPSEEK_API_KEY") }
            IfCondition EqualTo(StringCompare(SelectedProvider.name, "OpenAI"), 0) ThenBlock: { env_key = CC_GetEnv("OPENAI_API_KEY") }
            IfCondition EqualTo(StringCompare(SelectedProvider.name, "Grok"), 0) ThenBlock: { env_key = CC_GetEnv("XAI_API_KEY") }
            IfCondition EqualTo(StringCompare(SelectedProvider.name, "OpenRouter"), 0) ThenBlock: { env_key = CC_GetEnv("OPENROUTER_API_KEY") }

            IfCondition EqualTo(auth_mode_choice, 1) ThenBlock: {
                IfCondition EqualTo(is_google, 1) ThenBlock: {
                    CC_WriteStdout("\n[auth] Initiating Google OAuth flow for Gemini...\n")
                    cfg_path = CC_ExpandHome("~/.halcode/google_oauth_config.json")
                    client_path = CC_ExpandHome("~/.halcode/google_oauth_client.json")
                    tok_path = CC_ExpandHome("~/.halcode/google_oauth_tokens.json")
                    auth_result = Auth.RunOAuthFlow(cfg_path, tok_path)
                } ElseBlock: {
                    // OAuth path is built but the token endpoint rejects our exchange
                    // attempts (rate_limit_error). Awaiting Anthropic guidance on issue
                    // #54184. For now, fall back to key file so the UI is usable.
                    CC_WriteStdout("\n[!] OAuth path is implemented but blocked on Anthropic token-endpoint behavior.\n")
                    CC_WriteStdout("    See github.com/anthropics/claude-code issue #54184.\n")
                    CC_WriteStdout("    Falling back to key file for this session.\n\n")
                    auth_result = Auth.RunAPIKeyFlow(env_key, prov_key_hint)
                }
            } ElseBlock: {
                auth_result = Auth.RunAPIKeyFlow(env_key, prov_key_hint)
            }

            status = JSON.GetString(auth_result, "status")

            // Bootstrap on needs_setup_oauth: offer to write default config and retry
            IfCondition EqualTo(StringCompare(status, "needs_setup_oauth"), 0) ThenBlock: {
                CC_WriteStdout("\nNo OAuth config found at ")
                CC_WriteStdout(cfg_path)
                CC_WriteStdout("\nWould you like me to write a default config now? [y/N] ")
                ans = Allocate(16)
                n = CC_ReadStdinLine(ans, 16)
                IfCondition GreaterThan(n, 0) ThenBlock: {
                    first = GetByte(ans, 0)
                    IfCondition Or(EqualTo(first, 121), EqualTo(first, 89)) ThenBlock: {
                        ok = 0
                        IfCondition EqualTo(is_google, 1) ThenBlock: {
                            CC_WriteStdout("\n[setup] To use Google Gemini, you need a Google Cloud Desktop App Client ID.\n")
                            CC_WriteStdout("        (e.g., 123456-abcdef.apps.googleusercontent.com)\n")
                            CC_WriteStdout("Please paste your Client ID here: ")
                            cid_buf = Allocate(256)
                            cid_len = CC_ReadStdinLine(cid_buf, 256)
                            CC_WriteStdout("Please paste your Client Secret here: ")
                            csec_buf = Allocate(256)
                            csec_len = CC_ReadStdinLine(csec_buf, 256)
                            IfCondition GreaterThan(cid_len, 0) ThenBlock: {
                                ok = Auth.WriteGoogleOAuthConfig(cfg_path, cid_buf, csec_buf)
                            } ElseBlock: {
                                CC_WriteStdout("No Client ID provided. Using placeholder.\n")
                                ok = Auth.WriteGoogleOAuthConfig(cfg_path, "YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com", "YOUR_CLIENT_SECRET")
                            }
                            Deallocate(cid_buf, 256)
                            Deallocate(csec_buf, 256)
                        } ElseBlock: {
                            ok = Auth.WriteDefaultOAuthConfig(cfg_path)
                        }
                        IfCondition EqualTo(ok, 1) ThenBlock: {
                            CC_WriteStdout("[setup] wrote default config. Re-running OAuth flow...\n")
                            auth_result = Auth.RunOAuthFlow(cfg_path, tok_path)
                            status = JSON.GetString(auth_result, "status")
                        } ElseBlock: {
                            CC_WriteStdout("[setup] failed to write config\n")
                        }
                    }
                }
                Deallocate(ans, 16)
            }

            // Bootstrap on needs_client_id: ask for key directly
            IfCondition EqualTo(StringCompare(status, "needs_client_id"), 0) ThenBlock: {
                CC_WriteStdout("\n[setup] Your Google Client ID or Secret is missing or using the default placeholder.\n")
                CC_WriteStdout("        To use Google Gemini, you need a Google Cloud Desktop App Client ID.\n")
                CC_WriteStdout("        (e.g., 123456-abcdef.apps.googleusercontent.com)\n")
                CC_WriteStdout("Please paste your Client ID here: ")
                cid_buf = Allocate(256)
                cid_len = CC_ReadStdinLine(cid_buf, 256)
                CC_WriteStdout("Please paste your Client Secret here: ")
                csec_buf = Allocate(256)
                csec_len = CC_ReadStdinLine(csec_buf, 256)
                IfCondition GreaterThan(cid_len, 0) ThenBlock: {
                    ok = Auth.WriteGoogleOAuthConfig(cfg_path, cid_buf, csec_buf)
                    CC_WriteStdout("[setup] Saved new Client ID. Restarting flow...\n")
                } ElseBlock: {
                    CC_WriteStdout("No Client ID provided. Please try again.\n")
                }
                Deallocate(cid_buf, 256)
                Deallocate(csec_buf, 256)
                ContinueLoop
            }

            // Bootstrap on needs_setup_apikey: print walk-through and exit
            IfCondition EqualTo(StringCompare(status, "needs_setup_apikey"), 0) ThenBlock: {
                CC_WriteStdout("\nNo API key found for ")
                CC_WriteStdout(SelectedProvider.name)
                CC_WriteStdout(".\n\nPlease paste your API key here: ")
                key_buf = Allocate(2048)
                key_len = CC_ReadStdinLine(key_buf, 2048)
                IfCondition GreaterThan(key_len, 0) ThenBlock: {
                    kpath = CC_ExpandHome(StringConcat("~/.halcode/", StringConcat(prov_key_hint, "_key")))
                    kfd = SystemCall(CCSys.SYS_OPEN, kpath, 577, 384, 0, 0) // O_WRONLY|O_CREAT|O_TRUNC (577), 0600 (384)
                    IfCondition GreaterEqual(kfd, 0) ThenBlock: {
                        SystemCall(CCSys.SYS_WRITE, kfd, key_buf, key_len, 0, 0)
                        SystemCall(CCSys.SYS_CLOSE, kfd, 0, 0, 0, 0)
                        CC_WriteStdout("[setup] Saved API key. Restarting flow...\n")
                    }
                }
                Deallocate(key_buf, 2048)
                ContinueLoop
            }

            IfCondition NotEqual(StringCompare(status, "ok"), 0) ThenBlock: {
                msg = JSON.GetString(auth_result, "message")
                CC_WriteStdout("\nauth failed: ")
                IfCondition NotEqual(msg, 0) ThenBlock: { CC_WriteStdout(msg) }
                CC_WriteStdout("\n\nType 'r' to reset old configs, or press Enter to restart setup: ")
                ans = Allocate(16)
                n_ans = CC_ReadStdinLine(ans, 16)
                IfCondition GreaterThan(n_ans, 0) ThenBlock: {
                    first_ch = GetByte(ans, 0)
                    IfCondition Or(EqualTo(first_ch, 114), EqualTo(first_ch, 82)) ThenBlock: {
                        SystemCall(87, cfg_path, 0, 0, 0, 0)
                        SystemCall(87, client_path, 0, 0, 0, 0)
                        SystemCall(87, tok_path, 0, 0, 0, 0)
                        CC_WriteStdout("\n[setup] Cleared old configurations.\n")
                    }
                }
                Deallocate(ans, 16)
                ContinueLoop
            }
            auth_ok = 1
        }
        ReturnValue(auth_result)
    }
}

// Interactive waiting indicator for tool registration
Function.CC_RegisterOneTool {
    Input: name: Address
    Input: path: Address
    Body: {
        CC_WriteStdout("   [Wait] ") CC_WriteStdout(name) CC_WriteStdout("...")
        res = IPCDispatch.RegisterTool(name, path)
        // Carriage return + ANSI Erase Line
        buf = Allocate(16)
        SetByte(buf,0,13) SetByte(buf,1,27) SetByte(buf,2,91) SetByte(buf,3,50) SetByte(buf,4,75) SetByte(buf,5,0)
        CC_WriteStdout(buf)
        Deallocate(buf, 16)
        IfCondition EqualTo(res, 0) ThenBlock: {
            CC_WriteStdout("   [FAIL] ")
        } ElseBlock: {
            CC_WriteStdout("   [ OK ] ")
        }
        CC_WriteStdout(name)
        CC_WriteStdout("\n")
    }
}

// Reads cc_tools.json and launches / registers every tool listed in it.
// do_launch=1: fork+exec each binary (pass 1) then connect+register (pass 2).
// do_launch=0: connect+register only — used by agent workers where the daemons
//              are already running (launched by the parent process).
// buf is intentionally NOT freed — JSON stores raw string pointers into it.
Function.CC_LoadManifest {
    Input: path: Address
    Input: do_launch: Integer
    Output: Integer
    Body: {
        fd = SystemCall(CCSys.SYS_OPEN, path, 0, 0, 0, 0)
        IfCondition LessThan(fd, 0) ThenBlock: {
            CC_WriteStdout("[tools] WARN: cc_tools.json not found\n")
            ReturnValue(0)
        }
        buf = Allocate(32768)
        n = SystemCall(CCSys.SYS_READ, fd, buf, 32767, 0, 0)
        SystemCall(CCSys.SYS_CLOSE, fd, 0, 0, 0, 0)
        IfCondition LessEqual(n, 0) ThenBlock: {
            Deallocate(buf, 32768)
            ReturnValue(0)
        }
        SetByte(buf, n, 0)
        parsed = ParseJSON(buf)
        IfCondition EqualTo(parsed, 0) ThenBlock: {
            CC_WriteStdout("[tools] WARN: cc_tools.json parse failed\n")
            ReturnValue(0)
        }
        obj = JSON.AsObject(parsed)
        IfCondition EqualTo(obj, 0) ThenBlock: { ReturnValue(0) }
        tools_arr = JSON.GetArray(obj, "tools")
        IfCondition EqualTo(tools_arr, 0) ThenBlock: {
            CC_WriteStdout("[tools] WARN: no 'tools' array in cc_tools.json\n")
            ReturnValue(0)
        }
        count = JSON.ArrayLength(tools_arr)

        // Pass 1 (launch mode only): fork+exec all binaries so they bind in parallel.
        IfCondition EqualTo(do_launch, 1) ThenBlock: {
            j = 0
            WhileLoop LessThan(j, count) {
                et = JSON.ArrayGet(tools_arr, j)
                eo = JSON.AsObject(et)
                IfCondition NotEqual(eo, 0) ThenBlock: {
                    bin = JSON.GetString(eo, "binary")
                    IfCondition NotEqual(bin, 0) ThenBlock: {
                        CC_LaunchTool(bin)
                    }
                }
                j = Add(j, 1)
            }
        }

        // Pass 2: connect to each socket, fetch schema, register in dispatch table.
        i = 0
        WhileLoop LessThan(i, count) {
            et = JSON.ArrayGet(tools_arr, i)
            eo = JSON.AsObject(et)
            IfCondition NotEqual(eo, 0) ThenBlock: {
                tool_name   = JSON.GetString(eo, "name")
                tool_socket = JSON.GetString(eo, "socket")
                IfCondition And(NotEqual(tool_name, 0), NotEqual(tool_socket, 0)) ThenBlock: {
                    IfCondition EqualTo(do_launch, 1) ThenBlock: {
                        CC_RegisterOneTool(tool_name, tool_socket)
                    } ElseBlock: {
                        IPCDispatch.RegisterTool(tool_name, tool_socket)
                    }
                }
            }
            i = Add(i, 1)
        }
        ReturnValue(count)
    }
}

Function.CC_BootTools {
    Body: {
        CCRunState.child_pids = Allocate(Multiply(CCConst.MAX_CHILDREN, 8))
        CCRunState.child_count = 0

        CC_WriteStdout(" Loading tools from cc_tools.json...\n")
        CC_LoadManifest("./cc_tools.json", 1)

        CC_LoadQuotes("./intrusivethoughts.json")
    }
}

Function.CC_ChatLoop {
    Output: Integer
    Body: {
        paste_active = 0
        paste_buf = 0
        paste_used = 0

        WhileLoop EqualTo(CCRunState.running, 1) {
            CC_CheckAgentNotify()
            line = UI.ReadLine()
            n = StringLength(line)

            // Detect Bracketed Paste Start: \e[200~
            has_start = 0
            IfCondition GreaterEqual(n, 6) ThenBlock: {
                IfCondition And(EqualTo(GetByte(line,0),27), EqualTo(GetByte(line,1),91)) ThenBlock: {
                    IfCondition And(EqualTo(GetByte(line,2),50), EqualTo(GetByte(line,3),48)) ThenBlock: {
                        IfCondition And(EqualTo(GetByte(line,4),48), EqualTo(GetByte(line,5),126)) ThenBlock: {
                            has_start = 1
                        }
                    }
                }
            }

            // Detect Bracketed Paste End: \e[201~
            has_end = 0
            end_idx = 0
            i = 0
            WhileLoop LessEqual(i, Subtract(n, 6)) {
                IfCondition And(EqualTo(GetByte(line,i),27), EqualTo(GetByte(line,Add(i,1)),91)) ThenBlock: {
                    IfCondition And(EqualTo(GetByte(line,Add(i,2)),50), EqualTo(GetByte(line,Add(i,3)),48)) ThenBlock: {
                        IfCondition And(EqualTo(GetByte(line,Add(i,4)),49), EqualTo(GetByte(line,Add(i,5)),126)) ThenBlock: {
                            has_end = 1
                            end_idx = i
                            BreakLoop
                        }
                    }
                }
                i = Add(i, 1)
            }

            IfCondition EqualTo(has_start, 1) ThenBlock: {
                paste_active = 1
                IfCondition EqualTo(paste_buf, 0) ThenBlock: { paste_buf = Allocate(CCConst.INPUT_BUF_SZ) }
                paste_used = 0
                chunk_start = 6
                chunk_len = Subtract(n, 6)
                IfCondition EqualTo(has_end, 1) ThenBlock: { paste_active = 0  chunk_len = Subtract(end_idx, 6) }
                IfCondition GreaterThan(chunk_len, 0) ThenBlock: {
                    MemoryCopy(Add(paste_buf, paste_used), Add(line, chunk_start), chunk_len)
                    paste_used = Add(paste_used, chunk_len)
                }
                IfCondition EqualTo(paste_active, 1) ThenBlock: { SetByte(paste_buf, paste_used, 10) paste_used = Add(paste_used, 1) ContinueLoop }
            } ElseBlock: {
                IfCondition EqualTo(paste_active, 1) ThenBlock: {
                    chunk_start = 0
                    chunk_len = n
                    IfCondition EqualTo(has_end, 1) ThenBlock: { paste_active = 0  chunk_len = end_idx }
                    IfCondition And(GreaterThan(chunk_len, 0), LessThan(Add(paste_used, chunk_len), Subtract(CCConst.INPUT_BUF_SZ, 1))) ThenBlock: {
                        MemoryCopy(Add(paste_buf, paste_used), Add(line, chunk_start), chunk_len)
                        paste_used = Add(paste_used, chunk_len)
                    }
                    IfCondition EqualTo(paste_active, 1) ThenBlock: { SetByte(paste_buf, paste_used, 10) paste_used = Add(paste_used, 1) ContinueLoop }
                }
            }

            IfCondition And(EqualTo(paste_active, 0), GreaterThan(paste_used, 0)) ThenBlock: {
                SetByte(paste_buf, paste_used, 0)
                CC_SessionLogUser(paste_buf)
                History.AppendUser(paste_buf)
                paste_used = 0
                CC_RunTurn()
                ContinueLoop
            }

            IfCondition And(EqualTo(paste_active, 0), GreaterEqual(n, 0)) ThenBlock: {
                IfCondition EqualTo(StringCompare(line, "/quit"), 0) ThenBlock: {
                    CCRunState.running = 0
                }
                IfCondition EqualTo(StringCompare(line, "/home"), 0) ThenBlock: {
                    CCRunState.go_home = 1
                    CCRunState.running = 0
                }
                IfCondition EqualTo(StringCompare(line, "/help"), 0) ThenBlock: {
                    UI.PrintHelp()
                }
                IfCondition EqualTo(StringCompare(line, "/clear"), 0) ThenBlock: {
                    History.Init()
                    UI.Shutdown()
                    UI.Init()
                    UI.SessionHeader(0, 0, 0)
                }
                IfCondition EqualTo(StringCompare(line, "/logout"), 0) ThenBlock: {
                    c1 = CC_ExpandHome("~/.halcode/google_oauth_config.json")
                    c2 = CC_ExpandHome("~/.halcode/google_oauth_tokens.json")
                    c3 = CC_ExpandHome("~/.halcode/oauth_config.json")
                    c4 = CC_ExpandHome("~/.halcode/oauth_tokens.json")
                    SystemCall(87, c1, 0, 0, 0, 0) SystemCall(87, c2, 0, 0, 0, 0)
                    SystemCall(87, c3, 0, 0, 0, 0) SystemCall(87, c4, 0, 0, 0, 0)
                    UI.ChatPrintln("Logged out and configs cleared. Please restart HalCode9000.")
                    CCRunState.running = 0
                }
                // /auto — toggle autonomous mode (no 25-tool confirmation pause)
                IfCondition EqualTo(StringCompare(line, "/auto"), 0) ThenBlock: {
                    IfCondition EqualTo(CCRunState.auto_approve, 0) ThenBlock: {
                        CCRunState.auto_approve = 1
                        UI.ChatTag("✓", "Autonomous mode ON — tool chains run without pause.", 2)
                    } ElseBlock: {
                        CCRunState.auto_approve = 0
                        UI.ChatTag("✓", "Autonomous mode OFF — will pause after 25 tool calls.", 3)
                    }
                }
                // /project — show current project info
                IfCondition EqualTo(StringCompare(line, "/project"), 0) ThenBlock: {
                    CC_ProjectCommand()
                }
                // /sysprompt — show/set/clear/apply the per-project system prompt addon
                IfCondition EqualTo(StringCompare(line, "/sysprompt"), 0) ThenBlock: {
                    proj = CC_LoadProjectPrompt()
                    IfCondition EqualTo(proj, 0) ThenBlock: {
                        UI.ChatPrintln("No project prompt set.")
                    } ElseBlock: {
                        UI.ChatPrintln(StringConcat("Project prompt:\n", proj))
                    }
                    UI.ChatPrintln("  /sysprompt set <text>  — save and apply inline")
                    UI.ChatPrintln("  /sysprompt clear       — remove project prompt")
                    UI.ChatPrintln("  /sysprompt apply       — reload from pgmem (e.g. after external edit)")
                }
                IfCondition EqualTo(StringCompare(line, "/sysprompt clear"), 0) ThenBlock: {
                    clr_args = JSON.NewObject()
                    JSON.SetString(clr_args, "op", "park")
                    JSON.SetString(clr_args, "key", "__prompt__")
                    JSON.SetString(clr_args, "kind", "config")
                    JSON.SetString(clr_args, "content", "")
                    JSON.SetString(clr_args, "scope", "global")
                    clr_perr = Allocate(8)
                    StoreValue(clr_perr, 0, "dword")
                    IPCDispatch.Dispatch("Pgmem", clr_args, 0, clr_perr)
                    Deallocate(clr_perr, 8)
                    CCConst.PROJ_PROMPT = 0
                    CC_ApplyProjectPrompt()
                    UI.Shutdown()
                    UI.Init()
                    UI.SessionHeader(0, 0, 0)
                    UI.ChatTag("✓", "Project prompt cleared. History reset.", 2)
                }
                IfCondition EqualTo(StringCompare(line, "/sysprompt apply"), 0) ThenBlock: {
                    CCConst.PROJ_PROMPT = CC_LoadProjectPrompt()
                    CC_ApplyProjectPrompt()
                    UI.Shutdown()
                    UI.Init()
                    UI.SessionHeader(0, 0, 0)
                    IfCondition NotEqual(CCConst.PROJ_PROMPT, 0) ThenBlock: {
                        UI.ChatTag("✓", "Project prompt reloaded. History reset.", 2)
                    } ElseBlock: {
                        UI.ChatTag("✓", "No project prompt in pgmem. History reset.", 3)
                    }
                }
                IfCondition GreaterThan(StringLength(line), 15) ThenBlock: {
                    sp_pfx = Allocate(16)
                    sp_k = 0
                    WhileLoop LessThan(sp_k, 15) {
                        SetByte(sp_pfx, sp_k, GetByte(line, sp_k))
                        sp_k = Add(sp_k, 1)
                    }
                    SetByte(sp_pfx, 15, 0)
                    IfCondition EqualTo(StringCompare(sp_pfx, "/sysprompt set "), 0) ThenBlock: {
                        prompt_text = Add(line, 15)
                        sp_args = JSON.NewObject()
                        JSON.SetString(sp_args, "op", "park")
                        JSON.SetString(sp_args, "key", "__prompt__")
                        JSON.SetString(sp_args, "kind", "config")
                        JSON.SetString(sp_args, "content", prompt_text)
                        JSON.SetString(sp_args, "scope", "global")
                        sp_perr = Allocate(8)
                        StoreValue(sp_perr, 0, "dword")
                        IPCDispatch.Dispatch("Pgmem", sp_args, 0, sp_perr)
                        sp_err = Dereference(sp_perr, "dword")
                        Deallocate(sp_perr, 8)
                        IfCondition EqualTo(sp_err, 1) ThenBlock: {
                            UI.ChatTag("✗", "Failed to save — is pgmem running?", 1)
                        } ElseBlock: {
                            CCConst.PROJ_PROMPT = prompt_text
                            CC_ApplyProjectPrompt()
                            UI.Shutdown()
                            UI.Init()
                            UI.SessionHeader(0, 0, 0)
                            UI.ChatTag("✓", "Project prompt saved and applied. History reset.", 2)
                        }
                    }
                    Deallocate(sp_pfx, 16)
                }
                // /model [name] — show or switch model
                IfCondition EqualTo(StringCompare(line, "/model"), 0) ThenBlock: {
                    UI.ChatPrintln(StringConcat("Current model: ", SelectedProvider.default_model))
                    IfCondition EqualTo(SelectedProvider.kind, BackendKind.OPENAI) ThenBlock: {
                        IfCondition EqualTo(StringCompare(SelectedProvider.name, "OpenRouter"), 0) ThenBlock: {
                            UI.ChatPrintln("  anthropic/claude-sonnet-4    openai/gpt-4o")
                            UI.ChatPrintln("  google/gemini-2.5-flash-preview")
                            UI.ChatPrintln("  meta-llama/llama-3.3-70b-instruct:free")
                            UI.ChatPrintln("  deepseek/deepseek-chat-v3-0324:free")
                        } ElseBlock: {
                            UI.ChatPrintln("  deepseek-v4-pro   deepseek-v4-flash")
                            UI.ChatPrintln("  gpt-4o   gpt-4o-mini")
                        }
                        UI.ChatPrintln("Use: /model <name>")
                    }
                }
                IfCondition GreaterThan(StringLength(line), 7) ThenBlock: {
                    pfx7 = Allocate(8)
                    k7 = 0
                    WhileLoop LessThan(k7, 7) {
                        SetByte(pfx7, k7, GetByte(line, k7))
                        k7 = Add(k7, 1)
                    }
                    SetByte(pfx7, 7, 0)
                    IfCondition EqualTo(StringCompare(pfx7, "/model "), 0) ThenBlock: {
                        new_model = Add(line, 7)
                        SelectedProvider.default_model = new_model
                        OpenAI.SetModel(new_model)
                        UI.ChatPrintln(StringConcat("Model set to: ", new_model))
                    }
                    Deallocate(pfx7, 8)
                }
                // /reasoning [off|min|medium|max]
                IfCondition EqualTo(StringCompare(line, "/reasoning"), 0) ThenBlock: {
                    re = SelectedProvider.reasoning_effort
                    IfCondition EqualTo(re, 0) ThenBlock: {
                        UI.ChatPrintln("Reasoning: off")
                    } ElseBlock: {
                        UI.ChatPrintln(StringConcat("Reasoning: ", re))
                    }
                }
                IfCondition GreaterThan(StringLength(line), 11) ThenBlock: {
                    pfx11 = Allocate(12)
                    k11 = 0
                    WhileLoop LessThan(k11, 11) {
                        SetByte(pfx11, k11, GetByte(line, k11))
                        k11 = Add(k11, 1)
                    }
                    SetByte(pfx11, 11, 0)
                    IfCondition EqualTo(StringCompare(pfx11, "/reasoning "), 0) ThenBlock: {
                        re_val = Add(line, 11)
                        IfCondition EqualTo(StringCompare(re_val, "off"), 0) ThenBlock: {
                            SelectedProvider.reasoning_effort = 0
                            OAICfg.reasoning_effort = 0
                            UI.ChatPrintln("Reasoning disabled")
                        } ElseBlock: {
                            IfCondition NotEqual(SelectedProvider.kind, BackendKind.OPENAI) ThenBlock: {
                                UI.ChatPrintln("Reasoning effort only applies to DeepSeek V4 Pro")
                            } ElseBlock: {
                                SelectedProvider.reasoning_effort = re_val
                                OpenAI.SetReasoningEffort(re_val)
                                UI.ChatPrintln(StringConcat("Reasoning set to: ", re_val))
                            }
                        }
                    }
                    Deallocate(pfx11, 12)
                }
                // Treat anything else as a chat turn
                IfCondition GreaterThan(n, 0) ThenBlock: {
                    first = GetByte(line, 0)
                    IfCondition NotEqual(first, 47) ThenBlock: {   // not '/'
                        CC_SessionLogUser(line)
                        History.AppendUser(line)
                        CC_RunTurn()
                    }
                }
            }
        }
        ReturnValue(CCRunState.go_home)
    }
}

// =============================================================================
// HEADLESS AGENT MODE — ./HalCode9000.x --agent <provider>[:<model>]
// Reads prompt from stdin, runs one CC_RunTurn, writes response to stdout.
// =============================================================================

// Parse /proc/self/cmdline for flag (e.g. "--agent").
// Returns a heap-allocated copy of the next argument after flag, or 0.
Function.CC_ReadArgValue {
    Input: flag: Address
    Output: Address
    Body: {
        fd = SystemCall(CCSys.SYS_OPEN, "/proc/self/cmdline", 0, 0, 0, 0)
        IfCondition LessThan(fd, 0) ThenBlock: { ReturnValue(0) }
        buf = Allocate(16384)
        n = SystemCall(CCSys.SYS_READ, fd, buf, 16383, 0, 0)
        SystemCall(CCSys.SYS_CLOSE, fd, 0, 0, 0, 0)
        IfCondition LessEqual(n, 0) ThenBlock: {
            Deallocate(buf, 16384)
            ReturnValue(0)
        }
        SetByte(buf, n, 0)
        flag_len = StringLength(flag)
        i = 0
        WhileLoop LessThan(i, n) {
            match = 1
            j = 0
            WhileLoop LessThan(j, flag_len) {
                IfCondition NotEqual(GetByte(buf, Add(i, j)), GetByte(flag, j)) ThenBlock: {
                    match = 0
                    BreakLoop
                }
                j = Add(j, 1)
            }
            IfCondition And(EqualTo(match, 1), EqualTo(GetByte(buf, Add(i, flag_len)), 0)) ThenBlock: {
                val_start = Add(i, Add(flag_len, 1))
                IfCondition GreaterEqual(val_start, n) ThenBlock: {
                    Deallocate(buf, 16384)
                    ReturnValue(0)
                }
                val_end = val_start
                WhileLoop LessThan(val_end, n) {
                    IfCondition EqualTo(GetByte(buf, val_end), 0) ThenBlock: { BreakLoop }
                    val_end = Add(val_end, 1)
                }
                val_len = Subtract(val_end, val_start)
                out = Allocate(Add(val_len, 1))
                k = 0
                WhileLoop LessThan(k, val_len) {
                    SetByte(out, k, GetByte(buf, Add(val_start, k)))
                    k = Add(k, 1)
                }
                SetByte(out, val_len, 0)
                Deallocate(buf, 16384)
                ReturnValue(out)
            }
            WhileLoop LessThan(i, n) {
                IfCondition EqualTo(GetByte(buf, i), 0) ThenBlock: { BreakLoop }
                i = Add(i, 1)
            }
            i = Add(i, 1)
        }
        Deallocate(buf, 16384)
        ReturnValue(0)
    }
}

// chdir to the directory containing the running binary (/proc/self/exe).
// Required in --mcp mode so ./cc_*_ipc.x relative paths resolve correctly.
Function.CC_ChdirToBinDir {
    Body: {
        buf = Allocate(4096)
        n = SystemCall(CCSys.SYS_READLINK, "/proc/self/exe", buf, 4095, 0, 0)
        IfCondition LessEqual(n, 0) ThenBlock: {
            Deallocate(buf, 4096)
            ReturnValue(0)
        }
        SetByte(buf, n, 0)
        last_slash = -1
        k = 0
        WhileLoop LessThan(k, n) {
            IfCondition EqualTo(GetByte(buf, k), 47) ThenBlock: { last_slash = k }
            k = Add(k, 1)
        }
        IfCondition GreaterEqual(last_slash, 0) ThenBlock: {
            SetByte(buf, last_slash, 0)
            SystemCall(CCSys.SYS_CHDIR, buf, 0, 0, 0, 0)
        }
        Deallocate(buf, 4096)
    }
}

// Returns 1 if flag is present as its own NUL-terminated token in cmdline, 0 otherwise.
// Use this for bare flags like --mcp that have no following value.
Function.CC_HasArg {
    Input: flag: Address
    Output: Integer
    Body: {
        fd = SystemCall(CCSys.SYS_OPEN, "/proc/self/cmdline", 0, 0, 0, 0)
        IfCondition LessThan(fd, 0) ThenBlock: { ReturnValue(0) }
        buf = Allocate(16384)
        n = SystemCall(CCSys.SYS_READ, fd, buf, 16383, 0, 0)
        SystemCall(CCSys.SYS_CLOSE, fd, 0, 0, 0, 0)
        IfCondition LessEqual(n, 0) ThenBlock: {
            Deallocate(buf, 16384)
            ReturnValue(0)
        }
        SetByte(buf, n, 0)
        flag_len = StringLength(flag)
        i = 0
        WhileLoop LessThan(i, n) {
            match = 1
            j = 0
            WhileLoop LessThan(j, flag_len) {
                IfCondition NotEqual(GetByte(buf, Add(i, j)), GetByte(flag, j)) ThenBlock: {
                    match = 0
                    BreakLoop
                }
                j = Add(j, 1)
            }
            IfCondition And(EqualTo(match, 1), EqualTo(GetByte(buf, Add(i, flag_len)), 0)) ThenBlock: {
                Deallocate(buf, 16384)
                ReturnValue(1)
            }
            WhileLoop LessThan(i, n) {
                IfCondition EqualTo(GetByte(buf, i), 0) ThenBlock: { BreakLoop }
                i = Add(i, 1)
            }
            i = Add(i, 1)
        }
        Deallocate(buf, 16384)
        ReturnValue(0)
    }
}

// Read all of stdin until EOF. Returns bytes read (buf is NUL-terminated).
Function.CC_ReadStdinAll {
    Input: buf: Address
    Input: maxlen: Integer
    Output: Integer
    Body: {
        total = 0
        WhileLoop LessThan(total, Subtract(maxlen, 1)) {
            n = SystemCall(CCSys.SYS_READ, 0, Add(buf, total), Subtract(Subtract(maxlen, 1), total), 0, 0)
            IfCondition LessEqual(n, 0) ThenBlock: { BreakLoop }
            total = Add(total, n)
        }
        SetByte(buf, total, 0)
        ReturnValue(total)
    }
}

// Parse "provider[:model]" spec, call CC_MakeProvider, look up the API key.
// Returns the credential string (heap copy from env, or "" for local).
Function.CC_SetupAgentProvider {
    Input: spec: Address
    Output: Address
    Body: {
        prov_name = spec
        model_override = 0

        // Find ':' separator
        colon_pos = -1
        ci = 0
        WhileLoop NotEqual(GetByte(spec, ci), 0) {
            IfCondition EqualTo(GetByte(spec, ci), 58) ThenBlock: {
                colon_pos = ci
                BreakLoop
            }
            ci = Add(ci, 1)
        }
        IfCondition GreaterEqual(colon_pos, 0) ThenBlock: {
            model_override = Add(spec, Add(colon_pos, 1))
            prov_buf = Allocate(64)
            pk = 0
            WhileLoop LessThan(pk, colon_pos) {
                SetByte(prov_buf, pk, GetByte(spec, pk))
                pk = Add(pk, 1)
            }
            SetByte(prov_buf, colon_pos, 0)
            prov_name = prov_buf
        }

        cred = 0
        matched = 0

        IfCondition EqualTo(StringCompare(prov_name, "anthropic"), 0) ThenBlock: {
            CC_MakeProvider("Anthropic", "anthropic", "https://api.anthropic.com",
                            "/v1/messages", "claude-sonnet-4-6", "anthropic")
            cred = CC_GetEnv("ANTHROPIC_API_KEY")
            matched = 1
        }
        IfCondition And(EqualTo(matched, 0), EqualTo(StringCompare(prov_name, "deepseek"), 0)) ThenBlock: {
            CC_MakeProvider("DeepSeek", "openai", "https://api.deepseek.com",
                            "/v1/chat/completions", "deepseek-v4-flash", "deepseek")
            cred = CC_GetEnv("DEEPSEEK_API_KEY")
            matched = 1
        }
        IfCondition And(EqualTo(matched, 0), EqualTo(StringCompare(prov_name, "openai"), 0)) ThenBlock: {
            CC_MakeProvider("OpenAI", "openai", "https://api.openai.com",
                            "/v1/chat/completions", "gpt-4o", "openai")
            cred = CC_GetEnv("OPENAI_API_KEY")
            matched = 1
        }
        IfCondition And(EqualTo(matched, 0), EqualTo(StringCompare(prov_name, "grok"), 0)) ThenBlock: {
            CC_MakeProvider("Grok", "openai", "https://api.x.ai",
                            "/v1/chat/completions", "grok-3", "xai")
            cred = CC_GetEnv("XAI_API_KEY")
            matched = 1
        }
        IfCondition And(EqualTo(matched, 0), EqualTo(StringCompare(prov_name, "gemini"), 0)) ThenBlock: {
            CC_MakeProvider("Google", "gemini", "https://generativelanguage.googleapis.com",
                            "/v1beta/openai/chat/completions", "gemini-2.5-flash", "google")
            cred = CC_GetEnv("GEMINI_API_KEY")
            matched = 1
        }
        IfCondition And(EqualTo(matched, 0), EqualTo(StringCompare(prov_name, "local"), 0)) ThenBlock: {
            CC_MakeProvider("Local", "openai", "http://localhost:11434",
                            "/v1/chat/completions", "llama3", "local")
            cred = ""
            matched = 1
        }
        IfCondition EqualTo(matched, 0) ThenBlock: {
            CC_MakeProvider("Anthropic", "anthropic", "https://api.anthropic.com",
                            "/v1/messages", "claude-sonnet-4-6", "anthropic")
            cred = CC_GetEnv("ANTHROPIC_API_KEY")
        }

        IfCondition NotEqual(model_override, 0) ThenBlock: {
            IfCondition GreaterThan(StringLength(model_override), 0) ThenBlock: {
                SelectedProvider.default_model = model_override
            }
        }
        // Fall back to key file if env var not set
        IfCondition EqualTo(cred, 0) ThenBlock: {
            auth_res = Auth.RunAPIKeyFlow(0, SelectedProvider.key_hint)
            auth_status = JSON.GetString(auth_res, "status")
            IfCondition EqualTo(StringCompare(auth_status, "ok"), 0) ThenBlock: {
                cred = JSON.GetString(auth_res, "credential")
            }
        }
        IfCondition EqualTo(cred, 0) ThenBlock: { cred = "" }
        ReturnValue(cred)
    }
}

// Connect to already-running tool sockets without launching new processes.
// Used in headless mode where the parent HalCode9000.x already launched tools.
Function.CC_RegisterToolsOnly {
    Body: {
        CCRunState.child_pids = Allocate(Multiply(CCConst.MAX_CHILDREN, 8))
        CCRunState.child_count = 0
        CC_LoadManifest("./cc_tools.json", 0)
    }
}

// Write a debug line to stderr (fd 2). In agent mode stderr → log file via 2>>.
Function.CC_AgentLog {
    Input: msg: Address
    Body: {
        IfCondition EqualTo(msg, 0) ThenBlock: { ReturnValue(0) }
        alen = StringLength(msg)
        SystemCall(CCSys.SYS_WRITE, 2, msg, alen, 0, 0)
        anl = Allocate(4)
        SetByte(anl, 0, 10) SetByte(anl, 1, 0)
        SystemCall(CCSys.SYS_WRITE, 2, anl, 1, 0, 0)
        Deallocate(anl, 4)
    }
}

// Headless turn: redirect fd 1 to /dev/null, init TUI (escape seqs discarded,
// raw-mode ioctl fails silently on pipe), run CC_RunTurn once, restore fd 1,
// then write the final assistant response to stdout.
Function.CC_RunAgentMode {
    Input: prompt: Address
    Body: {
        CC_AgentLog("[worker] CC_RunAgentMode starting")
        CCRunState.auto_approve = 1

        // Redirect stdout → /dev/null so all TUI/ANSI output is discarded
        devnull = SystemCall(CCSys.SYS_OPEN, "/dev/null", 2, 0, 0, 0)
        saved_stdout = SystemCall(CCSys.SYS_DUP, 1, 0, 0, 0, 0)
        IfCondition GreaterEqual(devnull, 0) ThenBlock: {
            SystemCall(CCSys.SYS_DUP2, devnull, 1, 0, 0, 0)
            SystemCall(CCSys.SYS_CLOSE, devnull, 0, 0, 0, 0)
        }

        CC_AgentLog("[worker] UI.Init")
        UI.Init()
        CC_AgentLog("[worker] appending prompt to history")
        History.AppendUser(prompt)
        CC_AgentLog("[worker] CC_RunTurn starting")
        CC_RunTurn()
        CC_AgentLog("[worker] CC_RunTurn complete")
        UI.Shutdown()

        // Restore stdout before writing result
        IfCondition GreaterEqual(saved_stdout, 0) ThenBlock: {
            SystemCall(CCSys.SYS_DUP2, saved_stdout, 1, 0, 0, 0)
            SystemCall(CCSys.SYS_CLOSE, saved_stdout, 0, 0, 0, 0)
        }

        // Walk history backward to find the last assistant message
        msgs = History.GetMessagesArray()
        cnt = History.Count()
        i = Subtract(cnt, 1)
        found = 0
        result = ""
        WhileLoop And(GreaterEqual(i, 0), EqualTo(found, 0)) {
            tag = JSON.ArrayGet(msgs, i)
            msg = JSON.AsObject(tag)
            IfCondition NotEqual(msg, 0) ThenBlock: {
                role = JSON.GetString(msg, "role")
                IfCondition NotEqual(role, 0) ThenBlock: {
                    IfCondition EqualTo(StringCompare(role, "assistant"), 0) ThenBlock: {
                        c = JSON.GetString(msg, "content")
                        IfCondition NotEqual(c, 0) ThenBlock: { result = c }
                        found = 1
                    }
                }
            }
            i = Subtract(i, 1)
        }

        CC_AgentLog(StringConcat("[worker] result chars=", NumberToString(StringLength(result))))
        CC_WriteStdout(result)
        CC_WriteStdout("\n")
        CC_AgentLog("[worker] done")
    }
}

// =============================================================================
// MCP SERVER MODE — ./HalCode9000.x --mcp
// Boots all cc_tools, then speaks MCP JSON-RPC 2.0 over stdio.
// Claude Code (or any MCP client) registers this as an MCP server.
// All tool calls route through the running @halcode/* sockets.
// =============================================================================

// Write one JSONL MCP message: JSON string + newline.
// Claude Code MCP transport uses newline-delimited JSON (JSONL), not Content-Length framing.
Function.CC_MCP_WriteFrame {
    Input: str: Address
    Body: {
        slen = StringLength(str)
        SystemCall(CCSys.SYS_WRITE, 1, str, slen, 0, 0)
        nl = Allocate(4)
        SetByte(nl, 0, 10) SetByte(nl, 1, 0)
        SystemCall(CCSys.SYS_WRITE, 1, nl, 1, 0, 0)
        Deallocate(nl, 4)
    }
}

// Reads one JSONL MCP message from stdin (reads until '\n').
// Returns bytes in buf (excluding the newline), or -1 on EOF/error.
Function.CC_MCP_ReadFrame {
    Input: buf: Address
    Input: maxlen: Integer
    Output: Integer
    Body: {
        total = 0
        lim = Subtract(maxlen, 1)
        WhileLoop LessThan(total, lim) {
            n = SystemCall(CCSys.SYS_READ, 0, Add(buf, total), 1, 0, 0)
            IfCondition LessEqual(n, 0) ThenBlock: {
                IfCondition EqualTo(total, 0) ThenBlock: { ReturnValue(-1) }
                BreakLoop
            }
            ch = GetByte(buf, total)
            IfCondition EqualTo(ch, 10) ThenBlock: { BreakLoop }
            total = Add(total, 1)
        }
        // Strip trailing \r if present
        IfCondition And(GreaterThan(total, 0), EqualTo(GetByte(buf, Subtract(total, 1)), 13)) ThenBlock: {
            total = Subtract(total, 1)
        }
        SetByte(buf, total, 0)
        ReturnValue(total)
    }
}

// Extract raw JSON id value (e.g. 1 or "abc") from a JSON-RPC string.
// Returns heap copy of the raw fragment, or 0 if not found.
Function.CC_MCP_ExtractID {
    Input: json_str: Address
    Output: Address
    Body: {
        key = "\"id\":"
        klen = 5
        jlen = StringLength(json_str)
        i = 0
        WhileLoop LessThan(i, Subtract(jlen, klen)) {
            IfCondition EqualTo(MemCompare(Add(json_str, i), key, klen), 0) ThenBlock: {
                j = Add(i, klen)
                WhileLoop LessThan(j, jlen) {
                    c = GetByte(json_str, j)
                    IfCondition Or(EqualTo(c, 32), EqualTo(c, 9)) ThenBlock: {
                        j = Add(j, 1)
                    } ElseBlock: { BreakLoop }
                }
                start = j
                WhileLoop LessThan(j, jlen) {
                    c = GetByte(json_str, j)
                    IfCondition Or(EqualTo(c, 44), EqualTo(c, 125)) ThenBlock: { BreakLoop }
                    j = Add(j, 1)
                }
                id_len = Subtract(j, start)
                IfCondition LessEqual(id_len, 0) ThenBlock: { ReturnValue(0) }
                id_buf = Allocate(Add(id_len, 1))
                MemoryCopy(id_buf, Add(json_str, start), id_len)
                SetByte(id_buf, id_len, 0)
                ReturnValue(id_buf)
            }
            i = Add(i, 1)
        }
        ReturnValue(0)
    }
}

Function.CC_MCP_SendResult {
    Input: id_raw: Address
    Input: result_json: Address
    Body: {
        id_part = id_raw
        IfCondition EqualTo(id_raw, 0) ThenBlock: { id_part = "null" }
        msg = StringConcat("{\"jsonrpc\":\"2.0\",\"id\":", id_part)
        msg = StringConcat(msg, ",\"result\":")
        msg = StringConcat(msg, result_json)
        msg = StringConcat(msg, "}")
        CC_MCP_WriteFrame(msg)
    }
}

Function.CC_MCP_SendError {
    Input: id_raw: Address
    Input: code: Address
    Input: msg_str: Address
    Body: {
        id_part = id_raw
        IfCondition EqualTo(id_raw, 0) ThenBlock: { id_part = "null" }
        escaped = JSON.EscapeString(msg_str)
        frame = StringConcat("{\"jsonrpc\":\"2.0\",\"id\":", id_part)
        frame = StringConcat(frame, ",\"error\":{\"code\":")
        frame = StringConcat(frame, code)
        frame = StringConcat(frame, ",\"message\":\"")
        frame = StringConcat(frame, escaped)
        frame = StringConcat(frame, "\"}}")
        CC_MCP_WriteFrame(frame)
    }
}

Function.CC_MCP_HandleInitialize {
    Input: id_raw: Address
    Body: {
        result = "{\"protocolVersion\":\"2025-11-25\",\"capabilities\":{\"tools\":{\"listChanged\":false}},\"serverInfo\":{\"name\":\"HalCode9000\",\"version\":\"1.0\"}}"
        CC_MCP_SendResult(id_raw, result)
    }
}

Function.CC_MCP_HandleToolsList {
    Input: id_raw: Address
    Body: {
        tools_arr = JSON.NewArray()
        i = 0
        WhileLoop LessThan(i, IPCDState.count) {
            base = Add(IPCDState.table, Multiply(i, IPCDConst.ENTRY_SIZE))
            fd_val = Dereference(Add(base, IPCDOff.FD))
            sch   = Dereference(Add(base, IPCDOff.SCHEMA))
            IfCondition And(GreaterEqual(fd_val, 0), NotEqual(sch, 0)) ThenBlock: {
                tname = JSON.GetString(sch, "name")
                tdesc = JSON.GetString(sch, "description")
                tin   = JSON.GetObject(sch, "input_schema")
                tool  = JSON.NewObject()
                IfCondition NotEqual(tname, 0) ThenBlock: { JSON.SetString(tool, "name", tname) }
                IfCondition NotEqual(tdesc, 0) ThenBlock: { JSON.SetString(tool, "description", tdesc) }
                IfCondition NotEqual(tin, 0)   ThenBlock: { JSON.SetObject(tool, "inputSchema", tin) }
                JSON.PushObject(tools_arr, tool)
            }
            i = Add(i, 1)
        }
        res_obj = JSON.NewObject()
        JSON.SetArray(res_obj, "tools", tools_arr)
        CC_MCP_SendResult(id_raw, JSON.SerializeObject(res_obj))
    }
}

Function.CC_MCP_HandleToolsCall {
    Input: id_raw: Address
    Input: params_obj: Address
    Body: {
        IfCondition EqualTo(params_obj, 0) ThenBlock: {
            CC_MCP_SendError(id_raw, "-32602", "missing params")
            ReturnValue(0)
        }
        tname = JSON.GetString(params_obj, "name")
        targs = JSON.GetObject(params_obj, "arguments")
        IfCondition EqualTo(tname, 0) ThenBlock: {
            CC_MCP_SendError(id_raw, "-32602", "missing tool name")
            ReturnValue(0)
        }
        is_err_buf = Allocate(8)
        StoreValue(is_err_buf, 0, "dword")
        content = IPCDispatch.Dispatch(tname, targs, id_raw, is_err_buf)
        is_err = Dereference(is_err_buf)
        Deallocate(is_err_buf, 8)
        IfCondition EqualTo(content, 0) ThenBlock: { content = "" }
        item = JSON.NewObject()
        JSON.SetString(item, "type", "text")
        JSON.SetString(item, "text", content)
        arr = JSON.NewArray()
        JSON.PushObject(arr, item)
        res = JSON.NewObject()
        JSON.SetArray(res, "content", arr)
        IfCondition EqualTo(is_err, 1) ThenBlock: { JSON.SetBool(res, "isError", 1) }
        CC_MCP_SendResult(id_raw, JSON.SerializeObject(res))
    }
}

Function.CC_RunMCPMode {
    Body: {
        buf = Allocate(131072)
        done = 0
        WhileLoop EqualTo(done, 0) {
            n = CC_MCP_ReadFrame(buf, 131072)
            IfCondition LessThan(n, 0) ThenBlock: { done = 1 }
            IfCondition And(EqualTo(done, 0), GreaterThan(n, 0)) ThenBlock: {
                id_raw = CC_MCP_ExtractID(buf)
                parsed = ParseJSON(buf)
                IfCondition EqualTo(parsed, 0) ThenBlock: {
                    CC_MCP_SendError(id_raw, "-32700", "Parse error")
                } ElseBlock: {
                    obj = JSON.AsObject(parsed)
                    IfCondition EqualTo(obj, 0) ThenBlock: {
                        CC_MCP_SendError(id_raw, "-32600", "Invalid Request")
                    } ElseBlock: {
                        method = JSON.GetString(obj, "method")
                        IfCondition EqualTo(method, 0) ThenBlock: {
                            IfCondition NotEqual(id_raw, 0) ThenBlock: {
                                CC_MCP_SendError(id_raw, "-32600", "missing method")
                            }
                        } ElseBlock: {
                            handled = 0
                            IfCondition EqualTo(StringCompare(method, "initialize"), 0) ThenBlock: {
                                CC_MCP_HandleInitialize(id_raw)
                                handled = 1
                            }
                            IfCondition And(EqualTo(handled,0), EqualTo(StringCompare(method,"notifications/initialized"),0)) ThenBlock: {
                                handled = 1
                            }
                            IfCondition And(EqualTo(handled,0), EqualTo(StringCompare(method,"ping"),0)) ThenBlock: {
                                CC_MCP_SendResult(id_raw, "{}")
                                handled = 1
                            }
                            IfCondition And(EqualTo(handled,0), EqualTo(StringCompare(method,"tools/list"),0)) ThenBlock: {
                                CC_MCP_HandleToolsList(id_raw)
                                handled = 1
                            }
                            IfCondition And(EqualTo(handled,0), EqualTo(StringCompare(method,"tools/call"),0)) ThenBlock: {
                                params = JSON.GetObject(obj, "params")
                                CC_MCP_HandleToolsCall(id_raw, params)
                                handled = 1
                            }
                            IfCondition And(EqualTo(handled,0), NotEqual(id_raw,0)) ThenBlock: {
                                CC_MCP_SendError(id_raw, "-32601", "Method not found")
                            }
                        }
                    }
                    JSON.Free(parsed)
                }
            }
        }
        Deallocate(buf, 131072)
    }
}

// =============================================================================
// MAIN
// =============================================================================
SubRoutine.Main {

    // MCP server mode: ./HalCode9000.x --mcp
    // Boots tools, then speaks JSON-RPC 2.0 over stdio.
    // Stdout is redirected to stderr during boot to keep the MCP stream clean.
    mcp_flag = CC_HasArg("--mcp")
    IfCondition EqualTo(mcp_flag, 1) ThenBlock: {
        CC_ChdirToBinDir()
        History.Init()
        IPCDispatch.Init()
        cred = CC_SetupAgentProvider("deepseek")
        CCConst.SYSTEM_PROMPT = "You are HAL Code 9000. Be concise."
        Backend.Init("apikey", cred, CCConst.SYSTEM_PROMPT)
        // Respond to initialize immediately so health checks pass before the ~12s tool boot.
        mcp_init_buf = Allocate(16384)
        mcp_init_n = CC_MCP_ReadFrame(mcp_init_buf, 16384)
        IfCondition LessThan(mcp_init_n, 0) ThenBlock: {
            SystemCall(CCSys.SYS_EXIT, 0, 0, 0, 0, 0)
        }
        IfCondition GreaterThan(mcp_init_n, 0) ThenBlock: {
            mcp_init_id = CC_MCP_ExtractID(mcp_init_buf)
            CC_MCP_HandleInitialize(mcp_init_id)
        }
        // Boot tools while redirecting boot messages to stderr.
        saved_out = SystemCall(CCSys.SYS_DUP, 1, 0, 0, 0, 0)
        SystemCall(CCSys.SYS_DUP2, 2, 1, 0, 0, 0)
        CC_BootTools()
        IfCondition GreaterEqual(saved_out, 0) ThenBlock: {
            SystemCall(CCSys.SYS_DUP2, saved_out, 1, 0, 0, 0)
            SystemCall(CCSys.SYS_CLOSE, saved_out, 0, 0, 0, 0)
        }
        CC_RunMCPMode()
        SystemCall(CCSys.SYS_EXIT, 0, 0, 0, 0, 0)
    }

    // Headless agent mode: ./HalCode9000.x --agent <provider>[:<model>]
    // Must be detected before the splash so nothing writes to stdout.
    agent_spec = CC_ReadArgValue("--agent")
    IfCondition NotEqual(agent_spec, 0) ThenBlock: {
        CC_AgentLog("[init] agent mode detected")
        prompt_buf = Allocate(CCConst.INPUT_BUF_SZ)
        CC_AgentLog("[init] reading stdin")
        n_read = CC_ReadStdinAll(prompt_buf, CCConst.INPUT_BUF_SZ)
        CC_AgentLog(StringConcat("[init] stdin bytes=", NumberToString(n_read)))
        IfCondition LessEqual(n_read, 0) ThenBlock: {
            CC_AgentLog("[init] empty stdin — exiting")
            SystemCall(CCSys.SYS_EXIT, 1, 0, 0, 0, 0)
        }
        CC_AgentLog("[init] CC_SetupAgentProvider")
        cred = CC_SetupAgentProvider(agent_spec)
        CC_AgentLog("[init] SYSTEM_PROMPT assign")
        CCConst.SYSTEM_PROMPT = "You are HAL Code 9000. Be concise. WSL2 RULES: (1) NEVER use find with / or /mnt or Windows paths. (2) Use Relmem op=symbols to locate files. (3) Scope find to specific subdirectories. (4) Pipe unbounded output through head/grep/tail. (5) NEVER call Relmem op=index on broad paths. (6) Use Pgmem op=\"search\" to extract parked data, DO NOT use op=\"pickup\". (7) Max 25 tool chains in a row, then ask user. (8) BLOCKED COMMANDS: sudo, rm, mv, dd, kill, killall, pkill, crontab, and piping to sh/bash are all forbidden. (9) AILang: run `./ailang.x src.ailang dest.x` and `./analyzer.x src.ailang` via Bash to check syntax. (10) VCS: use Olympus tool (snapshot, review, log, info, init) for compound workflows; use Git tool for raw git subcommands. (11) Write tool: use absolute paths. If grandparent missing, use Bash mkdir -p. For files >200 lines, use Bash `cat << 'EOF' > file`. (12) Write tool blocks /etc, /proc, /sys, /dev, /bin, /usr. (13) NO UNSOLICITED EDITS: never modify files unless explicitly asked — read-only exploration (Read, Head, Grep, Find, Stat, Wc, Du, Diff, LS, Git) is always OK without asking. (14) TOOL ERRORS: recheck your own parameters first — most errors are bad inputs not broken tools; retry with corrected params before reporting the tool as broken. (15) GREP: when path is a directory you MUST pass recursive=1; the include glob (e.g. *.ailang) only applies in recursive mode. (16) AGENT: always pass task_id (use the pgmem task ID from op=task_create) so the daemon can call task_end and mark the task complete; omitting task_id leaves the task stuck in pending forever. (17) AGENT WAITING: after spawning agents call `Sleep seconds=90` (the Sleep tool) then check Pgmem ONCE per wait cycle — NEVER use Bash sleep or poll Pgmem in a loop; the Sleep tool is the ONLY safe wait mechanism because it does not touch Pgmem; Pgmem is single-threaded and each pickup call holds the socket, blocking the agent daemon from parking its result and calling task_end, which causes a deadlock that kills the agent with a timeout."
        CC_AgentLog("[init] History.Init")
        History.Init()
        CC_AgentLog("[init] IPCDispatch.Init")
        IPCDispatch.Init()
        CC_AgentLog("[init] Backend.Init")
        Backend.Init("apikey", cred, CCConst.SYSTEM_PROMPT)
        CC_AgentLog("[init] CC_RegisterToolsOnly")
        CC_RegisterToolsOnly()
        CC_AgentLog("[init] CC_RunAgentMode")
        CC_RunAgentMode(prompt_buf)
        SystemCall(CCSys.SYS_EXIT, 0, 0, 0, 0, 0)
    }

    // Startup animation — HALCODE assembles from both sides, eye orbits O.
    UI.StartupAnimation()

    // Demo mode: skip auth + tool launches + real API; just render the UI
    // primitives so the operator can eyeball the look. Demo handles its own UI.Init.
    demo_active = 0
    demo_env = CC_GetEnv("CC_DEMO")
    IfCondition NotEqual(demo_env, 0) ThenBlock: {
        IfCondition GreaterThan(StringLength(demo_env), 0) ThenBlock: {
            demo_active = 1
        }
    }
    IfCondition EqualTo(demo_active, 1) ThenBlock: {
        CC_RunDemo()
        SystemCall(CCSys.SYS_EXIT, 0, 0, 0, 0, 0)
    }

    // Auth runs in COOKED mode (line input from kernel, no raw-mode TUI).
    // Tool registration logs print via PrintMessage; both happen before
    // we grab the screen.

    CCConst.SYSTEM_PROMPT = "You are HAL Code 9000. Be concise. WSL2 RULES: (1) NEVER use find with / or /mnt or Windows paths. (2) Use Relmem op=symbols to locate files. (3) Scope find to specific subdirectories. (4) Pipe unbounded output through head/grep/tail. (5) NEVER call Relmem op=index on broad paths. (6) Use Pgmem op=\"search\" to extract parked data, DO NOT use op=\"pickup\". (7) Max 25 tool chains in a row, then ask user. (8) BLOCKED COMMANDS: sudo, rm, mv, dd, kill, killall, pkill, crontab, and piping to sh/bash are all forbidden. (9) AILang: run `./ailang.x src.ailang dest.x` and `./analyzer.x src.ailang` via Bash to check syntax. (10) VCS: use Olympus tool (snapshot, review, log, info, init) for compound workflows; use Git tool for raw git subcommands. (11) Write tool: use absolute paths. If grandparent missing, use Bash mkdir -p. For files >200 lines, use Bash `cat << 'EOF' > file`. (12) Write tool blocks /etc, /proc, /sys, /dev, /bin, /usr. (13) NO UNSOLICITED EDITS: never modify files unless explicitly asked — read-only exploration (Read, Head, Grep, Find, Stat, Wc, Du, Diff, LS, Git) is always OK without asking. (14) TOOL ERRORS: recheck your own parameters first — most errors are bad inputs not broken tools; retry with corrected params before reporting the tool as broken. (15) GREP: when path is a directory you MUST pass recursive=1; the include glob (e.g. *.ailang) only applies in recursive mode. (16) AGENT: always pass task_id (use the pgmem task ID from op=task_create) so the daemon can call task_end and mark the task complete; omitting task_id leaves the task stuck in pending forever. (17) AGENT WAITING: after spawning agents call `Sleep seconds=90` (the Sleep tool) then check Pgmem ONCE per wait cycle — NEVER use Bash sleep or poll Pgmem in a loop; the Sleep tool is the ONLY safe wait mechanism because it does not touch Pgmem; Pgmem is single-threaded and each pickup call holds the socket, blocking the agent daemon from parking its result and calling task_end, which causes a deadlock that kills the agent with a timeout."

    CC_ChdirToBinDir()
    CC_KillStaleTools()

    // Tools are provider-agnostic — boot once for the lifetime of the process.
    History.Init()
    IPCDispatch.Init()
    CC_BootTools()

    // Outer loop: /home returns here to pick a different provider without restarting.
    // auth_result == 0 means user quit from the provider menu — exit immediately.
    go_home = 1
    WhileLoop EqualTo(go_home, 1) {
        auth_result = CC_RunAuth()

        IfCondition EqualTo(auth_result, 0) ThenBlock: { go_home = 0 }
        IfCondition NotEqual(auth_result, 0) ThenBlock: {
            auth_mode_str = JSON.GetString(auth_result, "mode")
            credential = JSON.GetString(auth_result, "credential")
            CCRunState.auth_mode = auth_mode_str
            CCRunState.auth_cred = credential

            CCConst.PROJ_PROMPT = CC_LoadProjectPrompt()
            History.Init()
            Backend.Init(auth_mode_str, credential, CC_BuildFullPrompt())

            // Now grab the terminal — auth is done, no more cooked-mode prints.
            UI.Init()

            // Enable Terminal Bracketed Paste (\e[?2004h)
            bp_on = Allocate(16)
            SetByte(bp_on,0,27) SetByte(bp_on,1,91) SetByte(bp_on,2,63) SetByte(bp_on,3,50) SetByte(bp_on,4,48) SetByte(bp_on,5,48) SetByte(bp_on,6,52) SetByte(bp_on,7,104) SetByte(bp_on,8,0)
            CC_WriteStdout(bp_on)
            Deallocate(bp_on, 16)

            UI.BootScroll()

            // Compact in-chat session header — small mascot + version/model/cwd
            UI.SessionHeader(0, 0, 0)

            CCRunState.running = 1
            CCRunState.go_home = 0
            go_home = CC_ChatLoop()

            // Release terminal before looping back to cooked-mode provider menu.
            UI.Shutdown()
        }
    }

    CC_SessionCleanup()
    IPCDispatch.Shutdown()
    CC_KillAllChildren()
    SystemCall(CCSys.SYS_EXIT, 0, 0, 0, 0, 0)
}

RunTask(Main)
