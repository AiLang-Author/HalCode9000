// HalCode9000.Backend.Anthropic.ailang — Messages API request shape + SSE event router.
//
// Anthropic-specific glue between the generic agent loop in ClaudeCode.ailang
// and api.anthropic.com/v1/messages. Handles:
//   - Building the request JSON (model, system, messages, tools, stream:true)
//   - Building the headers string (x-api-key, anthropic-version)
//   - Routing SSE events via OnEvent — accumulates text + tool_use blocks
//   - Producing the assistant message + tool_results to commit to history
//
// Multi-tool-block aware: a single assistant turn can produce N tool_use
// blocks; we accumulate them all and the caller dispatches them as a batch
// (sending all results back in one user message with N tool_result entries).
//
// Public API:
//   Anthropic.Init(api_key, model, system_prompt)
//   Anthropic.BuildHeaders()                  -> headers_str
//   Anthropic.BuildRequest(messages_arr, tools_arr) -> body_str
//   Anthropic.OnEvent(event_type, event_data) -> signal
//        0 = CONTINUE, 1 = TURN_DONE_NO_TOOLS, 2 = TURN_DONE_WITH_TOOLS
//   Anthropic.GetPendingTools()               -> JSON array (live ref)
//   Anthropic.CommitAssistantToHistory()      — flush text+tools to history
//   Anthropic.AppendToolResultsToHistory(arr) — wrap results, push to history
//   Anthropic.IsCleanStop()                   -> Integer
//   Anthropic.Reset()                         — clear in-flight per-turn state
//
// Copyright 2026 Sean Collins, 2 Paws Machine and Engineering. SCSL.

LibraryImport.Arena
LibraryImport.JSON
LibraryImport.StringUtils
Import.Applications.HalCode9000.History
Import.Applications.HalCode9000.UI

FixedPool.AnthSignal {
    "CONTINUE":           Initialize=0
    "TURN_DONE_NO_TOOLS": Initialize=1
    "TURN_DONE_WITH_TOOLS": Initialize=2
}

FixedPool.AnthBlockKind {
    "NONE":               Initialize=0
    "TEXT":               Initialize=1
    "TOOL_USE":           Initialize=2
}

FixedPool.AnthConst {
    "TEXT_BUF_SZ":        Initialize=262144   // 256KB per-turn assistant text
    "TOOL_INPUT_SZ":      Initialize=65536    // 64KB per tool input accumulator
    "API_HOST":           Initialize=0, CanChange=True
    "API_PATH":           Initialize=0, CanChange=True
    "ANTH_VERSION":       Initialize=0, CanChange=True
}

FixedPool.AnthCfg {
    "api_key":            Initialize=0, CanChange=True   // for apikey mode
    "bearer_token":       Initialize=0, CanChange=True   // for oauth mode
    "auth_mode":          Initialize=0, CanChange=True   // "apikey" or "oauth"
    "model":              Initialize=0, CanChange=True
    "system_prompt":      Initialize=0, CanChange=True
    "max_tokens":         Initialize=4096, CanChange=True
}

FixedPool.AnthState {
    "text_buf":           Initialize=0, CanChange=True
    "text_used":          Initialize=0, CanChange=True
    "tool_blocks":        Initialize=0, CanChange=True   // JSON array of tool_use objects
    "current_kind":       Initialize=0, CanChange=True
    "current_tool":       Initialize=0, CanChange=True   // current tool_use JSON obj
    "tool_input_buf":     Initialize=0, CanChange=True   // accumulator for input_json_delta
    "tool_input_used":    Initialize=0, CanChange=True
    "tool_names":         Initialize=0, CanChange=True   // parallel array: index -> stable name string
    "tool_ids":           Initialize=0, CanChange=True   // parallel array: index -> stable id string
    "tool_count":         Initialize=0, CanChange=True   // entries in tool_names/tool_ids
    "last_input_tokens":  Initialize=0, CanChange=True
    "last_output_tokens": Initialize=0, CanChange=True
    "last_cache_read":    Initialize=0, CanChange=True
    "last_cache_write":   Initialize=0, CanChange=True
    "initialized":        Initialize=0, CanChange=True
}

// =============================================================================
// INIT
// =============================================================================
// auth_mode: "apikey" or "oauth". credential is the API key OR the Bearer token.
Function.Anthropic.Init {
    Input: auth_mode: Address
    Input: credential: Address
    Input: model: Address
    Input: system_prompt: Address
    Body: {
        AnthCfg.auth_mode = auth_mode
        IfCondition EqualTo(StringCompare(auth_mode, "oauth"), 0) ThenBlock: {
            AnthCfg.bearer_token = credential
            AnthCfg.api_key = 0
        } ElseBlock: {
            AnthCfg.api_key = credential
            AnthCfg.bearer_token = 0
        }
        AnthCfg.model = model
        AnthCfg.system_prompt = system_prompt

        AnthConst.API_HOST = "https://api.anthropic.com"
        AnthConst.API_PATH = "/v1/messages"
        AnthConst.ANTH_VERSION = "2023-06-01"

        AnthState.text_buf = Allocate(AnthConst.TEXT_BUF_SZ)
        SetByte(AnthState.text_buf, 0, 0)
        AnthState.text_used = 0
        AnthState.tool_blocks = JSON.NewArray()
        AnthState.current_kind = AnthBlockKind.NONE
        AnthState.current_tool = 0
        AnthState.tool_input_buf = Allocate(AnthConst.TOOL_INPUT_SZ)
        SetByte(AnthState.tool_input_buf, 0, 0)
        AnthState.tool_input_used = 0
        // Parallel arrays of stable string copies for tool name/id —
        // sidesteps a JSON-lib hash-collision bug where reading "name"
        // back from a tool_use object after Serialize* returns garbage
        // (consistently the literal string "index" via collision).
        // Capacity: 32 tool calls per turn (way over what any model emits).
        AnthState.tool_names = Allocate(256)   // 32 ptrs × 8 bytes
        AnthState.tool_ids   = Allocate(256)
        MemorySet(AnthState.tool_names, 0, 256)
        MemorySet(AnthState.tool_ids, 0, 256)
        AnthState.tool_count = 0
        AnthState.initialized = 1
    }
}

// Allocate a stable null-terminated copy of a string.
Function.Anthropic_DupString {
    Input: src: Address
    Output: Address
    Body: {
        IfCondition EqualTo(src, 0) ThenBlock: { ReturnValue(0) }
        n = StringLength(src)
        out = Allocate(Add(n, 1))
        i = 0
        WhileLoop LessThan(i, n) {
            SetByte(out, i, GetByte(src, i))
            i = Add(i, 1)
        }
        SetByte(out, n, 0)
        ReturnValue(out)
    }
}

// =============================================================================
// HEADERS — required: x-api-key, anthropic-version, content-type
// =============================================================================
Function.Anthropic.BuildHeaders {
    Output: Address
    Body: {
        // Branch on auth_mode: oauth -> Authorization: Bearer, apikey -> x-api-key
        is_oauth = 0
        IfCondition NotEqual(AnthCfg.auth_mode, 0) ThenBlock: {
            IfCondition EqualTo(StringCompare(AnthCfg.auth_mode, "oauth"), 0) ThenBlock: {
                is_oauth = 1
            }
        }
        a = ""
        IfCondition EqualTo(is_oauth, 1) ThenBlock: {
            a = StringConcat("Authorization: Bearer ", AnthCfg.bearer_token)
        } ElseBlock: {
            a = StringConcat("x-api-key: ", AnthCfg.api_key)
        }
        b = StringConcat(a, "\nanthropic-version: ")
        c = StringConcat(b, AnthConst.ANTH_VERSION)
        d = StringConcat(c, "\ncontent-type: application/json")
        e = StringConcat(d, "\naccept: text/event-stream")
        // oauth beta combines oauth + caching + extended-cache-ttl (for 1h TTL support)
        IfCondition EqualTo(is_oauth, 1) ThenBlock: {
            f = StringConcat(e, "\nanthropic-beta: oauth-2025-04-20,prompt-caching-2024-07-31,extended-cache-ttl-2025-02-19\n")
        } ElseBlock: {
            f = StringConcat(e, "\nanthropic-beta: prompt-caching-2024-07-31,extended-cache-ttl-2025-02-19\n")
        }
        ReturnValue(f)
    }
}

// =============================================================================
// REQUEST URL helper
// =============================================================================
Function.Anthropic.GetURL {
    Output: Address
    Body: {
        ReturnValue(StringConcat(AnthConst.API_HOST, AnthConst.API_PATH))
    }
}

// =============================================================================
// BUILD REQUEST BODY
// =============================================================================
Function.Anthropic.BuildRequest {
    Input: messages_arr: Address
    Input: tools_arr: Address
    Output: Address
    Body: {
        req = JSON.NewObject()
        JSON.SetString(req, "model", AnthCfg.model)
        JSON.SetNumber(req, "max_tokens", AnthCfg.max_tokens)
        JSON.SetBool(req, "stream", 1)

        // System prompt with 1-hour cached text block. 1h TTL survives
        // inter-turn gaps that would expire the default 5-minute cache.
        IfCondition NotEqual(AnthCfg.system_prompt, 0) ThenBlock: {
            sys_cc = JSON.NewObject()
            JSON.SetString(sys_cc, "type", "ephemeral")
            JSON.SetString(sys_cc, "ttl", "1h")
            sys_block = JSON.NewObject()
            JSON.SetString(sys_block, "type", "text")
            JSON.SetString(sys_block, "text", AnthCfg.system_prompt)
            JSON.SetObject(sys_block, "cache_control", sys_cc)
            sys_arr = JSON.NewArray()
            JSON.PushObject(sys_arr, sys_block)
            JSON.SetArray(req, "system", sys_arr)
        }

        JSON.SetArray(req, "messages", messages_arr)

        // Last tool gets 1-hour cache_control — extends breakpoint past
        // system+tools so both are covered in the same cache slot.
        tools_count = 0
        IfCondition NotEqual(tools_arr, 0) ThenBlock: {
            tools_count = JSON.ArrayLength(tools_arr)
            IfCondition GreaterThan(tools_count, 0) ThenBlock: {
                last_tag = JSON.ArrayGet(tools_arr, Subtract(tools_count, 1))
                last_tool = JSON.AsObject(last_tag)
                IfCondition NotEqual(last_tool, 0) ThenBlock: {
                    tool_cc = JSON.NewObject()
                    JSON.SetString(tool_cc, "type", "ephemeral")
                    JSON.SetString(tool_cc, "ttl", "1h")
                    JSON.SetObject(last_tool, "cache_control", tool_cc)
                }
                JSON.SetArray(req, "tools", tools_arr)
            }
        }
        body = JSON.SerializeObject(req)
        ReturnValue(body)
    }
}

// =============================================================================
// SSE EVENT ROUTER
// =============================================================================
// event_type: "message_start" | "content_block_start" | "content_block_delta"
//             | "content_block_stop" | "message_delta" | "message_stop" | "ping"
// event_data: JSON string of the event payload
//
// Returns AnthSignal.{CONTINUE, TURN_DONE_NO_TOOLS, TURN_DONE_WITH_TOOLS}
// =============================================================================
Function.Anthropic.OnEvent {
    Input: event_type: Address
    Input: event_data: Address
    Output: Integer
    Body: {
        // ping / unknown
        IfCondition EqualTo(event_type, 0) ThenBlock: { ReturnValue(AnthSignal.CONTINUE) }

        // message_stop -> end of turn
        IfCondition EqualTo(StringCompare(event_type, "message_stop"), 0) ThenBlock: {
            tools_n = JSON.ArrayLength(AnthState.tool_blocks)
            IfCondition GreaterThan(tools_n, 0) ThenBlock: {
                ReturnValue(AnthSignal.TURN_DONE_WITH_TOOLS)
            }
            ReturnValue(AnthSignal.TURN_DONE_NO_TOOLS)
        }

        // Cheap exits
        IfCondition EqualTo(StringCompare(event_type, "ping"), 0) ThenBlock: {
            ReturnValue(AnthSignal.CONTINUE)
        }
        IfCondition EqualTo(StringCompare(event_type, "message_start"), 0) ThenBlock: {
            IfCondition NotEqual(event_data, 0) ThenBlock: {
                p2 = ParseJSON(event_data)
                IfCondition NotEqual(p2, 0) ThenBlock: {
                    o2 = JSON.AsObject(p2)
                    IfCondition NotEqual(o2, 0) ThenBlock: {
                        msg2 = JSON.GetObject(o2, "message")
                        IfCondition NotEqual(msg2, 0) ThenBlock: {
                            u2 = JSON.GetObject(msg2, "usage")
                            IfCondition NotEqual(u2, 0) ThenBlock: {
                                AnthState.last_input_tokens = JSON.GetNumber(u2, "input_tokens")
                                AnthState.last_cache_read  = JSON.GetNumber(u2, "cache_read_input_tokens")
                                AnthState.last_cache_write = JSON.GetNumber(u2, "cache_creation_input_tokens")
                            }
                        }
                    }
                    JSON.Free(p2)
                }
            }
            ReturnValue(AnthSignal.CONTINUE)
        }
        IfCondition EqualTo(StringCompare(event_type, "message_delta"), 0) ThenBlock: {
            IfCondition NotEqual(event_data, 0) ThenBlock: {
                p3 = ParseJSON(event_data)
                IfCondition NotEqual(p3, 0) ThenBlock: {
                    o3 = JSON.AsObject(p3)
                    IfCondition NotEqual(o3, 0) ThenBlock: {
                        u3 = JSON.GetObject(o3, "usage")
                        IfCondition NotEqual(u3, 0) ThenBlock: {
                            AnthState.last_output_tokens = JSON.GetNumber(u3, "output_tokens")
                        }
                    }
                    JSON.Free(p3)
                }
            }
            ReturnValue(AnthSignal.CONTINUE)
        }

        // Anything below requires a parsed event payload
        IfCondition EqualTo(event_data, 0) ThenBlock: { ReturnValue(AnthSignal.CONTINUE) }
        parsed = ParseJSON(event_data)
        IfCondition EqualTo(parsed, 0) ThenBlock: { ReturnValue(AnthSignal.CONTINUE) }
        obj = JSON.AsObject(parsed)
        IfCondition EqualTo(obj, 0) ThenBlock: {
            JSON.Free(parsed)
            ReturnValue(AnthSignal.CONTINUE)
        }

        // content_block_start
        IfCondition EqualTo(StringCompare(event_type, "content_block_start"), 0) ThenBlock: {
            block = JSON.GetObject(obj, "content_block")
            IfCondition NotEqual(block, 0) ThenBlock: {
                btype = JSON.GetString(block, "type")
                IfCondition NotEqual(btype, 0) ThenBlock: {
                    IfCondition EqualTo(StringCompare(btype, "text"), 0) ThenBlock: {
                        AnthState.current_kind = AnthBlockKind.TEXT
                    }
                    IfCondition EqualTo(StringCompare(btype, "tool_use"), 0) ThenBlock: {
                        AnthState.current_kind = AnthBlockKind.TOOL_USE
                        tid = JSON.GetString(block, "id")
                        tname = JSON.GetString(block, "name")
                        // Stash STABLE COPIES in our own parallel arrays
                        // to bypass a Library.JSON hash-collision bug.
                        // Library.JSON has a hash-collision bug where reading
                        // "name" back later returns garbage ("index"). We avoid
                        // it by never re-reading from JSON for the name/id.
                        slot = AnthState.tool_count
                        IfCondition LessThan(slot, 32) ThenBlock: {
                            StoreValue(Add(AnthState.tool_names, Multiply(slot, 8)), Anthropic_DupString(tname))
                            StoreValue(Add(AnthState.tool_ids,   Multiply(slot, 8)), Anthropic_DupString(tid))
                            AnthState.tool_count = Add(slot, 1)
                        }
                        // Still build the JSON tool_use object for history,
                        // but the dispatch code reads name/id from our stash.
                        tu = JSON.NewObject()
                        JSON.SetString(tu, "type", "tool_use")
                        IfCondition NotEqual(tid, 0) ThenBlock: { JSON.SetString(tu, "id", tid) }
                        IfCondition NotEqual(tname, 0) ThenBlock: { JSON.SetString(tu, "name", tname) }
                        AnthState.current_tool = tu
                        // Reset input accumulator
                        SetByte(AnthState.tool_input_buf, 0, 0)
                        AnthState.tool_input_used = 0
                    }
                }
            }
            JSON.Free(parsed)
            ReturnValue(AnthSignal.CONTINUE)
        }

        // content_block_delta
        IfCondition EqualTo(StringCompare(event_type, "content_block_delta"), 0) ThenBlock: {
            delta = JSON.GetObject(obj, "delta")
            IfCondition NotEqual(delta, 0) ThenBlock: {
                dtype = JSON.GetString(delta, "type")
                IfCondition NotEqual(dtype, 0) ThenBlock: {
                    IfCondition EqualTo(StringCompare(dtype, "text_delta"), 0) ThenBlock: {
                        text = JSON.GetString(delta, "text")
                        IfCondition NotEqual(text, 0) ThenBlock: {
                            Anthropic_OnTextDelta(text)
                        }
                    }
                    IfCondition EqualTo(StringCompare(dtype, "input_json_delta"), 0) ThenBlock: {
                        partial = JSON.GetString(delta, "partial_json")
                        IfCondition NotEqual(partial, 0) ThenBlock: {
                            Anthropic_AppendToolInput(partial)
                        }
                    }
                }
            }
            JSON.Free(parsed)
            ReturnValue(AnthSignal.CONTINUE)
        }

        // content_block_stop
        IfCondition EqualTo(StringCompare(event_type, "content_block_stop"), 0) ThenBlock: {
            IfCondition EqualTo(AnthState.current_kind, AnthBlockKind.TOOL_USE) ThenBlock: {
                Anthropic_FinalizeCurrentToolBlock()
            }
            AnthState.current_kind = AnthBlockKind.NONE
            JSON.Free(parsed)
            ReturnValue(AnthSignal.CONTINUE)
        }

        JSON.Free(parsed)
        ReturnValue(AnthSignal.CONTINUE)
    }
}

// =============================================================================
// TEXT DELTA — print to stdout AND accumulate for history
// =============================================================================
Function.Anthropic_OnTextDelta {
    Input: text: Address
    Body: {
        len = StringLength(text)
        IfCondition LessEqual(len, 0) ThenBlock: { ReturnValue(0) }
        // Stream into the raw-mode chat region
        UI.ChatPrint(text)
        // Append to text_buf
        free_space = Subtract(AnthConst.TEXT_BUF_SZ, Add(AnthState.text_used, 1))
        copy = len
        IfCondition GreaterThan(copy, free_space) ThenBlock: { copy = free_space }
        IfCondition LessEqual(copy, 0) ThenBlock: { ReturnValue(0) }
        i = 0
        WhileLoop LessThan(i, copy) {
            SetByte(AnthState.text_buf, Add(AnthState.text_used, i), GetByte(text, i))
            i = Add(i, 1)
        }
        AnthState.text_used = Add(AnthState.text_used, copy)
        SetByte(AnthState.text_buf, AnthState.text_used, 0)
    }
}

Function.Anthropic_AppendToolInput {
    Input: partial: Address
    Body: {
        plen = StringLength(partial)
        free_space = Subtract(AnthConst.TOOL_INPUT_SZ, Add(AnthState.tool_input_used, 1))
        copy = plen
        IfCondition GreaterThan(copy, free_space) ThenBlock: { copy = free_space }
        IfCondition LessEqual(copy, 0) ThenBlock: { ReturnValue(0) }
        i = 0
        WhileLoop LessThan(i, copy) {
            SetByte(AnthState.tool_input_buf, Add(AnthState.tool_input_used, i), GetByte(partial, i))
            i = Add(i, 1)
        }
        AnthState.tool_input_used = Add(AnthState.tool_input_used, copy)
        SetByte(AnthState.tool_input_buf, AnthState.tool_input_used, 0)
    }
}

// Parse the accumulated tool input JSON string, attach it as `input` field,
// push the tool_use block to AnthState.tool_blocks.
Function.Anthropic_FinalizeCurrentToolBlock {
    Body: {
        IfCondition EqualTo(AnthState.current_tool, 0) ThenBlock: { ReturnValue(0) }
        // Parse accumulated input JSON (may be empty; default to {})
        input_obj = 0
        IfCondition GreaterThan(AnthState.tool_input_used, 0) ThenBlock: {
            parsed = ParseJSON(AnthState.tool_input_buf)
            IfCondition NotEqual(parsed, 0) ThenBlock: {
                input_obj = JSON.AsObject(parsed)
            }
        }
        IfCondition EqualTo(input_obj, 0) ThenBlock: {
            input_obj = JSON.NewObject()
        }
        JSON.SetObject(AnthState.current_tool, "input", input_obj)
        JSON.PushObject(AnthState.tool_blocks, AnthState.current_tool)
        AnthState.current_tool = 0
        SetByte(AnthState.tool_input_buf, 0, 0)
        AnthState.tool_input_used = 0
    }
}

// =============================================================================
// PUBLIC ACCESSORS
// =============================================================================
Function.Anthropic.GetPendingTools {
    Output: Address
    Body: { ReturnValue(AnthState.tool_blocks) }
}

// Stable accessors that bypass the JSON-lib hash-collision bug.
// Caller passes the same index they'd use into GetPendingTools()'s array.
Function.Anthropic.GetToolName {
    Input: idx: Integer
    Output: Address
    Body: {
        IfCondition Or(LessThan(idx, 0), GreaterEqual(idx, AnthState.tool_count)) ThenBlock: {
            ReturnValue(0)
        }
        ReturnValue(Dereference(Add(AnthState.tool_names, Multiply(idx, 8))))
    }
}

Function.Anthropic.GetToolId {
    Input: idx: Integer
    Output: Address
    Body: {
        IfCondition Or(LessThan(idx, 0), GreaterEqual(idx, AnthState.tool_count)) ThenBlock: {
            ReturnValue(0)
        }
        ReturnValue(Dereference(Add(AnthState.tool_ids, Multiply(idx, 8))))
    }
}

// =============================================================================
// COMMIT — wrap accumulated text + tool_blocks into a single assistant
// message and append to history. Then reset per-turn state.
// =============================================================================
Function.Anthropic.CommitAssistantToHistory {
    Body: {
        content_arr = JSON.NewArray()
        IfCondition GreaterThan(AnthState.text_used, 0) ThenBlock: {
            text_block = JSON.NewObject()
            JSON.SetString(text_block, "type", "text")
            // Allocate stable copy for history
            txt_copy = Allocate(Add(AnthState.text_used, 1))
            i = 0
            WhileLoop LessThan(i, AnthState.text_used) {
                SetByte(txt_copy, i, GetByte(AnthState.text_buf, i))
                i = Add(i, 1)
            }
            SetByte(txt_copy, AnthState.text_used, 0)
            JSON.SetString(text_block, "text", txt_copy)
            JSON.PushObject(content_arr, text_block)
        }
        // Append all tool_use blocks. CRITICAL: rebuild each block from
        // our stable name/id stash + the input object — reading the
        // existing tu object's "name" field returns garbage ("index")
        // due to the Library.JSON hash-collision bug. So we construct a
        // fresh object with the known-good name/id but reuse the parsed
        // input sub-object.
        n = JSON.ArrayLength(AnthState.tool_blocks)
        i = 0
        WhileLoop LessThan(i, n) {
            tu_tag = JSON.ArrayGet(AnthState.tool_blocks, i)
            tu_old = JSON.AsObject(tu_tag)
            IfCondition NotEqual(tu_old, 0) ThenBlock: {
                fresh = JSON.NewObject()
                JSON.SetString(fresh, "type", "tool_use")
                stable_id = Anthropic.GetToolId(i)
                stable_name = Anthropic.GetToolName(i)
                IfCondition NotEqual(stable_id, 0) ThenBlock: { JSON.SetString(fresh, "id", stable_id) }
                IfCondition NotEqual(stable_name, 0) ThenBlock: { JSON.SetString(fresh, "name", stable_name) }
                input_obj = JSON.GetObject(tu_old, "input")
                IfCondition NotEqual(input_obj, 0) ThenBlock: { JSON.SetObject(fresh, "input", input_obj) }
                JSON.PushObject(content_arr, fresh)
            }
            i = Add(i, 1)
        }
        History.AppendAssistantBlocks(content_arr)
    }
}

// Append a user message containing tool_result blocks (one per dispatched tool).
// results_arr is a JSON array of {tool_use_id, content, is_error?} objects.
Function.Anthropic.AppendToolResultsToHistory {
    Input: results_arr: Address
    Body: {
        // Wrap each entry in {type: "tool_result", ...}
        wrapped = JSON.NewArray()
        n = JSON.ArrayLength(results_arr)
        i = 0
        WhileLoop LessThan(i, n) {
            r_tag = JSON.ArrayGet(results_arr, i)
            r = JSON.AsObject(r_tag)
            IfCondition NotEqual(r, 0) ThenBlock: {
                tr = JSON.NewObject()
                JSON.SetString(tr, "type", "tool_result")
                tid = JSON.GetString(r, "tool_use_id")
                IfCondition NotEqual(tid, 0) ThenBlock: { JSON.SetString(tr, "tool_use_id", tid) }
                content = JSON.GetString(r, "content")
                IfCondition NotEqual(content, 0) ThenBlock: { JSON.SetString(tr, "content", content) }
                is_err = JSON.GetBool(r, "is_error")
                IfCondition EqualTo(is_err, 1) ThenBlock: { JSON.SetBool(tr, "is_error", 1) }
                JSON.PushObject(wrapped, tr)
            }
            i = Add(i, 1)
        }
        History.AppendToolResults(wrapped)
    }
}

Function.Anthropic.IsCleanStop {
    Output: Integer
    Body: {
        // Anthropic always correctly sends message_stop. A drop is a true drop.
        ReturnValue(0)
    }
}

// Clear per-turn state so the next turn starts fresh. Tool_blocks is
// re-allocated fresh; the previous one is now owned by the history.
Function.Anthropic.PrintUsage {
    Body: {
        IfCondition GreaterThan(AnthState.last_input_tokens, 0) ThenBlock: {
            UI.SetTokens(AnthState.last_input_tokens, AnthState.last_output_tokens)
        }
        IfCondition GreaterThan(AnthState.last_cache_read, 0) ThenBlock: {
            cr_str = NumberToString(AnthState.last_cache_read)
            cw_str = NumberToString(AnthState.last_cache_write)
            msg = StringConcat("  cache: ", cr_str)
            msg = StringConcat(msg, " read / ")
            msg = StringConcat(msg, cw_str)
            msg = StringConcat(msg, " written")
            UI.ChatPrintDim(msg)
        }
    }
}

Function.Anthropic.Reset {
    Body: {
        AnthState.text_used = 0
        SetByte(AnthState.text_buf, 0, 0)
        AnthState.tool_blocks = JSON.NewArray()
        AnthState.current_kind = AnthBlockKind.NONE
        AnthState.current_tool = 0
        AnthState.tool_input_used = 0
        SetByte(AnthState.tool_input_buf, 0, 0)
        // Clear stable name/id stash for next turn
        MemorySet(AnthState.tool_names, 0, 256)
        MemorySet(AnthState.tool_ids, 0, 256)
        AnthState.tool_count = 0
    }
}
