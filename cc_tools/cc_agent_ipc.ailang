// cc_agent_ipc.ailang — HalCode9000 Sub-Agent Orchestrator
//
// Spawns a DeepSeek-v4-Flash worker using the standalone deepseek.x CLI.
// Handles writing the context to a temp file, executing the worker, and
// reading the result back to the orchestrator.
//
// Socket: @halcode/Agent
//
// Copyright 2026 Sean Collins, 2 Paws Machine and Engineering. SCSL.

LibraryImport.Arena
LibraryImport.Socket
LibraryImport.JSON
LibraryImport.StringUtils
LibraryImport.UtilArgs

FixedPool.AgentSys {
    "SYS_READ":      Initialize=0
    "SYS_WRITE":     Initialize=1
    "SYS_OPEN":      Initialize=2
    "SYS_CLOSE":     Initialize=3
    "SYS_FORK":      Initialize=57
    "SYS_EXECVE":    Initialize=59
    "SYS_EXIT":      Initialize=60
    "SYS_WAIT4":     Initialize=61
    "SYS_MKDIR":     Initialize=83
    "SYS_UNLINK":    Initialize=87
}

FixedPool.AgentConst {
    "SOCK_PATH":     Initialize="@halcode/Agent", CanChange=True
    "BACKLOG":       Initialize=8
}

FixedPool.AgentState {
    "schema":        Initialize=0, CanChange=True
    "listen_fd":     Initialize=-1, CanChange=True
    "running":       Initialize=1, CanChange=True
}

// Inherit environment variables so DEEPSEEK_API_KEY is passed down to deepseek.x
Function.Agent_BuildInheritedEnvp {
    Output: Address
    Body: {
        fd = SystemCall(AgentSys.SYS_OPEN, "/proc/self/environ", 0, 0, 0, 0)
        IfCondition LessThan(fd, 0) ThenBlock: { ReturnValue(0) }
        buf = Allocate(65536)
        n = SystemCall(0, fd, buf, 65536, 0, 0)
        SystemCall(AgentSys.SYS_CLOSE, fd, 0, 0, 0, 0)
        IfCondition LessEqual(n, 0) ThenBlock: { ReturnValue(0) }

        envp = Allocate(4096)
        idx = 0
        StoreValue(Add(envp, 0), buf)
        i = 0
        WhileLoop LessThan(i, n) {
            IfCondition EqualTo(GetByte(buf, i), 0) ThenBlock: {
                next_pos = Add(i, 1)
                IfCondition LessThan(next_pos, n) ThenBlock: {
                    idx = Add(idx, 1)
                    StoreValue(Add(envp, Multiply(idx, 8)), Add(buf, next_pos))
                }
            }
            i = Add(i, 1)
        }
        StoreValue(Add(envp, Multiply(Add(idx, 1), 8)), 0)
        ReturnValue(envp)
    }
}

Function.Agent_BuildSchema {
    Output: Address
    Body: {
        s = UtilArgs_NewSchema("Agent", "Spawns a background DeepSeek-v4-Flash sub-agent to process a task asynchronously. Pulls input from Pgmem and parks output in Pgmem.")
        UtilArgs_AddField(s, "task_id", "string", 0, "The Task ID in pgmem (optional).", "task_id")
        UtilArgs_AddField(s, "task_prompt", "string", 1, "The instructions or goal for the sub-agent.", "task_prompt")
        UtilArgs_AddField(s, "context_key", "string", 1, "The Pgmem key to pickup context data from.", "context_key")
        UtilArgs_AddField(s, "result_key", "string", 1, "The Pgmem key to park the result to.", "result_key")
        ReturnValue(s)
    }
}

Function.Agent_SendError {
    Input: client_fd: Integer
    Input: id: Address
    Input: error_msg: Address
    Body: {
        resp = JSON.NewObject()
        JSON.SetString(resp, "method", "result")
        IfCondition NotEqual(id, 0) ThenBlock: { JSON.SetString(resp, "id", id) }
        JSON.SetBool(resp, "ok", 0)
        JSON.SetString(resp, "error", error_msg)
        Socket.SendMsg(client_fd, JSON.SerializeObject(resp))
    }
}

Function.Agent_SendResult {
    Input: client_fd: Integer
    Input: id: Address
    Input: content: Address
    Body: {
        resp = JSON.NewObject()
        JSON.SetString(resp, "method", "result")
        IfCondition NotEqual(id, 0) ThenBlock: { JSON.SetString(resp, "id", id) }
        JSON.SetBool(resp, "ok", 1)
        IfCondition NotEqual(content, 0) ThenBlock: { JSON.SetString(resp, "content", content) }
        Socket.SendMsg(client_fd, JSON.SerializeObject(resp))
    }
}

Function.Agent_SendSchema {
    Input: client_fd: Integer
    Body: {
        schema_str = "{\"name\":\"Agent\",\"description\":\"Spawns a background DeepSeek-v4-Flash sub-agent to process a task asynchronously. Pulls input from Pgmem and parks output in Pgmem.\",\"input_schema\":{\"type\":\"object\",\"properties\":{\"task_id\":{\"type\":\"string\",\"description\":\"The Task ID in pgmem (optional).\"},\"task_prompt\":{\"type\":\"string\",\"description\":\"The instructions or goal for the sub-agent.\"},\"context_key\":{\"type\":\"string\",\"description\":\"The Pgmem key to pickup context data from.\"},\"result_key\":{\"type\":\"string\",\"description\":\"The Pgmem key to park the result to.\"}},\"required\":[\"task_prompt\",\"context_key\",\"result_key\"]}}"
        resp_str = StringConcat("{\"method\":\"schema_response\",\"schema\":", schema_str)
        resp_str = StringConcat(resp_str, "}")
        Socket.SendMsg(client_fd, resp_str)
    }
}

Function.Agent_CallPgmem {
    Input: args_obj: Address
    Output: Address
    Body: {
        fd = Socket.Create(1, 1)
        IfCondition LessThan(fd, 0) ThenBlock: { ReturnValue(0) }
        rc = Socket.ConnectUnix(fd, "@halcode/Pgmem")
        IfCondition LessThan(rc, 0) ThenBlock: { Socket.Close(fd) ReturnValue(0) }
        
        wrap = JSON.NewObject()
        JSON.SetString(wrap, "method", "call")
        JSON.SetString(wrap, "id", "agent_internal")
        JSON.SetObject(wrap, "args", args_obj)
        
        Socket.SendMsg(fd, JSON.SerializeObject(wrap))
        resp_str = Socket.RecvMsg(fd)
        Socket.Close(fd)
        ReturnValue(resp_str)
    }
}

// Append a timestamped line to /tmp/hal_agent_<task_id>.log.
// O_WRONLY|O_CREAT|O_APPEND = 1|64|1024 = 1089, mode 0644 = 420
Function.Agent_LogMsg {
    Input: log_path: Address
    Input: msg: Address
    Body: {
        IfCondition EqualTo(log_path, 0) ThenBlock: { ReturnValue(0) }
        IfCondition EqualTo(msg, 0) ThenBlock: { ReturnValue(0) }
        lfd = SystemCall(AgentSys.SYS_OPEN, log_path, 1089, 420, 0, 0)
        IfCondition LessThan(lfd, 0) ThenBlock: { ReturnValue(0) }
        llen = StringLength(msg)
        SystemCall(AgentSys.SYS_WRITE, lfd, msg, llen, 0, 0)
        nl = Allocate(4)
        SetByte(nl, 0, 10) SetByte(nl, 1, 0)
        SystemCall(AgentSys.SYS_WRITE, lfd, nl, 1, 0, 0)
        Deallocate(nl, 4)
        SystemCall(AgentSys.SYS_CLOSE, lfd, 0, 0, 0, 0)
    }
}

Function.Agent_HandleRequest {
    Input: client_fd: Integer
    Input: req_str: Address
    Output: Integer
    Body: {
        parsed = ParseJSON(req_str)
        IfCondition EqualTo(parsed, 0) ThenBlock: { Agent_SendError(client_fd, 0, "invalid JSON") ReturnValue(0) }
        obj = JSON.AsObject(parsed)
        IfCondition EqualTo(obj, 0) ThenBlock: { Agent_SendError(client_fd, 0, "request must be a JSON object") ReturnValue(0) }

        method = JSON.GetString(obj, "method")
        IfCondition EqualTo(method, 0) ThenBlock: { Agent_SendError(client_fd, 0, "missing method") ReturnValue(0) }
        IfCondition EqualTo(StringCompare(method, "schema"), 0) ThenBlock: { Agent_SendSchema(client_fd) ReturnValue(0) }

        IfCondition EqualTo(StringCompare(method, "call"), 0) ThenBlock: {
            id = JSON.GetString(obj, "id")
            args = JSON.GetObject(obj, "args")
            validated = UtilArgs_ParseIPC(AgentState.schema, args)
            IfCondition EqualTo(validated, 0) ThenBlock: {
                Agent_SendError(client_fd, id, "missing required arguments") ReturnValue(0)
            }

            t_id = UtilArgs_GetString(validated, "task_id")
            t_prompt = UtilArgs_GetString(validated, "task_prompt")
            c_key = UtilArgs_GetString(validated, "context_key")
            r_key = UtilArgs_GetString(validated, "result_key")
            
            IfCondition EqualTo(t_id, 0) ThenBlock: { t_id = "unknown" }

            pid = SystemCall(AgentSys.SYS_FORK, 0, 0, 0, 0, 0)
            IfCondition EqualTo(pid, 0) ThenBlock: {
                pid2 = SystemCall(AgentSys.SYS_FORK, 0, 0, 0, 0, 0)
                IfCondition GreaterThan(pid2, 0) ThenBlock: {
                    SystemCall(AgentSys.SYS_EXIT, 0, 0, 0, 0, 0)
                }
                
                // Background Worker (Daemon)
                Arena_Init()
                log_path = StringConcat("/tmp/hal_agent_", t_id)
                log_path = StringConcat(log_path, ".log")
                Agent_LogMsg(log_path, "[daemon] started")
                Agent_LogMsg(log_path, StringConcat("[daemon] task_id=", t_id))
                Agent_LogMsg(log_path, StringConcat("[daemon] context_key=", c_key))
                Agent_LogMsg(log_path, StringConcat("[daemon] result_key=", r_key))

                c_data = ""
                IfCondition NotEqual(c_key, 0) ThenBlock: {
                    pg_req = JSON.NewObject()
                    JSON.SetString(pg_req, "op", "pickup")
                    JSON.SetString(pg_req, "key", c_key)
                    pg_resp_str = Agent_CallPgmem(pg_req)
                    IfCondition NotEqual(pg_resp_str, 0) ThenBlock: {
                        pg_resp = JSON.AsObject(ParseJSON(pg_resp_str))
                        IfCondition NotEqual(pg_resp, 0) ThenBlock: {
                            IfCondition EqualTo(JSON.GetBool(pg_resp, "ok"), 1) ThenBlock: {
                                c_data = JSON.GetString(pg_resp, "content")
                            }
                        }
                    }
                }
                
                in_content = StringConcat("TASK INSTRUCTIONS:\n", t_prompt)
                in_content = StringConcat(in_content, "\n\nCONTEXT DATA:\n")
                IfCondition NotEqual(c_data, 0) ThenBlock: {
                    in_content = StringConcat(in_content, c_data)
                }
                
                in_path = StringConcat("/tmp/agent_in_", t_id)
                in_path = StringConcat(in_path, ".txt")
                out_path = StringConcat("/tmp/agent_out_", t_id)
                out_path = StringConcat(out_path, ".txt")

                Agent_LogMsg(log_path, StringConcat("[daemon] writing input to ", in_path))
                fd = SystemCall(AgentSys.SYS_OPEN, in_path, 577, 384, 0, 0) // O_WRONLY|O_CREAT|O_TRUNC, 0600
                IfCondition GreaterEqual(fd, 0) ThenBlock: {
                    SystemCall(AgentSys.SYS_WRITE, fd, in_content, StringLength(in_content), 0, 0)
                    SystemCall(AgentSys.SYS_CLOSE, fd, 0, 0, 0, 0)
                }

                SystemCall(AgentSys.SYS_UNLINK, out_path, 0, 0, 0, 0)
                envp = Agent_BuildInheritedEnvp()

                Agent_LogMsg(log_path, "[daemon] spawning HalCode9000.x worker")
                cpid = SystemCall(AgentSys.SYS_FORK, 0, 0, 0, 0, 0)
                IfCondition EqualTo(cpid, 0) ThenBlock: {
                    argv = Allocate(32)
                    StoreValue(Add(argv, 0), "/bin/sh")
                    StoreValue(Add(argv, 8), "-c")
                    cmd = "timeout 300 ./HalCode9000.x --agent deepseek < "
                    cmd = StringConcat(cmd, in_path)
                    cmd = StringConcat(cmd, " > ")
                    cmd = StringConcat(cmd, out_path)
                    cmd = StringConcat(cmd, " 2>>")
                    cmd = StringConcat(cmd, log_path)
                    StoreValue(Add(argv, 16), cmd)
                    StoreValue(Add(argv, 24), 0)
                    SystemCall(AgentSys.SYS_EXECVE, "/bin/sh", argv, envp)
                    SystemCall(AgentSys.SYS_EXIT, 1, 0, 0, 0, 0)
                }

                status_ptr2 = Allocate(8)
                SystemCall(AgentSys.SYS_WAIT4, cpid, status_ptr2, 0, 0, 0)
                raw_status2 = Dereference(status_ptr2, "dword")
                exit_code2 = Modulo(Divide(raw_status2, 256), 256)
                Deallocate(status_ptr2, 8)
                Agent_LogMsg(log_path, StringConcat("[daemon] worker exited, code=", NumberToString(exit_code2)))

                out_content = "[Error: Sub-agent execution failed]"
                out_fd = SystemCall(AgentSys.SYS_OPEN, out_path, 0, 0, 0, 0)
                IfCondition GreaterEqual(out_fd, 0) ThenBlock: {
                    buf = Allocate(1048576)
                    n = SystemCall(AgentSys.SYS_READ, out_fd, buf, 1048575, 0, 0)
                    SystemCall(AgentSys.SYS_CLOSE, out_fd, 0, 0, 0, 0)
                    Agent_LogMsg(log_path, StringConcat("[daemon] output bytes=", NumberToString(n)))
                    IfCondition GreaterThan(n, 0) ThenBlock: {
                        SetByte(buf, n, 0)
                        out_content = buf
                    }
                } ElseBlock: {
                    Agent_LogMsg(log_path, "[daemon] output file not found or empty")
                }

                Agent_LogMsg(log_path, StringConcat("[daemon] parking to pgmem key=", r_key))
                park_req = JSON.NewObject()
                JSON.SetString(park_req, "op", "park")
                JSON.SetString(park_req, "key", r_key)
                JSON.SetString(park_req, "kind", "tool_result")
                JSON.SetString(park_req, "content", out_content)
                JSON.SetString(park_req, "scope", "project")
                Agent_CallPgmem(park_req)
                Agent_LogMsg(log_path, "[daemon] park sent")

                // Write flag file so HalCode9000 main loop can show a notification.
                notify_fd = SystemCall(AgentSys.SYS_OPEN, "/tmp/hal_agent_notify.txt", 577, 420, 0, 0)
                IfCondition GreaterEqual(notify_fd, 0) ThenBlock: {
                    notify_msg = StringConcat("Agent parked: ", r_key)
                    notify_msg = StringConcat(notify_msg, "\n")
                    SystemCall(AgentSys.SYS_WRITE, notify_fd, notify_msg, StringLength(notify_msg), 0, 0)
                    SystemCall(AgentSys.SYS_CLOSE, notify_fd, 0, 0, 0, 0)
                }

                IfCondition GreaterEqual(out_fd, 0) ThenBlock: {
                    Deallocate(buf, 1048576)
                }
                
                IfCondition NotEqual(StringCompare(t_id, "unknown"), 0) ThenBlock: {
                    Agent_LogMsg(log_path, "[daemon] calling task_end")
                    end_req = JSON.NewObject()
                    JSON.SetString(end_req, "op", "task_end")
                    JSON.SetString(end_req, "task_id", t_id)
                    JSON.SetString(end_req, "status", "complete")
                    JSON.SetString(end_req, "result_key", r_key)
                    Agent_CallPgmem(end_req)
                    Agent_LogMsg(log_path, "[daemon] task_end sent")
                }

                Agent_LogMsg(log_path, "[daemon] done, cleaning up")
                SystemCall(AgentSys.SYS_UNLINK, in_path, 0, 0, 0, 0)
                SystemCall(AgentSys.SYS_UNLINK, out_path, 0, 0, 0, 0)
                SystemCall(AgentSys.SYS_EXIT, 0, 0, 0, 0, 0)
            }
            
            status_ptr = Allocate(8)
            SystemCall(AgentSys.SYS_WAIT4, pid, status_ptr, 0, 0, 0)
            Deallocate(status_ptr, 8)
            
            log_reply = StringConcat("/tmp/hal_agent_", t_id)
            log_reply = StringConcat(log_reply, ".log")
            reply = StringConcat("Worker spawned asynchronously. Result will be parked in Pgmem under key: ", r_key)
            reply = StringConcat(reply, " | Log: ")
            reply = StringConcat(reply, log_reply)
            Agent_SendResult(client_fd, id, reply)
            ReturnValue(1)
        }
        Agent_SendError(client_fd, 0, "unknown method")
        ReturnValue(0)
    }
}

SubRoutine.Main {
    Arena_Init()
    AgentState.schema = Agent_BuildSchema()

    SystemCall(AgentSys.SYS_UNLINK, AgentConst.SOCK_PATH, 0, 0, 0, 0)

    fd = Socket.Create(1, 1)
    IfCondition LessThan(fd, 0) ThenBlock: { Exit(1) }
    bind_rc = Socket.BindUnix(fd, AgentConst.SOCK_PATH)
    IfCondition LessThan(bind_rc, 0) ThenBlock: { Exit(1) }
    Socket.Listen(fd, AgentConst.BACKLOG)
    AgentState.listen_fd = fd

    WhileLoop EqualTo(AgentState.running, 1) {
        client_fd = Socket.Accept(AgentState.listen_fd)
        IfCondition GreaterEqual(client_fd, 0) ThenBlock: {
            done = 0
            WhileLoop EqualTo(done, 0) {
                req = Socket.RecvMsg(client_fd)
                IfCondition EqualTo(req, 0) ThenBlock: { done = 1 }
                IfCondition NotEqual(req, 0) ThenBlock: {
                    IfCondition NotEqual(req, -1) ThenBlock: {
                        Agent_HandleRequest(client_fd, req)
                    }
                }
            }
            Socket.Close(client_fd)
        }
    }
    Exit(0)
}

RunTask(Main)