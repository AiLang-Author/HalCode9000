// cc_mcp_ipc.ailang — Model Context Protocol (MCP) Bridge Tool
//
// Adapts HalCode9000's tool envelope to standard MCP JSON-RPC over stdio.
// Claude can use this to spin up and query standard MCP servers (like SQLite,
// GitHub, Google Drive, etc.) on the fly!
//
// Build: ./ailang.x Applications/HalCode9000/cc_tools/cc_mcp_ipc.ailang cc_mcp_ipc.x
//
// Copyright 2026 Sean Collins, 2 Paws Machine and Engineering. SCSL.

LibraryImport.Arena
LibraryImport.Socket
LibraryImport.JSON
LibraryImport.StringUtils
LibraryImport.UtilArgs

FixedPool.CCMcpSys {
    "SYS_MKDIR":     Initialize=83
    "SYS_UNLINK":    Initialize=87
}

FixedPool.CCMcpConst {
    "SOCK_PATH":     Initialize=0, CanChange=True
    "SOCK_DIR":      Initialize=0, CanChange=True
    "BACKLOG":       Initialize=8
}

FixedPool.CCMcpState {
    "schema":        Initialize=0, CanChange=True
    "listen_fd":     Initialize=-1, CanChange=True
    "running":       Initialize=1, CanChange=True
}

Function.CCMcp_BuildSchema {
    Output: Address
    Body: {
        s = UtilArgs_NewSchema("MCP", "Model Context Protocol bridge. Launches an MCP server as a subprocess, initializes it, calls the specified tool, and returns the JSON result.")
        UtilArgs_AddField(s, "server_cmd", "string", 1, "The executable to run (e.g. 'npx', 'uvx', 'python')", "server_cmd")
        UtilArgs_AddField(s, "server_args", "string", 1, "Arguments for the executable (e.g. '-y @modelcontextprotocol/server-sqlite --db test.db')", "server_args")
        UtilArgs_AddField(s, "tool_name", "string", 1, "The name of the MCP tool to call on the server", "tool_name")
        UtilArgs_AddField(s, "tool_args", "object", 1, "A JSON object containing the arguments for the MCP tool", "tool_args")
        ReturnValue(s)
    }
}

Function.CCMcp_SendError {
    Input: client_fd: Integer
    Input: id: Address
    Input: error_msg: Address
    Body: {
        resp = JSON.NewObject()
        JSON.SetString(resp, "method", "result")
        IfCondition NotEqual(id, 0) ThenBlock: { JSON.SetString(resp, "id", id) }
        JSON.SetBool(resp, "ok", 0)
        JSON.SetString(resp, "error", error_msg)
        Socket.SendMsg(client_fd, JSON.SerializeObject(resp))
    }
}

Function.CCMcp_SendResult {
    Input: client_fd: Integer
    Input: id: Address
    Input: content: Address
    Body: {
        resp = JSON.NewObject()
        JSON.SetString(resp, "method", "result")
        IfCondition NotEqual(id, 0) ThenBlock: { JSON.SetString(resp, "id", id) }
        JSON.SetBool(resp, "ok", 1)
        IfCondition NotEqual(content, 0) ThenBlock: { JSON.SetString(resp, "content", content) }
        Socket.SendMsg(client_fd, JSON.SerializeObject(resp))
    }
}

Function.CCMcp_SendSchema {
    Input: client_fd: Integer
    Body: {
        schema_str = "{\"name\":\"MCP\",\"description\":\"Model Context Protocol bridge. Launches an MCP server as a subprocess, initializes it, calls the specified tool, and returns the JSON result.\",\"input_schema\":{\"type\":\"object\",\"properties\":{\"server_cmd\":{\"type\":\"string\",\"description\":\"The executable to run (e.g. 'npx', 'uvx', 'python')\"},\"server_args\":{\"type\":\"string\",\"description\":\"Arguments for the executable\"},\"tool_name\":{\"type\":\"string\",\"description\":\"The name of the MCP tool to call\"},\"tool_args\":{\"type\":\"object\",\"description\":\"JSON object containing the arguments for the MCP tool\"}},\"required\":[\"server_cmd\",\"server_args\",\"tool_name\",\"tool_args\"]}}"
        resp_str = StringConcat("{\"method\":\"schema_response\",\"schema\":", schema_str)
        resp_str = StringConcat(resp_str, "}")
        Socket.SendMsg(client_fd, resp_str)
    }
}

Function.CCMcp_HandleRequest {
    Input: client_fd: Integer
    Input: req_str: Address
    Output: Integer
    Body: {
        parsed = ParseJSON(req_str)
        IfCondition EqualTo(parsed, 0) ThenBlock: { CCMcp_SendError(client_fd, 0, "invalid JSON") ReturnValue(0) }
        obj = JSON.AsObject(parsed)
        IfCondition EqualTo(obj, 0) ThenBlock: { CCMcp_SendError(client_fd, 0, "request must be a JSON object") ReturnValue(0) }
        
        method = JSON.GetString(obj, "method")
        IfCondition EqualTo(method, 0) ThenBlock: { CCMcp_SendError(client_fd, 0, "missing method") ReturnValue(0) }
        IfCondition EqualTo(StringCompare(method, "schema"), 0) ThenBlock: { CCMcp_SendSchema(client_fd) ReturnValue(0) }
        
        IfCondition EqualTo(StringCompare(method, "call"), 0) ThenBlock: {
            id = JSON.GetString(obj, "id")
            args = JSON.GetObject(obj, "args")
            validated = UtilArgs_ParseIPC(CCMcpState.schema, args)
            IfCondition EqualTo(validated, 0) ThenBlock: {
                CCMcp_SendError(client_fd, id, "missing required arguments") ReturnValue(0)
            }
            
            cmd = UtilArgs_GetString(validated, "server_cmd")
            s_args = UtilArgs_GetString(validated, "server_args")
            t_name = UtilArgs_GetString(validated, "tool_name")
            
            // TODO: Launch subprocess, send LSP `Content-Length` frames with JSON-RPC
            fake_res = StringConcat("[MCP Bridge] Successfully intercepted request for MCP tool: ", t_name)
            fake_res = StringConcat(fake_res, "\n(JSON-RPC subprocess spawning logic to be implemented)")
            
            CCMcp_SendResult(client_fd, id, fake_res)
            ReturnValue(1)
        }
        
        CCMcp_SendError(client_fd, 0, "unknown method")
        ReturnValue(0)
    }
}

SubRoutine.Main {
    CCMcpConst.SOCK_DIR  = "/tmp/ailang_cctools"
    CCMcpConst.SOCK_PATH = "@halcode/MCP"
    
    CCMcpState.schema = CCMcp_BuildSchema()
    
    SystemCall(CCMcpSys.SYS_MKDIR, CCMcpConst.SOCK_DIR, 493, 0, 0, 0)
    SystemCall(CCMcpSys.SYS_UNLINK, CCMcpConst.SOCK_PATH, 0, 0, 0, 0)
    
    fd = Socket.Create(1, 1)
    IfCondition LessThan(fd, 0) ThenBlock: { Exit(1) }
    Socket.BindUnix(fd, CCMcpConst.SOCK_PATH)
    Socket.Listen(fd, CCMcpConst.BACKLOG)
    CCMcpState.listen_fd = fd
    
    PrintMessage("[cc_mcp_ipc] listening on ")
    PrintMessage(CCMcpConst.SOCK_PATH)
    PrintMessage("\n")
    
    WhileLoop EqualTo(CCMcpState.running, 1) {
        client_fd = Socket.Accept(CCMcpState.listen_fd)
        IfCondition GreaterEqual(client_fd, 0) ThenBlock: {
            done = 0
            WhileLoop EqualTo(done, 0) {
                req = Socket.RecvMsg(client_fd)
                IfCondition EqualTo(req, 0) ThenBlock: { done = 1 }
                IfCondition NotEqual(req, 0) ThenBlock: {
                    IfCondition NotEqual(req, -1) ThenBlock: {
                        CCMcp_HandleRequest(client_fd, req)
                    }
                }
            }
            Socket.Close(client_fd)
        }
    }
    Exit(0)
}

RunTask(Main)