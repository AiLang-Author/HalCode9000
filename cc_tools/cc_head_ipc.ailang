// cc_head_ipc.ailang — Claude Code Head tool, IPC service.
//
// Returns the first N lines of a file. The model uses this constantly to
// peek at sources without dragging the full file through the context window.
//
// Schema: path (required), lines (int, default 10).
// Envelope identical to cc_read_ipc.
//
// Build: ./ailang.x Applications/ClaudeCode/cc_tools/cc_head_ipc.ailang cc_head_ipc.x
// Run:   ./cc_head_ipc.x   (binds /tmp/ailang_cctools/Head.sock)
//
// Copyright 2026 Sean Collins, 2 Paws Machine and Engineering. SCSL.

LibraryImport.Arena
LibraryImport.Socket
LibraryImport.JSON
LibraryImport.StringUtils
LibraryImport.UtilArgs

FixedPool.CCHeadSys {
    "SYS_READ":      Initialize=0
    "SYS_OPEN":      Initialize=2
    "SYS_CLOSE":     Initialize=3
    "SYS_MKDIR":     Initialize=83
    "SYS_UNLINK":    Initialize=87
}

FixedPool.CCHeadConst {
    "SOCK_PATH":     Initialize=0, CanChange=True
    "SOCK_DIR":      Initialize=0, CanChange=True
    "MAX_OUTPUT":    Initialize=50000
    "READ_CHUNK":    Initialize=4096
    "BACKLOG":       Initialize=8
}

FixedPool.CCHeadState {
    "schema":        Initialize=0, CanChange=True
    "listen_fd":     Initialize=-1, CanChange=True
    "running":       Initialize=1, CanChange=True
}

Function.CCHead_BuildSchema {
    Output: Address
    Body: {
        s = UtilArgs_NewSchema("Head", "Read the first N lines of a file")
        UtilArgs_AddField(s, "path", "path", 1, "Absolute path to the file", "path")
        UtilArgs_AddField(s, "lines", "int", 0, "Number of lines to return (default 10)", "lines")
        UtilArgs_SetDefault(s, "lines", "10")
        ReturnValue(s)
    }
}

Function.CCHead_DoRead {
    Input: args: Address
    Input: out_truncated_ptr: Address
    Input: err_buf: Address
    Output: Address
    Body: {
        path = UtilArgs_GetString(args, "path")
        lines_want = UtilArgs_GetInt(args, "lines")
        IfCondition LessEqual(lines_want, 0) ThenBlock: { lines_want = 10 }
        StoreValue(out_truncated_ptr, 0, "dword")

        IfCondition EqualTo(path, 0) ThenBlock: {
            msg = "missing path"
            i = 0
            WhileLoop LessThan(i, StringLength(msg)) {
                SetByte(err_buf, i, GetByte(msg, i))
                i = Add(i, 1)
            }
            SetByte(err_buf, StringLength(msg), 0)
            ReturnValue(0)
        }

        fd = SystemCall(CCHeadSys.SYS_OPEN, path, 0, 0, 0, 0)
        IfCondition LessThan(fd, 0) ThenBlock: {
            prefix = "open failed: "
            i = 0
            WhileLoop LessThan(i, StringLength(prefix)) {
                SetByte(err_buf, i, GetByte(prefix, i))
                i = Add(i, 1)
            }
            j = 0
            WhileLoop LessThan(j, StringLength(path)) {
                SetByte(err_buf, Add(i, j), GetByte(path, j))
                j = Add(j, 1)
            }
            SetByte(err_buf, Add(i, j), 0)
            ReturnValue(0)
        }

        out = Allocate(Add(CCHeadConst.MAX_OUTPUT, 1))
        out_used = 0
        lines_seen = 0
        chunk = Allocate(CCHeadConst.READ_CHUNK)

        WhileLoop LessThan(lines_seen, lines_want) {
            n = SystemCall(CCHeadSys.SYS_READ, fd, chunk, CCHeadConst.READ_CHUNK, 0, 0)
            IfCondition LessEqual(n, 0) ThenBlock: { BreakLoop }
            i = 0
            WhileLoop LessThan(i, n) {
                IfCondition GreaterEqual(out_used, CCHeadConst.MAX_OUTPUT) ThenBlock: {
                    StoreValue(out_truncated_ptr, 1, "dword")
                    BreakLoop
                }
                ch = GetByte(chunk, i)
                SetByte(out, out_used, ch)
                out_used = Add(out_used, 1)
                IfCondition EqualTo(ch, 10) ThenBlock: {
                    lines_seen = Add(lines_seen, 1)
                    IfCondition GreaterEqual(lines_seen, lines_want) ThenBlock: { BreakLoop }
                }
                i = Add(i, 1)
            }
        }

        SetByte(out, out_used, 0)
        Deallocate(chunk, CCHeadConst.READ_CHUNK)
        SystemCall(CCHeadSys.SYS_CLOSE, fd, 0, 0, 0, 0)
        ReturnValue(out)
    }
}

Function.CCHead_SendError {
    Input: client_fd: Integer
    Input: id: Address
    Input: error_msg: Address
    Body: {
        resp = JSON.NewObject()
        JSON.SetString(resp, "method", "result")
        IfCondition NotEqual(id, 0) ThenBlock: { JSON.SetString(resp, "id", id) }
        JSON.SetBool(resp, "ok", 0)
        JSON.SetString(resp, "error", error_msg)
        Socket.SendMsg(client_fd, JSON.SerializeObject(resp))
    }
}

Function.CCHead_SendResult {
    Input: client_fd: Integer
    Input: id: Address
    Input: content: Address
    Input: truncated: Integer
    Body: {
        resp = JSON.NewObject()
        JSON.SetString(resp, "method", "result")
        IfCondition NotEqual(id, 0) ThenBlock: { JSON.SetString(resp, "id", id) }
        JSON.SetBool(resp, "ok", 1)
        IfCondition NotEqual(content, 0) ThenBlock: { JSON.SetString(resp, "content", content) }
        IfCondition EqualTo(truncated, 1) ThenBlock: { JSON.SetBool(resp, "truncated", 1) }
        Socket.SendMsg(client_fd, JSON.SerializeObject(resp))
    }
}

Function.CCHead_SendSchema {
    Input: client_fd: Integer
    Body: {
        schema_str = UtilArgs_ExportToolSchema(CCHeadState.schema)
        parsed = ParseJSON(schema_str)
        schema_obj = JSON.AsObject(parsed)
        resp = JSON.NewObject()
        JSON.SetString(resp, "method", "schema_response")
        IfCondition NotEqual(schema_obj, 0) ThenBlock: { JSON.SetObject(resp, "schema", schema_obj) }
        Socket.SendMsg(client_fd, JSON.SerializeObject(resp))
    }
}

Function.CCHead_HandleRequest {
    Input: client_fd: Integer
    Input: req_str: Address
    Body: {
        parsed = ParseJSON(req_str)
        IfCondition EqualTo(parsed, 0) ThenBlock: {
            CCHead_SendError(client_fd, 0, "invalid JSON")
            ReturnValue(0)
        }
        obj = JSON.AsObject(parsed)
        IfCondition EqualTo(obj, 0) ThenBlock: {
            CCHead_SendError(client_fd, 0, "request must be a JSON object")
            ReturnValue(0)
        }
        method = JSON.GetString(obj, "method")
        IfCondition EqualTo(method, 0) ThenBlock: {
            CCHead_SendError(client_fd, 0, "missing method")
            ReturnValue(0)
        }
        IfCondition EqualTo(StringCompare(method, "schema"), 0) ThenBlock: {
            CCHead_SendSchema(client_fd)
            ReturnValue(0)
        }
        IfCondition EqualTo(StringCompare(method, "call"), 0) ThenBlock: {
            id = JSON.GetString(obj, "id")
            args = JSON.GetObject(obj, "args")
            validated = UtilArgs_ParseIPC(CCHeadState.schema, args)
            IfCondition EqualTo(validated, 0) ThenBlock: {
                CCHead_SendError(client_fd, id, "missing required argument 'path'")
                ReturnValue(0)
            }
            err_buf = Allocate(256)
            SetByte(err_buf, 0, 0)
            trunc_holder = Allocate(8)
            StoreValue(trunc_holder, 0, "dword")
            content = CCHead_DoRead(validated, trunc_holder, err_buf)
            truncated = Dereference(trunc_holder, "dword")
            Deallocate(trunc_holder, 8)
            IfCondition EqualTo(content, 0) ThenBlock: {
                CCHead_SendError(client_fd, id, err_buf)
            } ElseBlock: {
                IfCondition EqualTo(truncated, 1) ThenBlock: {
                    marker = "\n[truncated: hit MAX_OUTPUT]"
                    final = StringConcat(content, marker)
                    CCHead_SendResult(client_fd, id, final, 1)
                } ElseBlock: {
                    CCHead_SendResult(client_fd, id, content, 0)
                }
            }
            Deallocate(err_buf, 256)
            ReturnValue(0)
        }
        CCHead_SendError(client_fd, 0, "unknown method")
    }
}

SubRoutine.Main {
    CCHeadConst.SOCK_DIR  = "/tmp/ailang_cctools"
    CCHeadConst.SOCK_PATH = "@halcode/Head"
    CCHeadState.schema = CCHead_BuildSchema()

    SystemCall(CCHeadSys.SYS_MKDIR, CCHeadConst.SOCK_DIR, 493, 0, 0, 0)
    SystemCall(CCHeadSys.SYS_UNLINK, CCHeadConst.SOCK_PATH, 0, 0, 0, 0)

    fd = Socket.Create(1, 1)
    IfCondition LessThan(fd, 0) ThenBlock: { Exit(1) }
    Socket.BindUnix(fd, CCHeadConst.SOCK_PATH)
    Socket.Listen(fd, CCHeadConst.BACKLOG)
    CCHeadState.listen_fd = fd

    PrintMessage("[cc_head_ipc] listening on ")
    PrintMessage(CCHeadConst.SOCK_PATH)
    PrintMessage("\n")

    WhileLoop EqualTo(CCHeadState.running, 1) {
        client_fd = Socket.Accept(CCHeadState.listen_fd)
        IfCondition GreaterEqual(client_fd, 0) ThenBlock: {
            done = 0
            WhileLoop EqualTo(done, 0) {
                req = Socket.RecvMsg(client_fd)
                IfCondition EqualTo(req, 0) ThenBlock: { done = 1 }
                IfCondition NotEqual(req, 0) ThenBlock: {
                    IfCondition NotEqual(req, -1) ThenBlock: {
                        CCHead_HandleRequest(client_fd, req)
                    }
                }
            }
            Socket.Close(client_fd)
        }
    }
    Exit(0)
}

RunTask(Main)
