// cc_bash_ipc.ailang — Claude Code Bash tool, IPC service.
//
// Runs a shell command via /bin/sh -c, captures combined stdout+stderr,
// returns exit code + output. The model's universal escape hatch — when
// nothing else fits, Bash does.
//
// Schema: command (required string), timeout_secs (int, default 0 = no timeout).
// Output format:
//   exit=<N>
//   <combined output>
//
// stderr is merged via the shell's `2>&1` so we only need one pipe.
// For Phase 1, timeout_secs is accepted but not enforced (always blocking
// wait). Add SIGALRM-based timeout in Phase 2.
//
// Build: ./ailang.x Applications/ClaudeCode/cc_tools/cc_bash_ipc.ailang cc_bash_ipc.x
// Run:   ./cc_bash_ipc.x   (binds /tmp/ailang_cctools/Bash.sock)
//
// Copyright 2026 Sean Collins, 2 Paws Machine and Engineering. SCSL.

LibraryImport.Arena
LibraryImport.Socket
LibraryImport.JSON
LibraryImport.StringUtils
LibraryImport.UtilArgs

FixedPool.CCBashSys {
    "SYS_READ":      Initialize=0
    "SYS_WRITE":     Initialize=1
    "SYS_OPEN":      Initialize=2
    "SYS_CLOSE":     Initialize=3
    "SYS_POLL":      Initialize=7
    "SYS_PIPE":      Initialize=22
    "SYS_DUP2":      Initialize=33
    "SYS_FORK":      Initialize=57
    "SYS_EXECVE":    Initialize=59
    "SYS_EXIT":      Initialize=60
    "SYS_WAIT4":     Initialize=61
    "SYS_KILL":      Initialize=62
    "SYS_MKDIR":     Initialize=83
    "SYS_UNLINK":    Initialize=87
    "SYS_TIME":      Initialize=201
    "POLLIN":        Initialize=1
    "O_RDONLY":      Initialize=0
    "SIGKILL":       Initialize=9
    "WNOHANG":       Initialize=1
    "DEFAULT_TIMEOUT": Initialize=30
}

FixedPool.CCBashConst {
    "SOCK_PATH":     Initialize=0, CanChange=True
    "SOCK_DIR":      Initialize=0, CanChange=True
    "MAX_OUTPUT":    Initialize=50000
    "READ_CHUNK":    Initialize=4096
    "BACKLOG":       Initialize=8
}

FixedPool.CCBashState {
    "schema":        Initialize=0, CanChange=True
    "listen_fd":     Initialize=-1, CanChange=True
    "running":       Initialize=1, CanChange=True
}

Function.CCBash_BuildSchema {
    Output: Address
    Body: {
        s = UtilArgs_NewSchema("Bash", "Run a shell command via /bin/sh and return its combined stdout+stderr with exit code")
        UtilArgs_AddField(s, "command", "string", 1, "Shell command to execute (interpreted by /bin/sh -c)", "command")
        UtilArgs_AddField(s, "timeout_secs", "int", 0, "Wall-clock timeout in seconds (0 = no timeout)", "timeout_secs")
        UtilArgs_SetDefault(s, "timeout_secs", "0")
        ReturnValue(s)
    }
}

// Read /proc/self/environ and build a char** envp array for execve.
// Returns the pointer array (caller frees with Deallocate(envp, 8200)) and
// stores the raw env data buffer in *env_data_out (caller frees 65536).
// Returns 0 on failure — caller should still pass 0 to execve rather than crash.
Function.CCBash_GetEnvp {
    Input:  env_data_out: Address
    Output: Address
    Body: {
        StoreValue(env_data_out, 0)
        fd = SystemCall(CCBashSys.SYS_OPEN, "/proc/self/environ", CCBashSys.O_RDONLY, 0, 0, 0)
        IfCondition LessThan(fd, 0) ThenBlock: { ReturnValue(0) }

        env_max  = 65536
        env_data = Allocate(env_max)
        n = SystemCall(CCBashSys.SYS_READ, fd, env_data, env_max, 0, 0)
        SystemCall(CCBashSys.SYS_CLOSE, fd, 0, 0, 0, 0)

        IfCondition LessEqual(n, 0) ThenBlock: {
            Deallocate(env_data, env_max)
            ReturnValue(0)
        }

        // Walk null-separated entries; build char** pointer array (max 1025 entries).
        envp_max = 8200
        envp     = Allocate(envp_max)
        pos = 0
        idx = 0
        WhileLoop LessThan(pos, n) {
            start      = pos
            end_found  = 0
            WhileLoop LessThan(pos, n) {
                IfCondition EqualTo(GetByte(env_data, pos), 0) ThenBlock: {
                    end_found = 1
                    pos = Add(pos, 1)
                    BreakLoop
                }
                pos = Add(pos, 1)
            }
            IfCondition EqualTo(end_found, 1) ThenBlock: {
                StoreValue(Add(envp, Multiply(idx, 8)), Add(env_data, start))
                idx = Add(idx, 1)
            }
        }
        StoreValue(Add(envp, Multiply(idx, 8)), 0)

        StoreValue(env_data_out, env_data)
        ReturnValue(envp)
    }
}

// Fork+exec /bin/sh -c "<cmd>" with stdout+stderr -> pipe.
// timeout_secs: wall-clock limit; 0 means use DEFAULT_TIMEOUT (30s).
// Returns allocated string "exit=N\n<output>" on success, 0 on internal failure.
Function.CCBash_Run {
    Input: cmd:              Address
    Input: timeout_secs:     Integer
    Input: out_truncated_ptr: Address
    Output: Address
    Body: {
        StoreValue(out_truncated_ptr, 0, "dword")
        IfCondition EqualTo(cmd, 0) ThenBlock: { ReturnValue(0) }

        // Clamp timeout: 0 → default, cap at 55s so IPCDispatch's 60s fence always wins.
        effective_timeout = timeout_secs
        IfCondition LessEqual(effective_timeout, 0) ThenBlock: {
            effective_timeout = CCBashSys.DEFAULT_TIMEOUT
        }
        IfCondition GreaterThan(effective_timeout, 55) ThenBlock: {
            effective_timeout = 55
        }
        deadline = Add(SystemCall(CCBashSys.SYS_TIME, 0, 0, 0, 0, 0), effective_timeout)

        // Build argv: ["/bin/sh", "-c", cmd, NULL]
        argv = Allocate(32)
        StoreValue(Add(argv, 0),  "/bin/sh")
        StoreValue(Add(argv, 8),  "-c")
        StoreValue(Add(argv, 16), cmd)
        StoreValue(Add(argv, 24), 0)

        // Capture current environment for the child.
        env_data_holder = Allocate(8)
        StoreValue(env_data_holder, 0)
        envp     = CCBash_GetEnvp(env_data_holder)
        env_data = Dereference(env_data_holder)
        Deallocate(env_data_holder, 8)

        pf = Allocate(8)
        pr = SystemCall(CCBashSys.SYS_PIPE, pf, 0, 0, 0, 0)
        IfCondition LessThan(pr, 0) ThenBlock: {
            Deallocate(pf, 8)
            Deallocate(argv, 32)
            IfCondition NotEqual(envp,     0) ThenBlock: { Deallocate(envp,     8200) }
            IfCondition NotEqual(env_data, 0) ThenBlock: { Deallocate(env_data, 65536) }
            ReturnValue(0)
        }
        pipe_r = Dereference(pf, "dword")
        pipe_w = Dereference(Add(pf, 4), "dword")
        Deallocate(pf, 8)

        pid = SystemCall(CCBashSys.SYS_FORK, 0, 0, 0, 0, 0)
        IfCondition LessThan(pid, 0) ThenBlock: {
            SystemCall(CCBashSys.SYS_CLOSE, pipe_r, 0, 0, 0, 0)
            SystemCall(CCBashSys.SYS_CLOSE, pipe_w, 0, 0, 0, 0)
            Deallocate(argv, 32)
            IfCondition NotEqual(envp,     0) ThenBlock: { Deallocate(envp,     8200) }
            IfCondition NotEqual(env_data, 0) ThenBlock: { Deallocate(env_data, 65536) }
            ReturnValue(0)
        }

        IfCondition EqualTo(pid, 0) ThenBlock: {
            // Child: redirect stdout+stderr to pipe, exec shell.
            SystemCall(CCBashSys.SYS_CLOSE, pipe_r, 0, 0, 0, 0)
            SystemCall(CCBashSys.SYS_DUP2,  pipe_w, 1, 0, 0, 0)
            SystemCall(CCBashSys.SYS_DUP2,  pipe_w, 2, 0, 0, 0)
            SystemCall(CCBashSys.SYS_CLOSE, pipe_w, 0, 0, 0, 0)
            SystemCall(CCBashSys.SYS_EXECVE, "/bin/sh", argv, envp)
            SystemCall(CCBashSys.SYS_EXIT, 127, 0, 0, 0, 0)
        }

        // Parent: close write end.
        SystemCall(CCBashSys.SYS_CLOSE, pipe_w, 0, 0, 0, 0)
        Deallocate(argv, 32)
        IfCondition NotEqual(envp,     0) ThenBlock: { Deallocate(envp,     8200) }
        IfCondition NotEqual(env_data, 0) ThenBlock: { Deallocate(env_data, 65536) }

        // Drain stdout+stderr via poll so we honor the deadline.
        // pollfd: fd(4) events(2) revents(2) = 8 bytes.
        pfd   = Allocate(8)
        out   = Allocate(Add(CCBashConst.MAX_OUTPUT, 64))
        body_off = 32
        used  = 0
        chunk = Allocate(CCBashConst.READ_CHUNK)
        timed_out = 0

        WhileLoop 1 {
            // Deadline check first.
            now = SystemCall(CCBashSys.SYS_TIME, 0, 0, 0, 0, 0)
            IfCondition GreaterEqual(now, deadline) ThenBlock: {
                timed_out = 1
                BreakLoop
            }

            free_room = Subtract(CCBashConst.MAX_OUTPUT, used)
            IfCondition LessEqual(free_room, 0) ThenBlock: {
                StoreValue(out_truncated_ptr, 1, "dword")
                // Drain remaining within remaining time so child doesn't block on write.
                WhileLoop 1 {
                    now2 = SystemCall(CCBashSys.SYS_TIME, 0, 0, 0, 0, 0)
                    IfCondition GreaterEqual(now2, deadline) ThenBlock: {
                        timed_out = 1
                        BreakLoop
                    }
                    remain_ms3 = Multiply(Subtract(deadline, now2), 1000)
                    IfCondition GreaterThan(remain_ms3, 1000) ThenBlock: { remain_ms3 = 1000 }
                    StoreValue(pfd, pipe_r, "dword")
                    SetByte(pfd, 4, CCBashSys.POLLIN)
                    SetByte(pfd, 5, 0)
                    SetByte(pfd, 6, 0)
                    SetByte(pfd, 7, 0)
                    pr3 = SystemCall(CCBashSys.SYS_POLL, pfd, 1, remain_ms3, 0, 0)
                    IfCondition LessEqual(pr3, 0) ThenBlock: { BreakLoop }
                    dn = SystemCall(CCBashSys.SYS_READ, pipe_r, chunk, CCBashConst.READ_CHUNK, 0, 0)
                    IfCondition LessEqual(dn, 0) ThenBlock: { BreakLoop }
                }
                BreakLoop
            }

            // Poll with up to 1s slices so deadline is checked each iteration.
            remain_ms = Multiply(Subtract(deadline, now), 1000)
            IfCondition GreaterThan(remain_ms, 1000) ThenBlock: { remain_ms = 1000 }
            StoreValue(pfd, pipe_r, "dword")
            SetByte(pfd, 4, CCBashSys.POLLIN)
            SetByte(pfd, 5, 0)
            SetByte(pfd, 6, 0)
            SetByte(pfd, 7, 0)
            poll_r = SystemCall(CCBashSys.SYS_POLL, pfd, 1, remain_ms, 0, 0)

            IfCondition EqualTo(poll_r, 0) ThenBlock: {
                // Poll slice expired, loop back to check deadline.
            }
            IfCondition LessThan(poll_r, 0) ThenBlock: { BreakLoop }
            IfCondition GreaterThan(poll_r, 0) ThenBlock: {
                want = CCBashConst.READ_CHUNK
                IfCondition GreaterThan(want, free_room) ThenBlock: { want = free_room }
                n = SystemCall(CCBashSys.SYS_READ, pipe_r, chunk, want, 0, 0)
                IfCondition LessEqual(n, 0) ThenBlock: { BreakLoop }
                i = 0
                WhileLoop LessThan(i, n) {
                    SetByte(out, Add(body_off, Add(used, i)), GetByte(chunk, i))
                    i = Add(i, 1)
                }
                used = Add(used, n)
            }
        }

        Deallocate(pfd, 8)
        Deallocate(chunk, CCBashConst.READ_CHUNK)
        SystemCall(CCBashSys.SYS_CLOSE, pipe_r, 0, 0, 0, 0)

        // Kill child if we hit the deadline.
        IfCondition EqualTo(timed_out, 1) ThenBlock: {
            SystemCall(CCBashSys.SYS_KILL, pid, CCBashSys.SIGKILL, 0, 0, 0)
            timeout_note = "\n[timed out]"
            tn_len = StringLength(timeout_note)
            avail = Subtract(CCBashConst.MAX_OUTPUT, used)
            IfCondition GreaterThan(tn_len, avail) ThenBlock: { tn_len = avail }
            tn = 0
            WhileLoop LessThan(tn, tn_len) {
                SetByte(out, Add(body_off, Add(used, tn)), GetByte(timeout_note, tn))
                tn = Add(tn, 1)
            }
            used = Add(used, tn_len)
        }

        // Reap child with WNOHANG + retry loop so a D-state child (e.g. find
        // stuck in WSL2 NTFS or /proc) never blocks us permanently.
        // If the child still hasn't exited after 10 x 100ms we leave it and
        // treat the exit code as 137 (SIGKILL convention).
        status_buf = Allocate(8)
        StoreValue(status_buf, 0)
        raw_status = 0
        wi = 0
        WhileLoop LessThan(wi, 10) {
            wr = SystemCall(CCBashSys.SYS_WAIT4, pid, status_buf, CCBashSys.WNOHANG, 0, 0)
            IfCondition NotEqual(wr, 0) ThenBlock: {
                raw_status = Dereference(status_buf, "dword")
                wi = 10
            } ElseBlock: {
                ts = Allocate(16)
                StoreValue(ts, 0)
                StoreValue(Add(ts, 8), 100000000)
                SystemCall(35, ts, 0, 0, 0, 0)
                Deallocate(ts, 16)
                wi = Add(wi, 1)
            }
        }
        Deallocate(status_buf, 8)
        // POSIX: bits 8-15 = exit code when WIFEXITED, bits 0-7 = signal number.
        exit_code = BitwiseAnd(RightShift(raw_status, 8), 255)

        // Build "exit=N\n" prefix in-place
        prefix_buf = Allocate(32)
        prefix_str = "exit="
        plen = StringLength(prefix_str)
        pi = 0
        WhileLoop LessThan(pi, plen) {
            SetByte(prefix_buf, pi, GetByte(prefix_str, pi))
            pi = Add(pi, 1)
        }
        // Encode exit code as decimal (0-255)
        digits = NumberToString(exit_code)
        dlen = StringLength(digits)
        di = 0
        WhileLoop LessThan(di, dlen) {
            SetByte(prefix_buf, Add(plen, di), GetByte(digits, di))
            di = Add(di, 1)
        }
        SetByte(prefix_buf, Add(plen, dlen), 10)  // newline
        prefix_total = Add(plen, Add(dlen, 1))

        // Final layout: prefix + body
        final_len = Add(prefix_total, used)
        final = Allocate(Add(final_len, 1))
        k = 0
        WhileLoop LessThan(k, prefix_total) {
            SetByte(final, k, GetByte(prefix_buf, k))
            k = Add(k, 1)
        }
        m = 0
        WhileLoop LessThan(m, used) {
            SetByte(final, Add(prefix_total, m), GetByte(out, Add(body_off, m)))
            m = Add(m, 1)
        }
        SetByte(final, final_len, 0)
        Deallocate(prefix_buf, 32)
        Deallocate(out, Add(CCBashConst.MAX_OUTPUT, 64))
        ReturnValue(final)
    }
}

// Returns 1 if c is the first byte after "find /" and identifies a dangerous root:
// end/space/tab = bare "/", 'm'=/mnt, 'p'=/proc, 's'=/sys
Function.CCBash_IsDangerousRoot {
    Input: c: Integer
    Output: Integer
    Body: {
        IfCondition EqualTo(c,   0) ThenBlock: { ReturnValue(1) }
        IfCondition EqualTo(c,  32) ThenBlock: { ReturnValue(1) }
        IfCondition EqualTo(c,   9) ThenBlock: { ReturnValue(1) }
        IfCondition EqualTo(c, 109) ThenBlock: { ReturnValue(1) }  // 'm' /mnt
        IfCondition EqualTo(c, 112) ThenBlock: { ReturnValue(1) }  // 'p' /proc
        IfCondition EqualTo(c, 115) ThenBlock: { ReturnValue(1) }  // 's' /sys
        ReturnValue(0)
    }
}

// Returns 1 if cmd contains "find " or "find\t" followed by a dangerous root.
// Allows find /home, /tmp, /var, etc. Only blocks /, /mnt, /proc, /sys.
Function.CCBash_IsDangerousFind {
    Input: cmd: Address
    Output: Integer
    Body: {
        IfCondition EqualTo(cmd, 0) ThenBlock: { ReturnValue(0) }
        len = StringLength(cmd)
        IfCondition LessThan(len, 6) ThenBlock: { ReturnValue(0) }
        i = 0
        limit = Subtract(len, 5)
        WhileLoop LessEqual(i, limit) {
            IfCondition EqualTo(GetByte(cmd, i), 102) ThenBlock: {
                IfCondition EqualTo(GetByte(cmd, Add(i, 1)), 105) ThenBlock: {
                    IfCondition EqualTo(GetByte(cmd, Add(i, 2)), 110) ThenBlock: {
                        IfCondition EqualTo(GetByte(cmd, Add(i, 3)), 100) ThenBlock: {
                            sep   = GetByte(cmd, Add(i, 4))
                            slash = GetByte(cmd, Add(i, 5))
                            IfCondition EqualTo(slash, 47) ThenBlock: {
                                c6    = 0
                                c6pos = Add(i, 6)
                                IfCondition LessThan(c6pos, len) ThenBlock: {
                                    c6 = GetByte(cmd, c6pos)
                                }
                                IfCondition EqualTo(sep, 32) ThenBlock: {
                                    IfCondition EqualTo(CCBash_IsDangerousRoot(c6), 1) ThenBlock: {
                                        ReturnValue(1)
                                    }
                                }
                                IfCondition EqualTo(sep, 9) ThenBlock: {
                                    IfCondition EqualTo(CCBash_IsDangerousRoot(c6), 1) ThenBlock: {
                                        ReturnValue(1)
                                    }
                                }
                            }
                        }
                    }
                }
            }
            i = Add(i, 1)
        }
        ReturnValue(0)
    }
}

// Returns 1 if c (char after '/') indicates a protected system path for rm purposes.
// Covers bare root, /etc, /bin, /sbin, /usr, /lib, /proc, /sys, /dev, /boot, /root, /*.
Function.CCBash_IsRmSystemRoot {
    Input: c: Integer
    Output: Integer
    Body: {
        IfCondition EqualTo(c,   0) ThenBlock: { ReturnValue(1) }   // bare /
        IfCondition EqualTo(c,  32) ThenBlock: { ReturnValue(1) }   // / (space)
        IfCondition EqualTo(c,   9) ThenBlock: { ReturnValue(1) }   // /\t
        IfCondition EqualTo(c,  42) ThenBlock: { ReturnValue(1) }   // /*
        IfCondition EqualTo(c, 101) ThenBlock: { ReturnValue(1) }   // /e → /etc
        IfCondition EqualTo(c,  98) ThenBlock: { ReturnValue(1) }   // /b → /bin /boot
        IfCondition EqualTo(c, 115) ThenBlock: { ReturnValue(1) }   // /s → /sys /sbin
        IfCondition EqualTo(c, 117) ThenBlock: { ReturnValue(1) }   // /u → /usr
        IfCondition EqualTo(c, 108) ThenBlock: { ReturnValue(1) }   // /l → /lib /lib64
        IfCondition EqualTo(c, 112) ThenBlock: { ReturnValue(1) }   // /p → /proc
        IfCondition EqualTo(c, 100) ThenBlock: { ReturnValue(1) }   // /d → /dev
        IfCondition EqualTo(c, 114) ThenBlock: { ReturnValue(1) }   // /r → /root
        IfCondition EqualTo(c, 109) ThenBlock: { ReturnValue(1) }   // /m → /mnt
        ReturnValue(0)
    }
}

// Returns 1 if cmd contains "rm " followed (eventually) by a system path like / /etc /bin etc.
// Scans for "rm " then looks for space-prefixed "/" tokens within the rest of the command.
Function.CCBash_IsDangerousRm {
    Input: cmd: Address
    Output: Integer
    Body: {
        IfCondition EqualTo(cmd, 0) ThenBlock: { ReturnValue(0) }
        len = StringLength(cmd)
        IfCondition LessThan(len, 4) ThenBlock: { ReturnValue(0) }
        i = 0
        limit = Subtract(len, 3)
        WhileLoop LessEqual(i, limit) {
            // Look for "rm" followed by space or tab
            IfCondition EqualTo(GetByte(cmd, i), 114) ThenBlock: {           // 'r'
                IfCondition EqualTo(GetByte(cmd, Add(i, 1)), 109) ThenBlock: { // 'm'
                    sep = GetByte(cmd, Add(i, 2))
                    IfCondition Or(EqualTo(sep, 32), EqualTo(sep, 9)) ThenBlock: {
                        // Scan forward for slash tokens (preceded by space/tab or at start)
                        j = Add(i, 3)
                        WhileLoop LessThan(j, len) {
                            IfCondition EqualTo(GetByte(cmd, j), 47) ThenBlock: {  // '/'
                                before = GetByte(cmd, Subtract(j, 1))
                                IfCondition Or(EqualTo(before, 32), EqualTo(before, 9)) ThenBlock: {
                                    c_after = 0
                                    IfCondition LessThan(Add(j, 1), len) ThenBlock: {
                                        c_after = GetByte(cmd, Add(j, 1))
                                    }
                                    IfCondition EqualTo(CCBash_IsRmSystemRoot(c_after), 1) ThenBlock: {
                                        ReturnValue(1)
                                    }
                                }
                            }
                            j = Add(j, 1)
                        }
                    }
                }
            }
            i = Add(i, 1)
        }
        ReturnValue(0)
    }
}

// Returns 1 if cmd contains a shell output-redirect (> or >>) targeting a system path.
// Catches patterns like: echo x > /etc/passwd, cmd > /bin/evil
Function.CCBash_IsRedirectToSystemPath {
    Input: cmd: Address
    Output: Integer
    Body: {
        IfCondition EqualTo(cmd, 0) ThenBlock: { ReturnValue(0) }
        len = StringLength(cmd)
        IfCondition LessThan(len, 4) ThenBlock: { ReturnValue(0) }
        i = 0
        limit = Subtract(len, 2)
        WhileLoop LessEqual(i, limit) {
            IfCondition EqualTo(GetByte(cmd, i), 62) ThenBlock: {  // '>'
                // Skip second '>' if present (>>)
                j = Add(i, 1)
                IfCondition EqualTo(GetByte(cmd, j), 62) ThenBlock: { j = Add(j, 1) }
                // Skip spaces/tabs after >
                WhileLoop LessThan(j, len) {
                    b = GetByte(cmd, j)
                    IfCondition And(NotEqual(b, 32), NotEqual(b, 9)) ThenBlock: { BreakLoop }
                    j = Add(j, 1)
                }
                // Check if next char is '/'
                IfCondition LessThan(j, len) ThenBlock: {
                    IfCondition EqualTo(GetByte(cmd, j), 47) ThenBlock: {  // '/'
                        c_after = 0
                        IfCondition LessThan(Add(j, 1), len) ThenBlock: {
                            c_after = GetByte(cmd, Add(j, 1))
                        }
                        IfCondition EqualTo(CCBash_IsRmSystemRoot(c_after), 1) ThenBlock: {
                            ReturnValue(1)
                        }
                    }
                }
            }
            i = Add(i, 1)
        }
        ReturnValue(0)
    }
}

// Returns 1 if cmd contains the substring "sudo".
Function.CCBash_ContainsSudo {
    Input: cmd: Address
    Output: Integer
    Body: {
        IfCondition EqualTo(cmd, 0) ThenBlock: { ReturnValue(0) }
        len = StringLength(cmd)
        IfCondition LessThan(len, 4) ThenBlock: { ReturnValue(0) }
        i = 0
        limit = Subtract(len, 4)
        WhileLoop LessEqual(i, limit) {
            IfCondition EqualTo(GetByte(cmd, i), 115) ThenBlock: {           // 's'
                IfCondition EqualTo(GetByte(cmd, Add(i, 1)), 117) ThenBlock: {   // 'u'
                    IfCondition EqualTo(GetByte(cmd, Add(i, 2)), 100) ThenBlock: {   // 'd'
                        IfCondition EqualTo(GetByte(cmd, Add(i, 3)), 111) ThenBlock: {   // 'o'
                            ReturnValue(1)
                        }
                    }
                }
            }
            i = Add(i, 1)
        }
        ReturnValue(0)
    }
}

Function.CCBash_SendError {
    Input: client_fd: Integer
    Input: id: Address
    Input: error_msg: Address
    Body: {
        resp = JSON.NewObject()
        JSON.SetString(resp, "method", "result")
        IfCondition NotEqual(id, 0) ThenBlock: { JSON.SetString(resp, "id", id) }
        JSON.SetBool(resp, "ok", 0)
        JSON.SetString(resp, "error", error_msg)
        Socket.SendMsg(client_fd, JSON.SerializeObject(resp))
    }
}

Function.CCBash_SendResult {
    Input: client_fd: Integer
    Input: id: Address
    Input: content: Address
    Input: truncated: Integer
    Body: {
        resp = JSON.NewObject()
        JSON.SetString(resp, "method", "result")
        IfCondition NotEqual(id, 0) ThenBlock: { JSON.SetString(resp, "id", id) }
        JSON.SetBool(resp, "ok", 1)
        IfCondition NotEqual(content, 0) ThenBlock: { JSON.SetString(resp, "content", content) }
        IfCondition EqualTo(truncated, 1) ThenBlock: { JSON.SetBool(resp, "truncated", 1) }
        Socket.SendMsg(client_fd, JSON.SerializeObject(resp))
    }
}

Function.CCBash_SendSchema {
    Input: client_fd: Integer
    Body: {
        schema_str = UtilArgs_ExportToolSchema(CCBashState.schema)
        parsed = ParseJSON(schema_str)
        schema_obj = JSON.AsObject(parsed)
        resp = JSON.NewObject()
        JSON.SetString(resp, "method", "schema_response")
        IfCondition NotEqual(schema_obj, 0) ThenBlock: { JSON.SetObject(resp, "schema", schema_obj) }
        Socket.SendMsg(client_fd, JSON.SerializeObject(resp))
    }
}

Function.CCBash_HandleRequest {
    Input: client_fd: Integer
    Input: req_str: Address
    Body: {
        parsed = ParseJSON(req_str)
        IfCondition EqualTo(parsed, 0) ThenBlock: {
            CCBash_SendError(client_fd, 0, "invalid JSON")
            ReturnValue(0)
        }
        obj = JSON.AsObject(parsed)
        IfCondition EqualTo(obj, 0) ThenBlock: {
            CCBash_SendError(client_fd, 0, "request must be a JSON object")
            ReturnValue(0)
        }
        method = JSON.GetString(obj, "method")
        IfCondition EqualTo(method, 0) ThenBlock: {
            CCBash_SendError(client_fd, 0, "missing method")
            ReturnValue(0)
        }
        IfCondition EqualTo(StringCompare(method, "schema"), 0) ThenBlock: {
            CCBash_SendSchema(client_fd)
            ReturnValue(0)
        }
        IfCondition EqualTo(StringCompare(method, "call"), 0) ThenBlock: {
            id = JSON.GetString(obj, "id")
            args = JSON.GetObject(obj, "args")
            validated = UtilArgs_ParseIPC(CCBashState.schema, args)
            IfCondition EqualTo(validated, 0) ThenBlock: {
                CCBash_SendError(client_fd, id, "missing required argument 'command'")
                ReturnValue(0)
            }
            cmd          = UtilArgs_GetString(validated, "command")
            IfCondition EqualTo(CCBash_IsDangerousFind(cmd), 1) ThenBlock: {
                CCBash_SendError(client_fd, id, "Blocked: `find` with a filesystem root (/ /mnt /proc /sys) causes permanent hangs on WSL2. Scope find to a specific directory under /home or the project path.")
                ReturnValue(0)
            }
            IfCondition EqualTo(CCBash_ContainsSudo(cmd), 1) ThenBlock: {
                CCBash_SendError(client_fd, id, "Blocked: `sudo` is strictly forbidden. Do not attempt to escalate privileges.")
                ReturnValue(0)
            }
            IfCondition EqualTo(CCBash_IsDangerousRm(cmd), 1) ThenBlock: {
                CCBash_SendError(client_fd, id, "Blocked: `rm` targeting a system directory (/, /etc, /bin, /usr, /lib, /sys, /proc, /dev, /boot, /root, /mnt). Use a scoped path under /tmp or the project directory.")
                ReturnValue(0)
            }
            IfCondition EqualTo(CCBash_IsRedirectToSystemPath(cmd), 1) ThenBlock: {
                CCBash_SendError(client_fd, id, "Blocked: shell output redirect (> or >>) targeting a system path. Writing to OS-critical directories is not allowed.")
                ReturnValue(0)
            }
            timeout_str  = UtilArgs_GetString(validated, "timeout_secs")
            timeout_secs = 0
            IfCondition NotEqual(timeout_str, 0) ThenBlock: {
                timeout_secs = StringToInt(timeout_str)
            }
            trunc_holder = Allocate(8)
            StoreValue(trunc_holder, 0, "dword")
            content = CCBash_Run(cmd, timeout_secs, trunc_holder)
            truncated = Dereference(trunc_holder, "dword")
            Deallocate(trunc_holder, 8)
            IfCondition EqualTo(content, 0) ThenBlock: {
                CCBash_SendError(client_fd, id, "fork/exec failed")
            } ElseBlock: {
                IfCondition EqualTo(truncated, 1) ThenBlock: {
                    marker = "\n[truncated: output exceeded MAX_OUTPUT]"
                    final = StringConcat(content, marker)
                    CCBash_SendResult(client_fd, id, final, 1)
                } ElseBlock: {
                    CCBash_SendResult(client_fd, id, content, 0)
                }
            }
            ReturnValue(0)
        }
        CCBash_SendError(client_fd, 0, "unknown method")
    }
}

SubRoutine.Main {
    CCBashConst.SOCK_DIR  = "/tmp/ailang_cctools"
    CCBashConst.SOCK_PATH = "@halcode/Bash"
    CCBashState.schema = CCBash_BuildSchema()

    SystemCall(CCBashSys.SYS_MKDIR, CCBashConst.SOCK_DIR, 493, 0, 0, 0)
    SystemCall(CCBashSys.SYS_UNLINK, CCBashConst.SOCK_PATH, 0, 0, 0, 0)

    fd = Socket.Create(1, 1)
    IfCondition LessThan(fd, 0) ThenBlock: { Exit(1) }
    Socket.BindUnix(fd, CCBashConst.SOCK_PATH)
    Socket.Listen(fd, CCBashConst.BACKLOG)
    CCBashState.listen_fd = fd

    PrintMessage("[cc_bash_ipc] listening on ")
    PrintMessage(CCBashConst.SOCK_PATH)
    PrintMessage("\n")

    WhileLoop EqualTo(CCBashState.running, 1) {
        client_fd = Socket.Accept(CCBashState.listen_fd)
        IfCondition GreaterEqual(client_fd, 0) ThenBlock: {
            done = 0
            WhileLoop EqualTo(done, 0) {
                req = Socket.RecvMsg(client_fd)
                IfCondition EqualTo(req, 0) ThenBlock: { done = 1 }
                IfCondition NotEqual(req, 0) ThenBlock: {
                    IfCondition NotEqual(req, -1) ThenBlock: {
                        CCBash_HandleRequest(client_fd, req)
                    }
                }
            }
            Socket.Close(client_fd)
        }
    }
    Exit(0)
}

RunTask(Main)
