// cc_write_ipc.ailang — Claude Code Write tool, IPC service.
//
// Writes (or appends) string content to a file. Creates parent file
// if missing. No directory creation — caller specifies a path that
// already lives in an existing directory.
//
// Schema: path (required string), content (required string), append (bool, default false).
//
// Build: ./ailang.x Applications/ClaudeCode/cc_tools/cc_write_ipc.ailang cc_write_ipc.x
// Run:   ./cc_write_ipc.x   (binds /tmp/ailang_cctools/Write.sock)
//
// Copyright 2026 Sean Collins, 2 Paws Machine and Engineering. SCSL.

LibraryImport.Arena
LibraryImport.Socket
LibraryImport.JSON
LibraryImport.StringUtils
LibraryImport.UtilArgs

FixedPool.CCWriteSys {
    "SYS_WRITE":     Initialize=1
    "SYS_OPEN":      Initialize=2
    "SYS_CLOSE":     Initialize=3
    "SYS_MKDIR":     Initialize=83
    "SYS_UNLINK":    Initialize=87
}

FixedPool.CCWriteFlags {
    "O_WRONLY":      Initialize=1
    "O_CREAT":       Initialize=64
    "O_TRUNC":       Initialize=512
    "O_APPEND":      Initialize=1024
}

FixedPool.CCWriteConst {
    "SOCK_PATH":     Initialize=0, CanChange=True
    "SOCK_DIR":      Initialize=0, CanChange=True
    "MODE":          Initialize=420   // 0o644
    "BACKLOG":       Initialize=8
}

FixedPool.CCWriteState {
    "schema":        Initialize=0, CanChange=True
    "listen_fd":     Initialize=-1, CanChange=True
    "running":       Initialize=1, CanChange=True
}

Function.CCWrite_BuildSchema {
    Output: Address
    Body: {
        s = UtilArgs_NewSchema("Write", "Write or append string content to a file. Creates the file if missing. Auto-creates the immediate parent directory. Use absolute paths only.")
        UtilArgs_AddField(s, "path", "path", 1, "Absolute path to write (parent directory is auto-created if missing)", "path")
        UtilArgs_AddField(s, "content", "string", 1, "Content to write", "content")
        UtilArgs_AddField(s, "append", "bool", 0, "Append instead of overwrite (default false)", "append")
        ReturnValue(s)
    }
}

// Returns 1 if str starts with prefix (exact byte match).
Function.CCWrite_HasPrefix {
    Input: str: Address
    Input: prefix: Address
    Output: Integer
    Body: {
        IfCondition EqualTo(str, 0) ThenBlock: { ReturnValue(0) }
        IfCondition EqualTo(prefix, 0) ThenBlock: { ReturnValue(0) }
        plen = StringLength(prefix)
        i = 0
        WhileLoop LessThan(i, plen) {
            IfCondition EqualTo(GetByte(str, i), 0) ThenBlock: { ReturnValue(0) }
            IfCondition NotEqual(GetByte(str, i), GetByte(prefix, i)) ThenBlock: { ReturnValue(0) }
            i = Add(i, 1)
        }
        ReturnValue(1)
    }
}

// Returns 1 if path targets an OS-critical directory that must never be overwritten.
Function.CCWrite_IsSystemPath {
    Input: path: Address
    Output: Integer
    Body: {
        IfCondition EqualTo(path, 0) ThenBlock: { ReturnValue(0) }
        IfCondition EqualTo(CCWrite_HasPrefix(path, "/etc/"), 1) ThenBlock: { ReturnValue(1) }
        IfCondition EqualTo(CCWrite_HasPrefix(path, "/proc/"), 1) ThenBlock: { ReturnValue(1) }
        IfCondition EqualTo(CCWrite_HasPrefix(path, "/sys/"), 1) ThenBlock: { ReturnValue(1) }
        IfCondition EqualTo(CCWrite_HasPrefix(path, "/dev/"), 1) ThenBlock: { ReturnValue(1) }
        IfCondition EqualTo(CCWrite_HasPrefix(path, "/bin/"), 1) ThenBlock: { ReturnValue(1) }
        IfCondition EqualTo(CCWrite_HasPrefix(path, "/sbin/"), 1) ThenBlock: { ReturnValue(1) }
        IfCondition EqualTo(CCWrite_HasPrefix(path, "/usr/bin/"), 1) ThenBlock: { ReturnValue(1) }
        IfCondition EqualTo(CCWrite_HasPrefix(path, "/usr/sbin/"), 1) ThenBlock: { ReturnValue(1) }
        IfCondition EqualTo(CCWrite_HasPrefix(path, "/usr/lib/"), 1) ThenBlock: { ReturnValue(1) }
        IfCondition EqualTo(CCWrite_HasPrefix(path, "/lib/"), 1) ThenBlock: { ReturnValue(1) }
        IfCondition EqualTo(CCWrite_HasPrefix(path, "/lib64/"), 1) ThenBlock: { ReturnValue(1) }
        IfCondition EqualTo(CCWrite_HasPrefix(path, "/boot/"), 1) ThenBlock: { ReturnValue(1) }
        ReturnValue(0)
    }
}

// Auto-create the immediate parent directory of path (best-effort, ignores EEXIST).
Function.CCWrite_MkdirParent {
    Input: path: Address
    Body: {
        IfCondition EqualTo(path, 0) ThenBlock: { ReturnValue(0) }
        plen = StringLength(path)
        IfCondition LessEqual(plen, 1) ThenBlock: { ReturnValue(0) }
        // Find last '/' (ASCII 47)
        i = Subtract(plen, 1)
        WhileLoop GreaterThan(i, 0) {
            IfCondition EqualTo(GetByte(path, i), 47) ThenBlock: { BreakLoop }
            i = Subtract(i, 1)
        }
        IfCondition LessEqual(i, 0) ThenBlock: { ReturnValue(0) }
        parent = Allocate(Add(i, 1))
        j = 0
        WhileLoop LessThan(j, i) {
            SetByte(parent, j, GetByte(path, j))
            j = Add(j, 1)
        }
        SetByte(parent, i, 0)
        SystemCall(CCWriteSys.SYS_MKDIR, parent, 493, 0, 0, 0)   // 0755
        Deallocate(parent, Add(i, 1))
    }
}

Function.CCWrite_Do {
    Input: args: Address
    Input: err_buf: Address
    Output: Integer
    Body: {
        path = UtilArgs_GetString(args, "path")
        content = UtilArgs_GetString(args, "content")
        append = UtilArgs_GetBool(args, "append")
        IfCondition EqualTo(path, 0) ThenBlock: {
            msg = "missing path — use an absolute path like /home/user/file.txt or /mnt/c/Users/..."
            i = 0
            WhileLoop LessThan(i, StringLength(msg)) { SetByte(err_buf, i, GetByte(msg, i))  i = Add(i, 1) }
            SetByte(err_buf, StringLength(msg), 0)
            ReturnValue(-1)
        }
        IfCondition EqualTo(content, 0) ThenBlock: { content = "" }

        // Block oversized writes — streaming huge content arguments causes TCP stream drops.
        clen = StringLength(content)
        IfCondition GreaterThan(clen, 40000) ThenBlock: {
            msg1 = "Content too large for a single Write ("
            cs = NumberToString(clen)
            msg2 = " bytes). Split into multiple Write calls of <=500 lines each and write them sequentially."
            i = 0
            WhileLoop LessThan(i, StringLength(msg1)) { SetByte(err_buf, i, GetByte(msg1, i))  i = Add(i, 1) }
            j = 0
            WhileLoop LessThan(j, StringLength(cs)) { SetByte(err_buf, Add(i, j), GetByte(cs, j))  j = Add(j, 1) }
            i = Add(i, j)
            j = 0
            WhileLoop LessThan(j, StringLength(msg2)) { SetByte(err_buf, Add(i, j), GetByte(msg2, j))  j = Add(j, 1) }
            SetByte(err_buf, Add(i, j), 0)
            ReturnValue(-1)
        }

        // Block writes to OS-critical directories
        IfCondition EqualTo(CCWrite_IsSystemPath(path), 1) ThenBlock: {
            msg = "Blocked: writing to OS system directory is not allowed: "
            i = 0
            WhileLoop LessThan(i, StringLength(msg)) { SetByte(err_buf, i, GetByte(msg, i))  i = Add(i, 1) }
            j = 0
            WhileLoop LessThan(j, StringLength(path)) { SetByte(err_buf, Add(i, j), GetByte(path, j))  j = Add(j, 1) }
            SetByte(err_buf, Add(i, j), 0)
            ReturnValue(-1)
        }

        // Auto-create the parent directory — common cause of "open failed" when
        // writing to a new subdirectory the model hasn't created yet.
        CCWrite_MkdirParent(path)

        flags = BitwiseOr(CCWriteFlags.O_WRONLY, CCWriteFlags.O_CREAT)
        IfCondition EqualTo(append, 1) ThenBlock: {
            flags = BitwiseOr(flags, CCWriteFlags.O_APPEND)
        } ElseBlock: {
            flags = BitwiseOr(flags, CCWriteFlags.O_TRUNC)
        }

        fd = SystemCall(CCWriteSys.SYS_OPEN, path, flags, CCWriteConst.MODE, 0, 0)
        IfCondition LessThan(fd, 0) ThenBlock: {
            // fd = -errno; report both the number and a human hint
            errno_val = Subtract(0, fd)
            hint = "check that the parent directory exists"
            IfCondition EqualTo(errno_val, 13) ThenBlock: { hint = "permission denied" }
            IfCondition EqualTo(errno_val, 30) ThenBlock: { hint = "read-only filesystem" }
            IfCondition EqualTo(errno_val, 20) ThenBlock: { hint = "a component of the path is not a directory" }
            prefix = "open failed (errno="
            i = 0
            WhileLoop LessThan(i, StringLength(prefix)) { SetByte(err_buf, i, GetByte(prefix, i))  i = Add(i, 1) }
            ens = NumberToString(errno_val)
            j = 0
            WhileLoop LessThan(j, StringLength(ens)) { SetByte(err_buf, Add(i, j), GetByte(ens, j))  j = Add(j, 1) }
            i = Add(i, j)
            sep = " "
            j = 0
            WhileLoop LessThan(j, StringLength(sep)) { SetByte(err_buf, Add(i, j), GetByte(sep, j))  j = Add(j, 1) }
            i = Add(i, j)
            j = 0
            WhileLoop LessThan(j, StringLength(hint)) { SetByte(err_buf, Add(i, j), GetByte(hint, j))  j = Add(j, 1) }
            i = Add(i, j)
            SetByte(err_buf, i, 58)  // ':'
            i = Add(i, 1)
            SetByte(err_buf, i, 32)  // ' '
            i = Add(i, 1)
            j = 0
            WhileLoop LessThan(j, StringLength(path)) { SetByte(err_buf, Add(i, j), GetByte(path, j))  j = Add(j, 1) }
            SetByte(err_buf, Add(i, j), 0)
            ReturnValue(-1)
        }

        clen = StringLength(content)
        total_written = 0
        WhileLoop LessThan(total_written, clen) {
            n = SystemCall(CCWriteSys.SYS_WRITE, fd, Add(content, total_written), Subtract(clen, total_written), 0, 0)
            IfCondition LessEqual(n, 0) ThenBlock: { BreakLoop }
            total_written = Add(total_written, n)
        }
        SystemCall(CCWriteSys.SYS_CLOSE, fd, 0, 0, 0, 0)
        ReturnValue(total_written)
    }
}

Function.CCWrite_SendError {
    Input: client_fd: Integer
    Input: id: Address
    Input: error_msg: Address
    Body: {
        resp = JSON.NewObject()
        JSON.SetString(resp, "method", "result")
        IfCondition NotEqual(id, 0) ThenBlock: { JSON.SetString(resp, "id", id) }
        JSON.SetBool(resp, "ok", 0)
        JSON.SetString(resp, "error", error_msg)
        Socket.SendMsg(client_fd, JSON.SerializeObject(resp))
    }
}

Function.CCWrite_SendResult {
    Input: client_fd: Integer
    Input: id: Address
    Input: content: Address
    Body: {
        resp = JSON.NewObject()
        JSON.SetString(resp, "method", "result")
        IfCondition NotEqual(id, 0) ThenBlock: { JSON.SetString(resp, "id", id) }
        JSON.SetBool(resp, "ok", 1)
        IfCondition NotEqual(content, 0) ThenBlock: { JSON.SetString(resp, "content", content) }
        Socket.SendMsg(client_fd, JSON.SerializeObject(resp))
    }
}

Function.CCWrite_SendSchema {
    Input: client_fd: Integer
    Body: {
        schema_str = UtilArgs_ExportToolSchema(CCWriteState.schema)
        parsed = ParseJSON(schema_str)
        schema_obj = JSON.AsObject(parsed)
        resp = JSON.NewObject()
        JSON.SetString(resp, "method", "schema_response")
        IfCondition NotEqual(schema_obj, 0) ThenBlock: { JSON.SetObject(resp, "schema", schema_obj) }
        Socket.SendMsg(client_fd, JSON.SerializeObject(resp))
    }
}

Function.CCWrite_HandleRequest {
    Input: client_fd: Integer
    Input: req_str: Address
    Body: {
        parsed = ParseJSON(req_str)
        IfCondition EqualTo(parsed, 0) ThenBlock: {
            CCWrite_SendError(client_fd, 0, "invalid JSON")  ReturnValue(0)
        }
        obj = JSON.AsObject(parsed)
        IfCondition EqualTo(obj, 0) ThenBlock: {
            CCWrite_SendError(client_fd, 0, "request must be a JSON object")  ReturnValue(0)
        }
        method = JSON.GetString(obj, "method")
        IfCondition EqualTo(method, 0) ThenBlock: {
            CCWrite_SendError(client_fd, 0, "missing method")  ReturnValue(0)
        }
        IfCondition EqualTo(StringCompare(method, "schema"), 0) ThenBlock: {
            CCWrite_SendSchema(client_fd)  ReturnValue(0)
        }
        IfCondition EqualTo(StringCompare(method, "call"), 0) ThenBlock: {
            id = JSON.GetString(obj, "id")
            args = JSON.GetObject(obj, "args")
            validated = UtilArgs_ParseIPC(CCWriteState.schema, args)
            IfCondition EqualTo(validated, 0) ThenBlock: {
                CCWrite_SendError(client_fd, id, "missing required arguments (path, content)")  ReturnValue(0)
            }
            err_buf = Allocate(256)
            SetByte(err_buf, 0, 0)
            written = CCWrite_Do(validated, err_buf)
            IfCondition LessThan(written, 0) ThenBlock: {
                CCWrite_SendError(client_fd, id, err_buf)
            } ElseBlock: {
                msg = StringConcat("wrote ", NumberToString(written))
                msg = StringConcat(msg, " bytes")
                CCWrite_SendResult(client_fd, id, msg)
            }
            Deallocate(err_buf, 256)
            ReturnValue(0)
        }
        CCWrite_SendError(client_fd, 0, "unknown method")
    }
}

SubRoutine.Main {
    CCWriteConst.SOCK_DIR  = "/tmp/ailang_cctools"
    CCWriteConst.SOCK_PATH = "@halcode/Write"
    CCWriteState.schema = CCWrite_BuildSchema()
    SystemCall(CCWriteSys.SYS_MKDIR, CCWriteConst.SOCK_DIR, 493, 0, 0, 0)
    SystemCall(CCWriteSys.SYS_UNLINK, CCWriteConst.SOCK_PATH, 0, 0, 0, 0)
    fd = Socket.Create(1, 1)
    IfCondition LessThan(fd, 0) ThenBlock: { Exit(1) }
    Socket.BindUnix(fd, CCWriteConst.SOCK_PATH)
    Socket.Listen(fd, CCWriteConst.BACKLOG)
    CCWriteState.listen_fd = fd
    PrintMessage("[cc_write_ipc] listening on ")  PrintMessage(CCWriteConst.SOCK_PATH)  PrintMessage("\n")
    WhileLoop EqualTo(CCWriteState.running, 1) {
        client_fd = Socket.Accept(CCWriteState.listen_fd)
        IfCondition GreaterEqual(client_fd, 0) ThenBlock: {
            done = 0
            WhileLoop EqualTo(done, 0) {
                req = Socket.RecvMsg(client_fd)
                IfCondition EqualTo(req, 0) ThenBlock: { done = 1 }
                IfCondition NotEqual(req, 0) ThenBlock: {
                    IfCondition NotEqual(req, -1) ThenBlock: {
                        CCWrite_HandleRequest(client_fd, req)
                    }
                }
            }
            Socket.Close(client_fd)
        }
    }
    Exit(0)
}

RunTask(Main)
