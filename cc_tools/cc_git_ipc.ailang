// cc_git_ipc.ailang — git operations IPC tool for HalCode9000.
//
// Executes /usr/bin/git subcommands via /bin/sh -c.
// Structured UtilArgs schema instead of raw command string.
// Subcommand is validated against a safe allowlist.
//
// Socket: @halcode/Git
// Schema: subcommand (required), args (optional string), path (optional cwd)
//
// Allowed subcommands: status, diff, log, show, add, commit, branch,
//   stash, reset, restore, checkout, pull, fetch, blame, annotate
//
// Copyright 2026 Sean Collins, 2 Paws Machine and Engineering. SCSL.

LibraryImport.Arena
LibraryImport.Socket
LibraryImport.JSON
LibraryImport.StringUtils
LibraryImport.UtilArgs

FixedPool.CCGitSys {
    "SYS_READ":    Initialize=0
    "SYS_WRITE":   Initialize=1
    "SYS_OPEN":    Initialize=2
    "SYS_CLOSE":   Initialize=3
    "SYS_POLL":    Initialize=7
    "SYS_PIPE":    Initialize=22
    "SYS_DUP2":    Initialize=33
    "SYS_FORK":    Initialize=57
    "SYS_EXECVE":  Initialize=59
    "SYS_EXIT":    Initialize=60
    "SYS_WAIT4":   Initialize=61
    "SYS_KILL":    Initialize=62
    "SYS_MKDIR":   Initialize=83
    "SYS_UNLINK":  Initialize=87
    "SYS_TIME":    Initialize=201
    "POLLIN":      Initialize=1
    "SIGKILL":     Initialize=9
    "WNOHANG":     Initialize=1
    "TIMEOUT_S":   Initialize=30
}

FixedPool.CCGitConst {
    "SOCK_PATH":   Initialize="@halcode/Git", CanChange=True
    "BACKLOG":     Initialize=8
    "MAX_OUTPUT":  Initialize=65536
    "READ_CHUNK":  Initialize=4096
}

FixedPool.CCGitState {
    "schema":    Initialize=0,  CanChange=True
    "listen_fd": Initialize=-1, CanChange=True
    "running":   Initialize=1,  CanChange=True
}

// =============================================================================
// ALLOWLIST: safe git subcommands
// Returns 1 if subcommand is allowed.
// =============================================================================

Function.CCGit_IsAllowed {
    Input: sub: Address
    Output: Integer
    Body: {
        IfCondition EqualTo(StringCompare(sub, "status"),   0) ThenBlock: { ReturnValue(1) }
        IfCondition EqualTo(StringCompare(sub, "diff"),     0) ThenBlock: { ReturnValue(1) }
        IfCondition EqualTo(StringCompare(sub, "log"),      0) ThenBlock: { ReturnValue(1) }
        IfCondition EqualTo(StringCompare(sub, "show"),     0) ThenBlock: { ReturnValue(1) }
        IfCondition EqualTo(StringCompare(sub, "add"),      0) ThenBlock: { ReturnValue(1) }
        IfCondition EqualTo(StringCompare(sub, "commit"),   0) ThenBlock: { ReturnValue(1) }
        IfCondition EqualTo(StringCompare(sub, "branch"),   0) ThenBlock: { ReturnValue(1) }
        IfCondition EqualTo(StringCompare(sub, "stash"),    0) ThenBlock: { ReturnValue(1) }
        IfCondition EqualTo(StringCompare(sub, "reset"),    0) ThenBlock: { ReturnValue(1) }
        IfCondition EqualTo(StringCompare(sub, "restore"),  0) ThenBlock: { ReturnValue(1) }
        IfCondition EqualTo(StringCompare(sub, "checkout"), 0) ThenBlock: { ReturnValue(1) }
        IfCondition EqualTo(StringCompare(sub, "pull"),     0) ThenBlock: { ReturnValue(1) }
        IfCondition EqualTo(StringCompare(sub, "fetch"),    0) ThenBlock: { ReturnValue(1) }
        IfCondition EqualTo(StringCompare(sub, "blame"),    0) ThenBlock: { ReturnValue(1) }
        IfCondition EqualTo(StringCompare(sub, "annotate"), 0) ThenBlock: { ReturnValue(1) }
        IfCondition EqualTo(StringCompare(sub, "tag"),      0) ThenBlock: { ReturnValue(1) }
        IfCondition EqualTo(StringCompare(sub, "remote"),   0) ThenBlock: { ReturnValue(1) }
        IfCondition EqualTo(StringCompare(sub, "shortlog"), 0) ThenBlock: { ReturnValue(1) }
        IfCondition EqualTo(StringCompare(sub, "rev-parse"),0) ThenBlock: { ReturnValue(1) }
        ReturnValue(0)
    }
}

// =============================================================================
// ENVP FROM /proc/self/environ
// =============================================================================

Function.CCGit_GetEnvp {
    Input: env_data_out: Address
    Output: Address
    Body: {
        StoreValue(env_data_out, 0)
        fd = SystemCall(CCGitSys.SYS_OPEN, "/proc/self/environ", 0, 0, 0, 0)
        IfCondition LessThan(fd, 0) ThenBlock: { ReturnValue(0) }
        env_data = Allocate(65536)
        n = SystemCall(CCGitSys.SYS_READ, fd, env_data, 65536, 0, 0)
        SystemCall(CCGitSys.SYS_CLOSE, fd, 0, 0, 0, 0)
        IfCondition LessEqual(n, 0) ThenBlock: {
            Deallocate(env_data, 65536)
            ReturnValue(0)
        }
        envp = Allocate(8200)
        pos = 0
        idx = 0
        WhileLoop LessThan(pos, n) {
            start = pos
            WhileLoop LessThan(pos, n) {
                IfCondition EqualTo(GetByte(env_data, pos), 0) ThenBlock: {
                    pos = Add(pos, 1)
                    BreakLoop
                }
                pos = Add(pos, 1)
            }
            IfCondition GreaterThan(pos, Add(start, 1)) ThenBlock: {
                StoreValue(Add(envp, Multiply(idx, 8)), Add(env_data, start))
                idx = Add(idx, 1)
            }
        }
        StoreValue(Add(envp, Multiply(idx, 8)), 0)
        StoreValue(env_data_out, env_data)
        ReturnValue(envp)
    }
}

// =============================================================================
// EXEC: cd <path> && git <subcommand> <args>
// Returns "exit=N\n<output>" string.
// =============================================================================

Function.CCGit_Run {
    Input: subcommand: Address
    Input: extra_args: Address
    Input: work_path: Address
    Output: Address
    Body: {
        // Build shell command: [cd <path> &&] git <sub> [args] 2>&1
        cmd = "git "
        cmd = StringConcat(cmd, subcommand)
        IfCondition NotEqual(extra_args, 0) ThenBlock: {
            cmd = StringConcat(cmd, " ")
            cmd = StringConcat(cmd, extra_args)
        }
        cmd = StringConcat(cmd, " 2>&1")
        IfCondition NotEqual(work_path, 0) ThenBlock: {
            prefix = StringConcat("cd ", work_path)
            prefix = StringConcat(prefix, " && ")
            cmd = StringConcat(prefix, cmd)
        }

        deadline = Add(SystemCall(CCGitSys.SYS_TIME, 0, 0, 0, 0, 0), CCGitSys.TIMEOUT_S)

        argv = Allocate(32)
        StoreValue(Add(argv, 0),  "/bin/sh")
        StoreValue(Add(argv, 8),  "-c")
        StoreValue(Add(argv, 16), cmd)
        StoreValue(Add(argv, 24), 0)

        env_data_holder = Allocate(8)
        StoreValue(env_data_holder, 0)
        envp     = CCGit_GetEnvp(env_data_holder)
        env_data = Dereference(env_data_holder)
        Deallocate(env_data_holder, 8)

        pf = Allocate(8)
        pr = SystemCall(CCGitSys.SYS_PIPE, pf, 0, 0, 0, 0)
        IfCondition LessThan(pr, 0) ThenBlock: {
            Deallocate(pf, 8)  Deallocate(argv, 32)
            IfCondition NotEqual(envp,     0) ThenBlock: { Deallocate(envp,     8200) }
            IfCondition NotEqual(env_data, 0) ThenBlock: { Deallocate(env_data, 65536) }
            ReturnValue(0)
        }
        pipe_r = Dereference(pf, "dword")
        pipe_w = Dereference(Add(pf, 4), "dword")
        Deallocate(pf, 8)

        pid = SystemCall(CCGitSys.SYS_FORK, 0, 0, 0, 0, 0)
        IfCondition EqualTo(pid, 0) ThenBlock: {
            SystemCall(CCGitSys.SYS_CLOSE, pipe_r, 0, 0, 0, 0)
            SystemCall(CCGitSys.SYS_DUP2,  pipe_w, 1, 0, 0, 0)
            SystemCall(CCGitSys.SYS_DUP2,  pipe_w, 2, 0, 0, 0)
            SystemCall(CCGitSys.SYS_CLOSE, pipe_w, 0, 0, 0, 0)
            SystemCall(CCGitSys.SYS_EXECVE, "/bin/sh", argv, envp)
            SystemCall(CCGitSys.SYS_EXIT, 127, 0, 0, 0, 0)
        }
        IfCondition LessThan(pid, 0) ThenBlock: {
            SystemCall(CCGitSys.SYS_CLOSE, pipe_r, 0, 0, 0, 0)
            SystemCall(CCGitSys.SYS_CLOSE, pipe_w, 0, 0, 0, 0)
            Deallocate(argv, 32)
            IfCondition NotEqual(envp,     0) ThenBlock: { Deallocate(envp,     8200) }
            IfCondition NotEqual(env_data, 0) ThenBlock: { Deallocate(env_data, 65536) }
            ReturnValue(0)
        }

        SystemCall(CCGitSys.SYS_CLOSE, pipe_w, 0, 0, 0, 0)
        Deallocate(argv, 32)
        IfCondition NotEqual(envp,     0) ThenBlock: { Deallocate(envp,     8200) }
        IfCondition NotEqual(env_data, 0) ThenBlock: { Deallocate(env_data, 65536) }

        pfd   = Allocate(8)
        out   = Allocate(Add(CCGitConst.MAX_OUTPUT, 64))
        used  = 0
        chunk = Allocate(CCGitConst.READ_CHUNK)
        timed_out = 0
        body_off = 32

        WhileLoop 1 {
            now = SystemCall(CCGitSys.SYS_TIME, 0, 0, 0, 0, 0)
            IfCondition GreaterEqual(now, deadline) ThenBlock: { timed_out = 1  BreakLoop }
            free_room = Subtract(CCGitConst.MAX_OUTPUT, used)
            IfCondition LessEqual(free_room, 0) ThenBlock: { BreakLoop }
            remain_ms = Multiply(Subtract(deadline, now), 1000)
            IfCondition GreaterThan(remain_ms, 1000) ThenBlock: { remain_ms = 1000 }
            StoreValue(pfd, pipe_r, "dword")
            SetByte(pfd, 4, CCGitSys.POLLIN)
            SetByte(pfd, 5, 0)  SetByte(pfd, 6, 0)  SetByte(pfd, 7, 0)
            poll_r = SystemCall(CCGitSys.SYS_POLL, pfd, 1, remain_ms, 0, 0)
            IfCondition LessThan(poll_r, 0) ThenBlock: { BreakLoop }
            IfCondition GreaterThan(poll_r, 0) ThenBlock: {
                want = CCGitConst.READ_CHUNK
                IfCondition GreaterThan(want, free_room) ThenBlock: { want = free_room }
                n = SystemCall(CCGitSys.SYS_READ, pipe_r, chunk, want, 0, 0)
                IfCondition LessEqual(n, 0) ThenBlock: { BreakLoop }
                i = 0
                WhileLoop LessThan(i, n) {
                    SetByte(out, Add(body_off, Add(used, i)), GetByte(chunk, i))
                    i = Add(i, 1)
                }
                used = Add(used, n)
            }
        }

        Deallocate(pfd, 8)
        Deallocate(chunk, CCGitConst.READ_CHUNK)
        SystemCall(CCGitSys.SYS_CLOSE, pipe_r, 0, 0, 0, 0)

        IfCondition EqualTo(timed_out, 1) ThenBlock: {
            SystemCall(CCGitSys.SYS_KILL, pid, CCGitSys.SIGKILL, 0, 0, 0)
            note = "\n[timed out]"
            nlen = StringLength(note)
            avail = Subtract(CCGitConst.MAX_OUTPUT, used)
            IfCondition GreaterThan(nlen, avail) ThenBlock: { nlen = avail }
            k = 0
            WhileLoop LessThan(k, nlen) {
                SetByte(out, Add(body_off, Add(used, k)), GetByte(note, k))
                k = Add(k, 1)
            }
            used = Add(used, nlen)
        }

        status_buf = Allocate(8)
        StoreValue(status_buf, 0)
        raw_status = 0
        wi = 0
        WhileLoop LessThan(wi, 10) {
            wr = SystemCall(CCGitSys.SYS_WAIT4, pid, status_buf, CCGitSys.WNOHANG, 0, 0)
            IfCondition NotEqual(wr, 0) ThenBlock: {
                raw_status = Dereference(status_buf, "dword")
                wi = 10
            } ElseBlock: {
                ts = Allocate(16)
                StoreValue(ts, 0)
                StoreValue(Add(ts, 8), 100000000)
                SystemCall(35, ts, 0, 0, 0, 0)
                Deallocate(ts, 16)
                wi = Add(wi, 1)
            }
        }
        Deallocate(status_buf, 8)
        exit_code = BitwiseAnd(RightShift(raw_status, 8), 255)

        // Build "exit=N\n" prefix
        prefix_buf = Allocate(32)
        prefix_str = "exit="
        plen = StringLength(prefix_str)
        pi2 = 0
        WhileLoop LessThan(pi2, plen) {
            SetByte(prefix_buf, pi2, GetByte(prefix_str, pi2))
            pi2 = Add(pi2, 1)
        }
        digits = NumberToString(exit_code)
        dlen = StringLength(digits)
        di = 0
        WhileLoop LessThan(di, dlen) {
            SetByte(prefix_buf, Add(plen, di), GetByte(digits, di))
            di = Add(di, 1)
        }
        SetByte(prefix_buf, Add(plen, dlen), 10)
        prefix_total = Add(plen, Add(dlen, 1))

        final_len = Add(prefix_total, used)
        final = Allocate(Add(final_len, 1))
        k2 = 0
        WhileLoop LessThan(k2, prefix_total) {
            SetByte(final, k2, GetByte(prefix_buf, k2))
            k2 = Add(k2, 1)
        }
        m = 0
        WhileLoop LessThan(m, used) {
            SetByte(final, Add(prefix_total, m), GetByte(out, Add(body_off, m)))
            m = Add(m, 1)
        }
        SetByte(final, final_len, 0)
        Deallocate(prefix_buf, 32)
        Deallocate(out, Add(CCGitConst.MAX_OUTPUT, 64))
        ReturnValue(final)
    }
}

// =============================================================================
// SCHEMA + IPC DISPATCH
// =============================================================================

Function.CCGit_BuildSchema {
    Output: Address
    Body: {
        s = UtilArgs_NewSchema("Git", "Run a git subcommand and return combined stdout+stderr with exit code")
        UtilArgs_AddField(s, "subcommand", "string", 1, "Git subcommand: status, diff, log, show, add, commit, branch, stash, reset, restore, checkout, pull, fetch, blame, tag, remote, shortlog, rev-parse", "subcommand")
        UtilArgs_AddField(s, "args",       "string", 0, "Additional arguments passed after the subcommand (e.g. --oneline -20 for log)", "args")
        UtilArgs_AddField(s, "path",       "path",   0, "Working directory for the command (default: current directory)", "path")
        ReturnValue(s)
    }
}

Function.CCGit_SendError {
    Input: client_fd: Integer
    Input: id: Address
    Input: msg: Address
    Body: {
        resp = JSON.NewObject()
        JSON.SetString(resp, "method", "result")
        IfCondition NotEqual(id, 0) ThenBlock: { JSON.SetString(resp, "id", id) }
        JSON.SetBool(resp, "ok", 0)
        JSON.SetString(resp, "error", msg)
        Socket.SendMsg(client_fd, JSON.SerializeObject(resp))
    }
}

Function.CCGit_SendResult {
    Input: client_fd: Integer
    Input: id: Address
    Input: content: Address
    Body: {
        resp = JSON.NewObject()
        JSON.SetString(resp, "method", "result")
        IfCondition NotEqual(id, 0) ThenBlock: { JSON.SetString(resp, "id", id) }
        JSON.SetBool(resp, "ok", 1)
        IfCondition NotEqual(content, 0) ThenBlock: { JSON.SetString(resp, "content", content) }
        Socket.SendMsg(client_fd, JSON.SerializeObject(resp))
    }
}

Function.CCGit_SendSchema {
    Input: client_fd: Integer
    Body: {
        schema_str = UtilArgs_ExportToolSchema(CCGitState.schema)
        parsed = ParseJSON(schema_str)
        schema_obj = JSON.AsObject(parsed)
        resp = JSON.NewObject()
        JSON.SetString(resp, "method", "schema_response")
        IfCondition NotEqual(schema_obj, 0) ThenBlock: { JSON.SetObject(resp, "schema", schema_obj) }
        Socket.SendMsg(client_fd, JSON.SerializeObject(resp))
    }
}

Function.CCGit_HandleRequest {
    Input: client_fd: Integer
    Input: req_str: Address
    Body: {
        parsed = ParseJSON(req_str)
        IfCondition EqualTo(parsed, 0) ThenBlock: {
            CCGit_SendError(client_fd, 0, "invalid JSON")  ReturnValue(0)
        }
        obj = JSON.AsObject(parsed)
        IfCondition EqualTo(obj, 0) ThenBlock: {
            CCGit_SendError(client_fd, 0, "request must be JSON object")
            JSON.Free(parsed)  ReturnValue(0)
        }
        method = JSON.GetString(obj, "method")
        IfCondition EqualTo(method, 0) ThenBlock: {
            CCGit_SendError(client_fd, 0, "missing method")
            JSON.Free(parsed)  ReturnValue(0)
        }
        IfCondition EqualTo(StringCompare(method, "schema"), 0) ThenBlock: {
            CCGit_SendSchema(client_fd)
            JSON.Free(parsed)  ReturnValue(0)
        }
        IfCondition EqualTo(StringCompare(method, "call"), 0) ThenBlock: {
            id        = JSON.GetString(obj, "id")
            args      = JSON.GetObject(obj, "args")
            validated = UtilArgs_ParseIPC(CCGitState.schema, args)
            IfCondition EqualTo(validated, 0) ThenBlock: {
                CCGit_SendError(client_fd, id, "missing required argument: subcommand")
                JSON.Free(parsed)  ReturnValue(0)
            }

            subcommand = UtilArgs_GetString(validated, "subcommand")
            IfCondition EqualTo(subcommand, 0) ThenBlock: {
                CCGit_SendError(client_fd, id, "subcommand is required")
                JSON.Free(parsed)  ReturnValue(0)
            }
            IfCondition EqualTo(CCGit_IsAllowed(subcommand), 0) ThenBlock: {
                CCGit_SendError(client_fd, id, StringConcat("git subcommand not in allowlist: ", subcommand))
                JSON.Free(parsed)  ReturnValue(0)
            }

            extra_args = UtilArgs_GetString(validated, "args")
            work_path  = UtilArgs_GetString(validated, "path")

            content = CCGit_Run(subcommand, extra_args, work_path)
            IfCondition EqualTo(content, 0) ThenBlock: {
                CCGit_SendError(client_fd, id, "fork/exec failed")
            } ElseBlock: {
                CCGit_SendResult(client_fd, id, content)
            }
            JSON.Free(parsed)
            ReturnValue(0)
        }
        CCGit_SendError(client_fd, 0, "unknown method")
        JSON.Free(parsed)
    }
}

SubRoutine.Main {
    CCGitConst.SOCK_PATH = "@halcode/Git"
    CCGitState.schema    = CCGit_BuildSchema()

    SystemCall(CCGitSys.SYS_MKDIR, "/tmp/ailang_cctools", 493, 0, 0, 0)
    SystemCall(CCGitSys.SYS_UNLINK, CCGitConst.SOCK_PATH, 0, 0, 0, 0)

    fd = Socket.Create(1, 1)
    IfCondition LessThan(fd, 0) ThenBlock: {
        PrintMessage("[cc_git_ipc] socket create failed\n")
        Exit(1)
    }
    br = Socket.BindUnix(fd, CCGitConst.SOCK_PATH)
    IfCondition LessThan(br, 0) ThenBlock: {
        PrintMessage("[cc_git_ipc] bind failed\n")
        Socket.Close(fd)  Exit(1)
    }
    Socket.Listen(fd, CCGitConst.BACKLOG)
    CCGitState.listen_fd = fd
    PrintMessage("[cc_git_ipc] listening on @halcode/Git\n")

    WhileLoop EqualTo(CCGitState.running, 1) {
        client_fd = Socket.Accept(CCGitState.listen_fd)
        IfCondition GreaterEqual(client_fd, 0) ThenBlock: {
            done = 0
            WhileLoop EqualTo(done, 0) {
                req = Socket.RecvMsg(client_fd)
                IfCondition EqualTo(req, 0) ThenBlock: { done = 1 }
                IfCondition NotEqual(req, 0) ThenBlock: {
                    IfCondition NotEqual(req, -1) ThenBlock: {
                        CCGit_HandleRequest(client_fd, req)
                    }
                }
            }
            Socket.Close(client_fd)
        }
    }
    Socket.Close(CCGitState.listen_fd)
    Exit(0)
}

RunTask(Main)
