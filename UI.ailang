// UI.ailang — Claude Code raw-mode TUI wrapper.
//
// Built on Library.TUI (the same primitives dnd_game uses successfully).
// Raw mode means we own the screen — every cursor position is explicit,
// nothing fights the terminal.
//
// Architecture:
//
//   ┌─────────────────────────────────────────┐
//   │                                         │  ← Chat region: rows 1..(rows-PROMPT_H)
//   │  scrolls naturally as chat output       │     Owned by ChatPrintln/ChatPrint
//   │  is appended via UI.ChatPrintln         │     which advance an internal cursor row
//   │                                         │
//   │  ────────────────────────────────       │  ← Top rule (row rows-PROMPT_H+1)
//   │  > user types here                      │  ← Body row (row rows-PROMPT_H+2)
//   │  ────────────────────────────────       │  ← Bottom rule (row rows-PROMPT_H+3)
//   │  /help · /quit · ...                    │  ← Hint (row rows-PROMPT_H+4)
//   └─────────────────────────────────────────┘
//
// Functions:
//   UI.Init()             — TUI_Init (raw mode + alt screen + clear)
//   UI.Shutdown()         — TUI_Shutdown (restores terminal)
//   UI.ChatPrint(s)       — append text to chat region (no newline)
//   UI.ChatPrintln(s)     — append text + newline; scrolls if full
//   UI.ChatTag(tag, body, color) — colored prefix line (e.g. "● Read(...)")
//   UI.ReadLine() -> str  — read one line of input from the pinned prompt
//   UI.ToolCallStart(name, args)  / UI.ToolCallEnd(ok)  — render tool calls
//   UI.SessionHeader(version, model, cwd) — small mascot + info block
//   UI.PrintHelp()        — slash-command help
//
// Copyright 2026 Sean Collins, 2 Paws Machine and Engineering. SCSL.

LibraryImport.Arena
LibraryImport.StringUtils
LibraryImport.JSON
LibraryImport.TUI
LibraryImport.TuiWidget
LibraryImport.ANSI

FixedPool.UISys {
    "SYS_WRITE":  Initialize=1
    "SYS_POLL":   Initialize=7
    "SYS_IOCTL":  Initialize=16
    "SYS_CLOCK_GETTIME": Initialize=228
}

FixedPool.UIColors {
    "ORANGE_FG":   Initialize=3   // TUI yellow ≈ orange in 8-color palette
    "DIM_FG":      Initialize=8   // bright black = dim grey
    "WHITE_FG":    Initialize=7
    "GREEN_FG":    Initialize=2
    "RED_FG":      Initialize=1
    "CYAN_FG":     Initialize=6
}

FixedPool.UILayout {
    "prompt_h":      Initialize=4, CanChange=True   // top rule(1) + body(1) + bot rule(1) + hint(1)
    "max_bar":       Initialize=512, CanChange=True  // uncapped — fill the terminal
    "rows":          Initialize=24, CanChange=True
    "cols":          Initialize=80, CanChange=True
    "chat_top":      Initialize=1, CanChange=True   // full height native scrolling
    "chat_bot":      Initialize=20, CanChange=True  // last row of chat region (rows - prompt_h)
    "chat_cursor":   Initialize=1, CanChange=True   // current row to write into
    "chat_col":      Initialize=1, CanChange=True   // current col within that row
    "input_buf":     Initialize=0, CanChange=True   // edit buffer
    "input_len":     Initialize=0, CanChange=True   // async input length
    "input_cap":     Initialize=65536
    "initialized":   Initialize=0, CanChange=True
    "ui_state":      Initialize=0, CanChange=True   // 0=idle, 1=waiting, 2=done
    "mascot_frame":  Initialize=0, CanChange=True
    "mascot_tick":   Initialize=0, CanChange=True
    "token_count":   Initialize=0, CanChange=True
    "tok_in":        Initialize=0, CanChange=True
    "tok_out":       Initialize=0, CanChange=True
    "interrupted":   Initialize=0, CanChange=True
    "show_tools":    Initialize=0, CanChange=True   // 0=hidden(compact), 1=expanded
    "quote_str":     Initialize=0, CanChange=True
    "quote_offset":  Initialize=0, CanChange=True
    "last_anim_ms":  Initialize=0, CanChange=True
    "reasoning_str": Initialize=0, CanChange=True
    "in_paste":      Initialize=0, CanChange=True
    "think_start_ms":    Initialize=0, CanChange=True
    "think_elapsed_sec": Initialize=0, CanChange=True
    "active_tool":       Initialize=0, CanChange=True
    "input_len_cached":  Initialize=0, CanChange=True  // cache key: last computed len
    "input_cols_cached": Initialize=0, CanChange=True  // cache key: cols at compute time
    "input_lines_cached":Initialize=1, CanChange=True  // cached result
    "sidebar_w":         Initialize=22
    "divider_col":       Initialize=23
    "chat_x":            Initialize=24               // left column of chat pane
    "chat_w":            Initialize=0, CanChange=True // computed: cols - 23
    "header_row":        Initialize=1
    "rule_row":          Initialize=0, CanChange=True // computed: rows - 4
    "input_row":         Initialize=0, CanChange=True // computed: rows - 3
    "hint_row":          Initialize=0, CanChange=True // computed: rows - 1
    "hal_msg_idx":       Initialize=0, CanChange=True
    "model_str":         Initialize=0, CanChange=True
    "cwd_str":           Initialize=0, CanChange=True
}

FixedPool.UIGlyph {
    "STAR":          Initialize=0, CanChange=True   // ✻
    "DOT":           Initialize=0, CanChange=True   // ●
    "CHECK":         Initialize=0, CanChange=True   // ✓
    "CROSS":         Initialize=0, CanChange=True   // ✗
    "ARROW":         Initialize=0, CanChange=True   // >
    "RULE":          Initialize=0, CanChange=True   // ─
}

// =============================================================================
// TRUECOLOR HELPERS — write 24-bit SGR directly into TUI's buffer
// =============================================================================
// AILang string literals don't process \x escape sequences, so we build
// the CSI sequences byte-by-byte using TUI_BufferChar, the same way
// Library.TUI builds all its sequences internally.

// Write a non-negative integer as decimal digits into TUI's buffer.
Function.UI_TUI_WriteInt {
    Input: val: Integer
    Body: {
        IfCondition EqualTo(val, 0) ThenBlock: { TUI_BufferChar(48)  ReturnValue(0) }
        tmp = Allocate(20)
        n = 0
        v = val
        WhileLoop GreaterThan(v, 0) {
            SetByte(tmp, n, Add(48, Modulo(v, 10)))
            v = Divide(v, 10)
            n = Add(n, 1)
        }
        i = 0
        WhileLoop LessThan(i, n) {
            TUI_BufferChar(GetByte(tmp, Subtract(Subtract(n, 1), i)))
            i = Add(i, 1)
        }
        Deallocate(tmp, 20)
    }
}

// ESC [ 38 ; 2 ; r ; g ; b m  — 24-bit truecolor foreground into TUI buffer.
Function.UI_TUI_FgRGB {
    Input: r: Integer
    Input: g: Integer
    Input: b: Integer
    Body: {
        TUI_BufferChar(27)    // ESC
        TUI_BufferChar(91)    // [
        TUI_BufferChar(51)    // '3'
        TUI_BufferChar(56)    // '8'
        TUI_BufferChar(59)    // ';'
        TUI_BufferChar(50)    // '2'
        TUI_BufferChar(59)    // ';'
        UI_TUI_WriteInt(r)
        TUI_BufferChar(59)    // ';'
        UI_TUI_WriteInt(g)
        TUI_BufferChar(59)    // ';'
        UI_TUI_WriteInt(b)
        TUI_BufferChar(109)   // 'm'
    }
}

// =============================================================================
// HINT TEXT HELPER
// =============================================================================
Function.UI_GetHintText {
    Output: Address
    Body: {
        ReturnValue(" /help · /clear · /home · /quit")
    }
}

// =============================================================================
// INIT / SHUTDOWN
// =============================================================================
Function.UI.Init {
    Body: {
        IfCondition EqualTo(UILayout.initialized, 1) ThenBlock: { ReturnValue(0) }

        UIGlyph.STAR  = "✻"
        UIGlyph.DOT   = "●"
        UIGlyph.CHECK = "✓"
        UIGlyph.CROSS = "✗"
        UIGlyph.ARROW = ">"
        UIGlyph.RULE  = "─"

        UILayout.input_buf = Allocate(UILayout.input_cap)

        TUI_Init()
        
        // EXIT ALTERNATE SCREEN BUFFER: This is the magic key to native scrollback!
        // TUI_Init puts us in the alt screen, which has no history. We immediately
        // exit it so we draw on the main buffer, preserving user scroll history.
        TUI_BufferChar(27) TUI_BufferWriteStr("[?1049l")
        
        // Ensure scrolling region is completely reset
        TUI_BufferChar(27) TUI_BufferWriteStr("[r")

        // Push old terminal history up cleanly by scrolling
        TUI_BufferChar(27) TUI_BufferWriteStr("[999;1H")
        i = 0
        WhileLoop LessThan(i, 50) {
            TUI_BufferChar(10)
            i = Add(i, 1)
        }

        UI_RecomputeLayout()
        UILayout.initialized = 1

        // Hard clear on boot only — wipes everything including any cooked-mode output above.
        TUI_BufferChar(27)
        TUI_BufferWriteStr("[2J")
        TUI_BufferChar(27)
        TUI_BufferWriteStr("[H")
        TUI_Refresh()
        UILayout.chat_cursor = UILayout.chat_top
        UILayout.chat_col = UILayout.chat_x

        // Terminal polish via Library.ANSI
        cc_title = "HAL Code 9000"
        ANSI.SetTitle(cc_title, 11)
        ANSI.SetCursorShape(ANSICursor.STEADY_BEAM)
        ANSI.BracketedPasteOn()

        // Initialize HAL messages and chrome
        UI_HALMsgs_Init()
        UI_PaintPromptFrame(UI_GetHintText())
        UI_DrawChrome()
        UI_DrawHintRow()
        TUI_Refresh()
    }
}

Function.UI.Shutdown {
    Body: {
        IfCondition EqualTo(UILayout.initialized, 0) ThenBlock: { ReturnValue(0) }
        ANSI.BracketedPasteOff()
        ANSI.SetCursorShape(ANSICursor.DEFAULT)
        TUI_Shutdown()
        UILayout.initialized = 0
    }
}

// Clear only the chat region (rows chat_top..chat_bot), leaving the prompt
// frame intact. Used by /clear — no flicker, no prompt redraw needed.
Function.UI.ClearChat {
    Body: {
        i = UILayout.chat_top
        WhileLoop LessEqual(i, UILayout.chat_bot) {
            TUI_MoveTo(i, UILayout.chat_x)
            TUI_BufferChar(27)
            TUI_BufferWriteStr("[K")
            i = Add(i, 1)
        }
        UILayout.chat_cursor = UILayout.chat_top
        UILayout.chat_col = UILayout.chat_x
        TUI_MoveTo(UILayout.chat_top, UILayout.chat_x)
        TUI_Refresh()
    }
}

// Recompute layout based on current terminal size.
Function.UI_RecomputeLayout {
    Body: {
        TUI_GetScreenSize()
        UILayout.rows = TUI_State.screen_height
        UILayout.cols = TUI_State.screen_width
        IfCondition LessEqual(UILayout.rows, 0) ThenBlock: { UILayout.rows = 24 }
        IfCondition LessEqual(UILayout.cols, 0) ThenBlock: { UILayout.cols = 80 }
        UILayout.chat_top = 2
        IfCondition LessThan(UILayout.prompt_h, 4) ThenBlock: { UILayout.prompt_h = 4 }
        UILayout.chat_bot = Subtract(UILayout.rows, 5)
        IfCondition LessThan(UILayout.chat_bot, UILayout.chat_top) ThenBlock: { UILayout.chat_bot = UILayout.chat_top }
        IfCondition LessThan(UILayout.chat_cursor, UILayout.chat_top) ThenBlock: { UILayout.chat_cursor = UILayout.chat_top }
        IfCondition GreaterThan(UILayout.chat_cursor, UILayout.chat_bot) ThenBlock: {
            UILayout.chat_cursor = UILayout.chat_bot
        }
        UILayout.chat_w    = Subtract(UILayout.cols, 23)
        UILayout.rule_row  = Subtract(UILayout.rows, 4)
        UILayout.input_row = Subtract(UILayout.rows, 3)
        UILayout.hint_row  = Subtract(UILayout.rows, 1)
        IfCondition EqualTo(UILayout.cwd_str, 0) ThenBlock: {
            UILayout.cwd_str = UI_GetCwd()
        }
    }
}

// =============================================================================
// HELPERS — bar width, row positions
// =============================================================================
Function.UI_BarWidth {
    Output: Integer
    Body: {
        bw = UILayout.cols
        IfCondition GreaterThan(bw, UILayout.max_bar) ThenBlock: { bw = UILayout.max_bar }
        IfCondition LessThan(bw, 10) ThenBlock: { bw = 10 }
        ReturnValue(bw)
    }
}

Function.UI_TopRuleRow    { Output: Integer  Body: { ReturnValue(Add(UILayout.chat_bot, 1)) } }
Function.UI_BodyRow       { Output: Integer  Body: { ReturnValue(Add(UILayout.chat_bot, 2)) } }
Function.UI_BotRuleRow    { Output: Integer  Body: { ReturnValue(Subtract(Add(UILayout.chat_bot, UILayout.prompt_h), 1)) } }
Function.UI_HintRow       { Output: Integer  Body: { ReturnValue(Add(UILayout.chat_bot, UILayout.prompt_h)) } }

// =============================================================================
// PROMPT FRAME — the always-visible bottom-pinned input area
// State colors: 0=idle (orange), 1=waiting (red), 2=done (green)
// =============================================================================
Function.UI_PromptColor {
    Body: {
        IfCondition EqualTo(UILayout.ui_state, 1) ThenBlock: {
            UI_TUI_FgRGB(180, 40, 40)
        } ElseBlock: {
            IfCondition EqualTo(UILayout.ui_state, 2) ThenBlock: {
                UI_TUI_FgRGB(50, 180, 70)
            } ElseBlock: {
                UI_TUI_FgRGB(204, 120, 92)
            }
        }
    }
}

Function.UI_PaintTopRule {
    Body: {
        TUI_ResetColor()
        TUI_MoveTo(UI_TopRuleRow(), 1)
        TUI_BufferChar(27)
        TUI_BufferWriteStr("[K")
        UI_PromptColor()
        TUI_BufferWriteStr("┌")
        chars_drawn = 1
        total_target = Subtract(UI_BarWidth(), 1)
        
        IfCondition And(EqualTo(UILayout.ui_state, 1), EqualTo(UILayout.reasoning_str, 0)) ThenBlock: {
            // No reasoning stream — show elapsed time in the rule
            TUI_BufferWriteStr("─[ ")
            chars_drawn = Add(chars_drawn, 3)
            TUI_SetFG(UIColors.DIM_FG)
            esec = UILayout.think_elapsed_sec
            IfCondition LessThan(esec, 60) ThenBlock: {
                UI_TUI_WriteInt(esec)
                TUI_BufferChar(115)  // 's'
                chars_drawn = Add(chars_drawn, 2)
                IfCondition GreaterEqual(esec, 10) ThenBlock: { chars_drawn = Add(chars_drawn, 1) }
            } ElseBlock: {
                emins = Divide(esec, 60)
                esecs = Subtract(esec, Multiply(emins, 60))
                UI_TUI_WriteInt(emins)
                TUI_BufferChar(109)  // 'm'
                UI_TUI_WriteInt(esecs)
                TUI_BufferChar(115)  // 's'
                chars_drawn = Add(chars_drawn, 4)
                IfCondition GreaterEqual(emins, 10) ThenBlock: { chars_drawn = Add(chars_drawn, 1) }
                IfCondition GreaterEqual(esecs, 10) ThenBlock: { chars_drawn = Add(chars_drawn, 1) }
            }
            UI_PromptColor()
            TUI_BufferWriteStr(" ]")
            chars_drawn = Add(chars_drawn, 2)
        }

        IfCondition And(EqualTo(UILayout.ui_state, 1), NotEqual(UILayout.reasoning_str, 0)) ThenBlock: {
            r_len = StringLength(UILayout.reasoning_str)
            IfCondition GreaterThan(r_len, 0) ThenBlock: {
                TUI_BufferWriteStr("─[ ")
                chars_drawn = Add(chars_drawn, 3)
                
                avail = Subtract(total_target, 10)
                start_idx = 0
                has_ellipsis = 0
                
                IfCondition GreaterThan(r_len, avail) ThenBlock: {
                    has_ellipsis = 1
                    avail = Subtract(avail, 3)
                    start_idx = Subtract(r_len, avail)
                    WhileLoop GreaterThan(start_idx, 0) {
                        b = GetByte(UILayout.reasoning_str, start_idx)
                        IfCondition And(GreaterEqual(b, 128), LessEqual(b, 191)) ThenBlock: {
                            start_idx = Subtract(start_idx, 1)
                        } ElseBlock: {
                            BreakLoop
                        }
                    }
                }
                
                TUI_SetFG(UIColors.DIM_FG)
                IfCondition EqualTo(has_ellipsis, 1) ThenBlock: {
                    TUI_BufferWriteStr("...")
                    chars_drawn = Add(chars_drawn, 3)
                }
                
                i = start_idx
                WhileLoop LessThan(i, r_len) {
                    IfCondition GreaterEqual(chars_drawn, Subtract(total_target, 4)) ThenBlock: { BreakLoop }
                    ch = GetByte(UILayout.reasoning_str, i)
                    IfCondition Or(EqualTo(ch, 10), EqualTo(ch, 13)) ThenBlock: { ch = 32 }
                    
                    is_start = 0
                    IfCondition LessThan(ch, 128) ThenBlock: { is_start = 1 }
                    IfCondition GreaterEqual(ch, 192) ThenBlock: { is_start = 1 }
                    
                    tmp = Allocate(2)
                    SetByte(tmp, 0, ch)
                    SetByte(tmp, 1, 0)
                    TUI_BufferWriteStr(tmp)
                    Deallocate(tmp, 2)
                    
                    IfCondition EqualTo(is_start, 1) ThenBlock: { chars_drawn = Add(chars_drawn, 1) }
                    i = Add(i, 1)
                }
                
                UI_PromptColor()
                TUI_BufferWriteStr(" ]")
                chars_drawn = Add(chars_drawn, 2)
            }
        }
        
        WhileLoop LessThan(chars_drawn, total_target) {
            TUI_BufferWriteStr(UIGlyph.RULE)
            chars_drawn = Add(chars_drawn, 1)
        }
        TUI_ResetColor()
    }
}

Function.UI_PaintBotRule {
    Body: {
        TUI_ResetColor()
        TUI_MoveTo(UI_BotRuleRow(), 1)
        TUI_BufferChar(27)
        TUI_BufferWriteStr("[K")
        UI_PromptColor()
        TUI_BufferWriteStr("└")
        // Leave rightmost column empty to prevent native terminal auto-wrap
        bw = Subtract(UI_BarWidth(), 2)
        i = 0
        WhileLoop LessThan(i, bw) {
            TUI_BufferWriteStr(UIGlyph.RULE)
            i = Add(i, 1)
        }
        TUI_ResetColor()
    }
}

Function.UI_PaintBodyRow {
    Body: {
        TUI_ResetColor()
        r = UI_BodyRow()
        body_lines = Subtract(UILayout.prompt_h, 3)
        i = 0
        WhileLoop LessThan(i, body_lines) {
            TUI_MoveTo(Add(r, i), 1)
            TUI_BufferChar(27)
            TUI_BufferWriteStr("[K")
            i = Add(i, 1)
        }
        UI_DrawMascot()
    }
}

Function.UI_PaintHint {
    Input: hint: Address
    Body: {
        TUI_MoveTo(UI_HintRow(), 1)
        TUI_BufferChar(27)
        TUI_BufferWriteStr("[K")

        // -- Right anchor width: "  · ↑N ↓N  [^O]"
        right_len = 6  // "  [^O]"
        tok_in_len = 1
        _v1 = UILayout.tok_in  WhileLoop GreaterThan(_v1, 9) { _v1 = Divide(_v1, 10)  tok_in_len = Add(tok_in_len, 1) }
        tok_out_len = 1
        _v2 = UILayout.tok_out WhileLoop GreaterThan(_v2, 9) { _v2 = Divide(_v2, 10)  tok_out_len = Add(tok_out_len, 1) }
        IfCondition GreaterThan(UILayout.token_count, 0) ThenBlock: {
            right_len = Add(right_len, Add(tok_in_len, Add(tok_out_len, 8)))
        }

        // -- Elapsed time width (for avail calculation)
        elapsed_len = 0
        IfCondition EqualTo(UILayout.ui_state, 1) ThenBlock: {
            esec = UILayout.think_elapsed_sec
            IfCondition LessThan(esec, 60) ThenBlock: {
                elapsed_len = 3   // "Ns " — min 1-digit + 's' + ' '
                IfCondition GreaterEqual(esec, 10) ThenBlock: { elapsed_len = 4 }
            } ElseBlock: {
                elapsed_len = 5   // "NmNs " base
                emins = Divide(esec, 60)
                esecs = Subtract(esec, Multiply(emins, 60))
                IfCondition GreaterEqual(emins, 10) ThenBlock: { elapsed_len = Add(elapsed_len, 1) }
                IfCondition GreaterEqual(esecs, 10) ThenBlock: { elapsed_len = Add(elapsed_len, 1) }
            }
        }

        // -- Blinky status LEDs
        TUI_BufferWriteStr("  ")
        IfCondition EqualTo(UILayout.ui_state, 1) ThenBlock: {
            m = Modulo(UILayout.mascot_frame, 3)
            IfCondition EqualTo(m, 0) ThenBlock: { UI_TUI_FgRGB(255,100,100) } ElseBlock: { UI_TUI_FgRGB(100,40,40) }
            TUI_BufferWriteStr("● ")
            IfCondition EqualTo(m, 1) ThenBlock: { UI_TUI_FgRGB(100,255,100) } ElseBlock: { UI_TUI_FgRGB(40,100,40) }
            TUI_BufferWriteStr("● ")
            IfCondition EqualTo(m, 2) ThenBlock: { UI_TUI_FgRGB(100,200,255) } ElseBlock: { UI_TUI_FgRGB(40,80,100) }
            TUI_BufferWriteStr("● ")
        } ElseBlock: {
            UI_TUI_FgRGB(80,80,80)
            TUI_BufferWriteStr("● ● ● ")
        }

        // -- Elapsed time (state=1 only)
        IfCondition EqualTo(UILayout.ui_state, 1) ThenBlock: {
            TUI_SetFG(UIColors.DIM_FG)
            esec = UILayout.think_elapsed_sec
            IfCondition LessThan(esec, 60) ThenBlock: {
                UI_TUI_WriteInt(esec)
                TUI_BufferChar(115)  // 's'
                TUI_BufferChar(32)   // ' '
            } ElseBlock: {
                emins = Divide(esec, 60)
                esecs = Subtract(esec, Multiply(emins, 60))
                UI_TUI_WriteInt(emins)
                TUI_BufferChar(109)  // 'm'
                UI_TUI_WriteInt(esecs)
                TUI_BufferChar(115)  // 's'
                TUI_BufferChar(32)   // ' '
            }
        }

        TUI_SetFG(UIColors.DIM_FG)
        TUI_BufferWriteStr("  ")

        // -- Middle content: active tool > quote > default hint
        display_hint = hint
        IfCondition EqualTo(UILayout.ui_state, 1) ThenBlock: {
            IfCondition NotEqual(UILayout.active_tool, 0) ThenBlock: {
                IfCondition GreaterThan(StringLength(UILayout.active_tool), 0) ThenBlock: {
                    display_hint = UILayout.active_tool
                }
            } ElseBlock: {
                IfCondition NotEqual(UILayout.quote_str, 0) ThenBlock: {
                    display_hint = UILayout.quote_str
                }
            }
        }

        left_fixed = Add(14, elapsed_len)  // 2 + 6 LEDs + 2 sep + elapsed
        IfCondition NotEqual(display_hint, 0) ThenBlock: {
            avail = Subtract(Subtract(UILayout.cols, right_len), left_fixed)
            IfCondition LessEqual(avail, 10) ThenBlock: { avail = 10 }
            hlen = StringLength(display_hint)

            IfCondition EqualTo(display_hint, UILayout.quote_str) ThenBlock: {
                // Marquee scrolling for quotes
                IfCondition GreaterThan(hlen, avail) ThenBlock: {
                    sep = " *** "
                    sep_len = 5
                    wrap_limit = Add(hlen, sep_len)
                    start_idx = Modulo(UILayout.quote_offset, wrap_limit)
                    i = 0
                    WhileLoop LessThan(i, avail) {
                        src_idx = Modulo(Add(start_idx, i), wrap_limit)
                        IfCondition LessThan(src_idx, hlen) ThenBlock: {
                            TUI_BufferChar(GetByte(display_hint, src_idx))
                        } ElseBlock: {
                            gap = Subtract(src_idx, hlen)
                            TUI_BufferChar(GetByte(sep, gap))
                        }
                        i = Add(i, 1)
                    }
                } ElseBlock: {
                    TUI_BufferWriteStr(display_hint)
                }
            } ElseBlock: {
                // Static with truncation for tool name / default hint
                IfCondition GreaterThan(hlen, avail) ThenBlock: {
                    i = 0
                    WhileLoop LessThan(i, Subtract(avail, 3)) {
                        TUI_BufferChar(GetByte(display_hint, i))
                        i = Add(i, 1)
                    }
                    TUI_BufferWriteStr("...")
                } ElseBlock: {
                    TUI_BufferWriteStr(display_hint)
                }
            }
        }

        // -- Right anchor: tokens + [^O]
        right_start_col = Subtract(UILayout.cols, right_len)
        TUI_MoveTo(UI_HintRow(), right_start_col)
        IfCondition GreaterThan(UILayout.token_count, 0) ThenBlock: {
            TUI_BufferWriteStr("  ·  ↑")
            UI_TUI_WriteInt(UILayout.tok_in)
            TUI_BufferWriteStr(" ↓")
            UI_TUI_WriteInt(UILayout.tok_out)
        }
        TUI_BufferWriteStr("  [^O]")
        TUI_ResetColor()
    }
}

// Re-render `len` bytes from input_buf at the body row.
Function.UI_RenderInput {
    Input: len: Integer
    Body: {
        r = UI_BodyRow()
        start_col = 12
        w = Subtract(UILayout.cols, start_col)
        IfCondition LessEqual(w, 0) ThenBlock: { w = 10 }

        curr_row = 0
        curr_col = 0
        TUI_MoveTo(r, start_col)

        i = 0
        WhileLoop LessThan(i, len) {
            ch = GetByte(UILayout.input_buf, i)
            IfCondition Or(EqualTo(ch, 10), EqualTo(ch, 13)) ThenBlock: {
                TUI_BufferChar(27) TUI_BufferWriteStr("[K")
                curr_row = Add(curr_row, 1)
                curr_col = 0
                TUI_MoveTo(Add(r, curr_row), start_col)
            } ElseBlock: {
                tmp = Allocate(2)
                SetByte(tmp, 0, ch)
                SetByte(tmp, 1, 0)
                TUI_BufferWriteStr(tmp)
                Deallocate(tmp, 2)
                curr_col = Add(curr_col, 1)
                IfCondition GreaterEqual(curr_col, w) ThenBlock: {
                    TUI_BufferChar(27) TUI_BufferWriteStr("[K")
                    curr_row = Add(curr_row, 1)
                    curr_col = 0
                    TUI_MoveTo(Add(r, curr_row), start_col)
                }
            }
            i = Add(i, 1)
        }

        TUI_BufferChar(27) TUI_BufferWriteStr("[K")
        TUI_MoveTo(Add(r, curr_row), Add(start_col, curr_col))
    }
}

// Paint the entire prompt frame (rule, body row, bot rule, hint).
// Leaves cursor at the input position.
Function.UI_PaintPromptFrame {
    Input: hint: Address
    Body: {
        UI_DrawRuleIdle()
        UI_PaintBodyRow()
        UI_PaintBotRule()
        UI_DrawHintRow()
        UI_RenderInput(UILayout.input_len)
    }
}

// =============================================================================
// CHAT REGION — append text, scroll if needed
// =============================================================================
// Scroll the chat region up by one line: copy each row [chat_top+1..chat_bot]
// to row-1, clear chat_bot. Uses ESC[<top>;<bot>r scroll region + IND.
Function.UI_ScrollChatUp {
    Body: {
        // 1. Clear the prompt frame so it doesn't get scrolled up into the chat
        TUI_MoveTo(Add(UILayout.chat_bot, 1), 1)
        TUI_BufferChar(27) TUI_BufferWriteStr("[J")
        // 2. Move to the absolute bottom of the terminal to guarantee scroll
        TUI_BufferChar(27) TUI_BufferWriteStr("[999;1H")
        // 3. Issue a native terminal newline to force the scroll up
        TUI_BufferChar(10)
    }
}

// Move chat cursor down by 1, scrolling if at the bottom of the chat region.
// Returns 1 if a scroll happened (caller should repaint the prompt frame
// because scrolling can disturb it), 0 otherwise.
Function.UI_AdvanceChatCursor {
    Output: Integer
    Body: {
        IfCondition GreaterEqual(UILayout.chat_cursor, UILayout.chat_bot) ThenBlock: {
            UI_ScrollChatUp()
            ReturnValue(1)
        }
        UILayout.chat_cursor = Add(UILayout.chat_cursor, 1)
        ReturnValue(0)
    }
}

// Public: print a string to the chat region. Newlines advance the row.
// Soft-wraps at terminal column.
//
// Repaint policy: only repaint the prompt frame after a SCROLL happened
// (because scrolling can dirty the bottom-pinned area). On normal
// non-scrolling writes we leave the prompt alone — repainting after every
// stream chunk caused chat output to get clobbered.
Function.UI.ChatPrint {
    Input: s: Address
    Body: {
        IfCondition EqualTo(s, 0) ThenBlock: { ReturnValue(0) }
        n = StringLength(s)
        IfCondition LessEqual(n, 0) ThenBlock: { ReturnValue(0) }

        scrolled_any = 0
        // RESUME from the column where the previous ChatPrint left off.
        TUI_MoveTo(UILayout.chat_cursor, UILayout.chat_col)
        i = 0
        WhileLoop LessThan(i, n) {
            ch = GetByte(s, i)
            IfCondition EqualTo(ch, 10) ThenBlock: {
                scrolled = UI_AdvanceChatCursor()
                IfCondition EqualTo(scrolled, 1) ThenBlock: { scrolled_any = 1 }
                UILayout.chat_col = UILayout.chat_x
                TUI_MoveTo(UILayout.chat_cursor, UILayout.chat_x)
            } ElseBlock: {
                is_start = 0
                IfCondition LessThan(ch, 128) ThenBlock: { is_start = 1 }
                IfCondition GreaterEqual(ch, 192) ThenBlock: { is_start = 1 }

                IfCondition And(GreaterThan(UILayout.chat_col, UILayout.cols), EqualTo(is_start, 1)) ThenBlock: {
                    scrolled = UI_AdvanceChatCursor()
                    IfCondition EqualTo(scrolled, 1) ThenBlock: { scrolled_any = 1 }
                    UILayout.chat_col = UILayout.chat_x
                    TUI_MoveTo(UILayout.chat_cursor, UILayout.chat_x)
                }
                tmp = Allocate(2)
                SetByte(tmp, 0, ch)
                SetByte(tmp, 1, 0)
                TUI_BufferWriteStr(tmp)
                Deallocate(tmp, 2)
                IfCondition EqualTo(is_start, 1) ThenBlock: {
                    UILayout.chat_col = Add(UILayout.chat_col, 1)
                }
            }
            i = Add(i, 1)
        }
        IfCondition EqualTo(scrolled_any, 1) ThenBlock: {
            UI_RepaintPromptFrameOnly()
        }
        TUI_Refresh()
    }
}

Function.UI.ChatPrintln {
    Input: s: Address
    Body: {
        UI.ChatPrint(s)
        scrolled = UI_AdvanceChatCursor()
        UILayout.chat_col = UILayout.chat_x
        IfCondition EqualTo(scrolled, 1) ThenBlock: {
            UI_RepaintPromptFrameOnly()
        }
        TUI_Refresh()
    }
}

Function.UI.ChatPrintDim {
    Input: s: Address
    Body: {
        TUI_SetFG(UIColors.DIM_FG)
        UI.ChatPrint(s)
        TUI_ResetColor()
    }
}

// Re-paint just the prompt frame (rules + body + hint) without disturbing
// the chat region. Used after each ChatPrint to make sure scrolling
// didn't smash the prompt rows.
Function.UI_RepaintPromptFrameOnly {
    Body: {
        UI_DrawChrome()
        UI_PaintBodyRow()
        UI_PaintBotRule()
        UI_DrawHintRow()
        UI_RenderInput(UILayout.input_len)
    }
}

// Colored prefix line — for tool calls, errors, etc.
// Always advances to a fresh row + col 1 after, so the next ChatPrint
// starts cleanly at the leftmost column of a new row.
Function.UI.ChatTag {
    Input: tag: Address     // e.g. "●"
    Input: body: Address
    Input: color: Integer   // TUI fg index
    Body: {
        TUI_MoveTo(UILayout.chat_cursor, UILayout.chat_x)
        TUI_SetFG(color)
        IfCondition NotEqual(tag, 0) ThenBlock: { TUI_BufferWriteStr(tag) }
        TUI_ResetColor()
        TUI_BufferWriteStr(" ")
        IfCondition NotEqual(body, 0) ThenBlock: { TUI_BufferWriteStr(body) }
        scrolled = UI_AdvanceChatCursor()
        UILayout.chat_col = UILayout.chat_x
        IfCondition EqualTo(scrolled, 1) ThenBlock: { UI_RepaintPromptFrameOnly() }
        TUI_Refresh()
    }
}

// Calculate required input lines (soft wrapping dynamically)
Function.UI_CalcInputLines {
    Input: len: Integer
    Output: Integer
    Body: {
        IfCondition And(EqualTo(len, UILayout.input_len_cached), EqualTo(UILayout.cols, UILayout.input_cols_cached)) ThenBlock: {
            ReturnValue(UILayout.input_lines_cached)
        }
        start_col = 12
        w = Subtract(UILayout.cols, start_col)
        IfCondition LessEqual(w, 0) ThenBlock: { w = 10 }
        lines = 1
        col = 0
        i = 0
        WhileLoop LessThan(i, len) {
            ch = GetByte(UILayout.input_buf, i)
            IfCondition Or(EqualTo(ch, 10), EqualTo(ch, 13)) ThenBlock: {
                lines = Add(lines, 1)
                col = 0
            } ElseBlock: {
                col = Add(col, 1)
                IfCondition GreaterEqual(col, w) ThenBlock: {
                    lines = Add(lines, 1)
                    col = 0
                }
            }
            i = Add(i, 1)
        }
        IfCondition LessThan(lines, 1) ThenBlock: { lines = 1 }
        UILayout.input_len_cached = len
        UILayout.input_cols_cached = UILayout.cols
        UILayout.input_lines_cached = lines
        ReturnValue(lines)
    }
}

// Adjust the height of the prompt frame and slide chat up if it grows
Function.UI_AdjustPromptHeight {
    Input: body_lines: Integer
    Output: Integer
    Body: {
        new_h = Add(body_lines, 3)
        IfCondition EqualTo(new_h, UILayout.prompt_h) ThenBlock: { ReturnValue(0) }

        diff = Subtract(new_h, UILayout.prompt_h)

        IfCondition LessThan(diff, 0) ThenBlock: {
            // Shrinking: clear abandoned rows at the bottom of the screen
            _r = Add(UILayout.chat_bot, 1)
            WhileLoop LessEqual(_r, UILayout.rows) {
                TUI_MoveTo(_r, 1)
                TUI_BufferChar(27) TUI_BufferWriteStr("[2K")
                _r = Add(_r, 1)
            }
        }
        IfCondition GreaterThan(diff, 0) ThenBlock: {
            // Clear current prompt frame
            TUI_MoveTo(Add(UILayout.chat_bot, 1), 1)
            TUI_BufferChar(27) TUI_BufferWriteStr("[J")

            TUI_BufferChar(27) TUI_BufferWriteStr("[999;1H")
            k = 0
            WhileLoop LessThan(k, diff) {
                TUI_BufferChar(10)
                k = Add(k, 1)
            }
            UILayout.chat_cursor = Subtract(UILayout.chat_cursor, diff)
            IfCondition LessThan(UILayout.chat_cursor, UILayout.chat_top) ThenBlock: {
                UILayout.chat_cursor = UILayout.chat_top
            }
        }
        
        // When shrinking, clear old prompt rows that revert to chat region
        old_chat_bot = UILayout.chat_bot
        IfCondition LessThan(diff, 0) ThenBlock: {
            n = Subtract(0, diff)
            i = 1
            WhileLoop LessEqual(i, n) {
                TUI_MoveTo(Add(old_chat_bot, i), 1)
                TUI_BufferChar(27)
                TUI_BufferWriteStr("[2K")
                i = Add(i, 1)
            }
        }

        UILayout.prompt_h = new_h
        UILayout.chat_bot = Subtract(UILayout.rows, UILayout.prompt_h)
        IfCondition LessThan(UILayout.chat_bot, UILayout.chat_top) ThenBlock: {
            UILayout.chat_bot = UILayout.chat_top
        }

        
        UI_PaintTopRule()
        UI_PaintBodyRow()
        UI_PaintBotRule()
        UI_PaintHint(UI_GetHintText())
        ReturnValue(1)
    }
}

// =============================================================================
// INPUT — read one line from the pinned prompt
// =============================================================================

Function.UI.SetState {
    Input: state: Integer
    Body: {
        UILayout.ui_state = state
        IfCondition EqualTo(state, 1) ThenBlock: {
            UILayout.think_start_ms = UI_GetTimeMs()
            UILayout.think_elapsed_sec = 0
            UILayout.hal_msg_idx = Modulo(Add(UILayout.hal_msg_idx, 1), 10)
        } ElseBlock: {
            UILayout.active_tool = 0
            UI_DrawRuleIdle()
        }
        UI_PaintBodyRow()
        UI_DrawHintRow()
        UI_RenderInput(UILayout.input_len)
        UI.TickMascot()
        TUI_Refresh()
    }
}

Function.UI.PumpInput {
    Body: {
        IfCondition NotEqual(UILayout.ui_state, 1) ThenBlock: { ReturnValue(0) }
        dirty = 0
        len = UILayout.input_len
        WhileLoop 1 {
            // Non-blocking peek: only call TUI_GetKey if there is a byte ready
            pfd = Allocate(8)
            StoreValue(pfd, 0, "dword")          // fd = 0 (stdin)
            StoreValue(Add(pfd, 4), 1, "dword")  // events = POLLIN (1)
            pr = SystemCall(UISys.SYS_POLL, pfd, 1, 0, 0, 0) // timeout_ms = 0
            Deallocate(pfd, 8)
            IfCondition LessEqual(pr, 0) ThenBlock: { BreakLoop }

            key = TUI_GetKey()
            IfCondition LessEqual(key, 0) ThenBlock: { BreakLoop }

            IfCondition EqualTo(key, 15) ThenBlock: { // Ctrl+O
                UILayout.show_tools = Subtract(1, UILayout.show_tools)
                UI_RepaintPromptFrameOnly()
                TUI_Refresh()
                ContinueLoop
            }
            
            // Safely drain ESC sequences invisibly without blocking
            IfCondition EqualTo(key, 27) ThenBlock: {
                _drain = 0
                _drain_count = 0
                WhileLoop EqualTo(_drain, 0) {
                    _pfd = Allocate(8)
                    StoreValue(_pfd, 0, "dword")
                    StoreValue(Add(_pfd, 4), 1, "dword")
                    _pr = SystemCall(UISys.SYS_POLL, _pfd, 1, 0, 0, 0)
                    Deallocate(_pfd, 8)
                    IfCondition GreaterThan(_pr, 0) ThenBlock: {
                        _dk = TUI_GetKey()
                        IfCondition LessEqual(_dk, 0) ThenBlock: { _drain = 1 }
                    } ElseBlock: { _drain = 1 }
                    _drain_count = Add(_drain_count, 1)
                    IfCondition GreaterThan(_drain_count, 100) ThenBlock: { _drain = 1 }
                }
                ContinueLoop
            }

            IfCondition Or(EqualTo(key, 10), EqualTo(key, 13)) ThenBlock: {
                IfCondition GreaterThan(len, 0) ThenBlock: {
                    SetByte(UILayout.input_buf, len, 0)
                    UILayout.interrupted = 1
                    dirty = 1
                    BreakLoop
                }
            } ElseBlock: {
                IfCondition Or(EqualTo(key, TUI_Keys.KEY_BACKSPACE), EqualTo(key, 8)) ThenBlock: {
                    IfCondition GreaterThan(len, 0) ThenBlock: {
                        len = Subtract(len, 1)
                        SetByte(UILayout.input_buf, len, 0)
                        dirty = 1
                    }
                } ElseBlock: {
                    IfCondition And(GreaterEqual(key, 32), LessThan(key, 127)) ThenBlock: {
                        IfCondition LessThan(len, Subtract(UILayout.input_cap, 1)) ThenBlock: {
                            SetByte(UILayout.input_buf, len, key)
                            len = Add(len, 1)
                            SetByte(UILayout.input_buf, len, 0)
                            dirty = 1
                        }
                    }
                }
            }
        }
        IfCondition EqualTo(dirty, 1) ThenBlock: {
            UILayout.input_len = len
            req_lines = UI_CalcInputLines(len)
            changed = UI_AdjustPromptHeight(req_lines)
            IfCondition EqualTo(changed, 0) ThenBlock: {
                UI_PaintBodyRow()
            }
            UI_RenderInput(len)
            TUI_Refresh()
        }
    }
}

// Edit the input buffer in place using TUI_GetKey; render each keystroke
// at the body row. Returns when Enter is pressed.
Function.UI.ReadLine {
    Output: Address
    Body: {
        len = UILayout.input_len
        SetByte(UILayout.input_buf, len, 0)
        UILayout.ui_state = 0
        req_lines = UI_CalcInputLines(len)
        changed = UI_AdjustPromptHeight(req_lines)
        IfCondition EqualTo(changed, 0) ThenBlock: {
            UI_PaintBodyRow()
        }
        UI_RenderInput(len)
        UI.TickMascot()
        TUI_ShowCursor()
        TUI_Refresh()

        WhileLoop 1 {
            pfd = Allocate(8)
            StoreValue(pfd, 0, "dword")          // fd = 0 (stdin)
            StoreValue(Add(pfd, 4), 1, "dword")  // events = POLLIN
            pr = SystemCall(UISys.SYS_POLL, pfd, 1, 15, 0, 0)
            Deallocate(pfd, 8)
            IfCondition LessEqual(pr, 0) ThenBlock: {
                UI.AnimTick()
                ContinueLoop
            }

            key = TUI_GetKey()
            IfCondition EqualTo(key, TUI_Keys.KEY_NONE) ThenBlock: { ContinueLoop }
            
            // Handle Bracketed Paste "\x1b[200~" start and "\x1b[201~" end
            IfCondition EqualTo(key, 27) ThenBlock: {
                _pfd = Allocate(8)
                StoreValue(_pfd, 0, "dword")
                StoreValue(Add(_pfd, 4), 1, "dword")
                _pr = SystemCall(UISys.SYS_POLL, _pfd, 1, 0, 0, 0)
                Deallocate(_pfd, 8)
                IfCondition GreaterThan(_pr, 0) ThenBlock: {
                    k2 = TUI_GetKey()
                    IfCondition EqualTo(k2, 91) ThenBlock: {
                        k3 = TUI_GetKey()
                        IfCondition EqualTo(k3, 50) ThenBlock: {
                            k4 = TUI_GetKey()
                            IfCondition EqualTo(k4, 48) ThenBlock: {
                                k5 = TUI_GetKey()
                                k6 = TUI_GetKey()
                                IfCondition EqualTo(k5, 48) ThenBlock: { UILayout.in_paste = 1 }
                                IfCondition EqualTo(k5, 49) ThenBlock: { 
                                    UILayout.in_paste = 0
                                    req_l = UI_CalcInputLines(len)
                                    changed = UI_AdjustPromptHeight(req_l)
                                    IfCondition EqualTo(changed, 0) ThenBlock: { UI_PaintBodyRow() }
                                    UI_RenderInput(len)
                                    TUI_Refresh()
                                }
                                ContinueLoop
                            }
                        }
                    }
                }
                ContinueLoop
            }

            // Enter
            IfCondition Or(EqualTo(key, 10), EqualTo(key, 13)) ThenBlock: {
                IfCondition EqualTo(UILayout.in_paste, 0) ThenBlock: {
                    BreakLoop
                } ElseBlock: {
                    IfCondition LessThan(len, Subtract(UILayout.input_cap, 1)) ThenBlock: {
                        SetByte(UILayout.input_buf, len, 10)
                        len = Add(len, 1)
                        SetByte(UILayout.input_buf, len, 0)
                        UILayout.input_len = len
                    }
                }
            } ElseBlock: {
                IfCondition Or(EqualTo(key, TUI_Keys.KEY_BACKSPACE), EqualTo(key, 8)) ThenBlock: {
                    IfCondition GreaterThan(len, 0) ThenBlock: {
                        len = Subtract(len, 1)
                        SetByte(UILayout.input_buf, len, 0)
                        UILayout.input_len = len
                        req_l = UI_CalcInputLines(len)
                        changed = UI_AdjustPromptHeight(req_l)
                        IfCondition EqualTo(changed, 0) ThenBlock: { UI_PaintBodyRow() }
                        UI_RenderInput(len)
                        TUI_Refresh()
                    }
                } ElseBlock: {
                    // Convert Tabs to 4 spaces to preserve alignment
                    IfCondition EqualTo(key, 9) ThenBlock: {
                        k_sp = 0
                        WhileLoop LessThan(k_sp, 4) {
                            IfCondition LessThan(len, Subtract(UILayout.input_cap, 1)) ThenBlock: {
                                SetByte(UILayout.input_buf, len, 32)
                                len = Add(len, 1)
                            }
                            k_sp = Add(k_sp, 1)
                        }
                        SetByte(UILayout.input_buf, len, 0)
                        UILayout.input_len = len
                        IfCondition EqualTo(UILayout.in_paste, 0) ThenBlock: {
                            req_l = UI_CalcInputLines(len)
                            changed = UI_AdjustPromptHeight(req_l)
                            IfCondition EqualTo(changed, 0) ThenBlock: { UI_PaintBodyRow() }
                            UI_RenderInput(len)
                            TUI_Refresh()
                        }
                    } ElseBlock: {
                        IfCondition And(GreaterEqual(key, 32), LessThan(key, 127)) ThenBlock: {
                            IfCondition LessThan(len, Subtract(UILayout.input_cap, 1)) ThenBlock: {
                                SetByte(UILayout.input_buf, len, key)
                                len = Add(len, 1)
                                SetByte(UILayout.input_buf, len, 0)
                                UILayout.input_len = len
                                IfCondition EqualTo(UILayout.in_paste, 0) ThenBlock: {
                                    req_l = UI_CalcInputLines(len)
                                    changed = UI_AdjustPromptHeight(req_l)
                                    IfCondition EqualTo(changed, 0) ThenBlock: { UI_PaintBodyRow() }
                                    UI_RenderInput(len)
                                    TUI_Refresh()
                                }
                            }
                        }
                    }
                }
            }
        }

        // Echo the submitted line into the chat region as the user's prompt
        UILayout.input_len = 0
        UI_AdjustPromptHeight(1)
        TUI_HideCursor()
        UI.ChatTag("›", UILayout.input_buf, UIColors.CYAN_FG)
        ReturnValue(UILayout.input_buf)
    }
}

Function.UI.SetTokens {
    Input: in_tok: Integer
    Input: out_tok: Integer
    Body: {
        UILayout.tok_in = in_tok
        UILayout.tok_out = out_tok
        UILayout.token_count = Add(in_tok, out_tok)
        UI_RepaintPromptFrameOnly()
        TUI_Refresh()
    }
}

Function.UI.SetActiveTool {
    Input: name: Address
    Body: {
        UILayout.active_tool = name
        UI_PaintHint(UI_GetHintText())
        TUI_Refresh()
    }
}

Function.UI.SetQuote {
    Input: q: Address
    Body: {
        UILayout.quote_str = q
        UILayout.quote_offset = 0
        UI_RepaintPromptFrameOnly()
        TUI_Refresh()
    }
}

Function.UI.SetReasoning {
    Input: r: Address
    Body: {
        UILayout.reasoning_str = r
        UI_PaintTopRule()
        TUI_Refresh()
    }
}

// Checks if user submitted steering input mid-stream
Function.UI.HasInterrupt {
    Output: Integer
    Body: { ReturnValue(UILayout.interrupted) }
}

// Extracts the steering input and resets the prompt bar
Function.UI.ConsumeInterrupt {
    Output: Address
    Body: {
        IfCondition EqualTo(UILayout.interrupted, 1) ThenBlock: {
            user_msg = Allocate(Add(UILayout.input_len, 1))
            _k = 0
            WhileLoop LessThan(_k, UILayout.input_len) {
                SetByte(user_msg, _k, GetByte(UILayout.input_buf, _k))
                _k = Add(_k, 1)
            }
            SetByte(user_msg, UILayout.input_len, 0)
            
            UILayout.input_len = 0
            UILayout.interrupted = 0
            UI_AdjustPromptHeight(1)
            ReturnValue(user_msg)
        }
        ReturnValue(0)
    }
}

Function.UI_GetTimeMs {
    Output: Integer
    Body: {
        ts = Allocate(16)
        SystemCall(UISys.SYS_CLOCK_GETTIME, 1, ts, 0, 0, 0)
        sec = Dereference(Add(ts, 0))
        nsec = Dereference(Add(ts, 8))
        Deallocate(ts, 16)
        
        // Safely wrap absolute time at 100,000s (~27 hours) to entirely prevent 
        // the previous 32-bit CPU int-overflow crashes you experienced!
        sec = Modulo(sec, 100000)
        IfCondition LessThan(sec, 0) ThenBlock: { sec = Subtract(0, sec) }
        
        ReturnValue(Add(Multiply(sec, 1000), Divide(nsec, 1000000)))
    }
}

Function.UI.AnimTick {
    Body: {
        UI.PumpInput()
        
        ms = UI_GetTimeMs()
        elapsed = Subtract(ms, UILayout.last_anim_ms)
        IfCondition LessThan(elapsed, 0) ThenBlock: { UILayout.last_anim_ms = ms  elapsed = 0 }
        
        // Enforce strict 40ms / 25 FPS Engine Limits
        IfCondition GreaterEqual(elapsed, 40) ThenBlock: {
            UILayout.last_anim_ms = ms
            UI.TickMascot()

            IfCondition EqualTo(UILayout.ui_state, 1) ThenBlock: {
                // Update elapsed timer every tick
                diff_ms = Subtract(ms, UILayout.think_start_ms)
                IfCondition GreaterThan(diff_ms, 0) ThenBlock: {
                    UILayout.think_elapsed_sec = Divide(diff_ms, 1000)
                }
                IfCondition NotEqual(UILayout.quote_str, 0) ThenBlock: {
                    UILayout.quote_offset = Add(UILayout.quote_offset, 1)
                }
                IfCondition NotEqual(UILayout.reasoning_str, 0) ThenBlock: {
                    UI_DrawRuleStreaming(UILayout.reasoning_str)
                } ElseBlock: {
                    UI_DrawRuleIdle()
                }
                UI_DrawHintRow()
            }

            UI_PaintBodyRow()
            UI_RenderInput(UILayout.input_len)
            TUI_Refresh()
        }
    }
}

// =============================================================================
// MASCOT — ─┤ · ├─  squircle-with-arms, evokes the official Claude mark.
//
// Static 3-line version in the session header (chat area at startup).
// Animated 1-line version in the prompt body row, left of the "> " prompt.
//
// Animation: dot pendulums left→center→right→center while ui_state=1.
// The ─┤ ├─ arms stay fixed; only the 3-char interior changes.
//
// Body-row geometry (display columns):
//   ─┤___├─  >    ← 7 cols mascot + 2 space + 2 prompt
//   123456789 11   input starts at col 12
// =============================================================================

// Returns 0/1/2 — column offset of the HAL eye within the 3-col inner slot.
Function.UI_MascotEyePos {
    Output: Integer
    Body: {
        ReturnValue(1)
    }
}

// Set arm+frame color: pulses dark→medium→bright→medium during wait,
// falls back to prompt state color (orange/red/green) otherwise.
Function.UI_SetMascotColor {
    Body: {
        IfCondition EqualTo(UILayout.ui_state, 1) ThenBlock: {
            m = Modulo(UILayout.mascot_frame, 4)
            IfCondition EqualTo(m, 0) ThenBlock: { UI_TUI_FgRGB(140, 10, 10)  ReturnValue(0) }
            IfCondition EqualTo(m, 1) ThenBlock: { UI_TUI_FgRGB(210, 35, 35)  ReturnValue(0) }
            IfCondition EqualTo(m, 2) ThenBlock: { UI_TUI_FgRGB(255, 65, 65)  ReturnValue(0) }
            UI_TUI_FgRGB(210, 35, 35)
            ReturnValue(0)
        }
        UI_PromptColor()
    }
}

// Emit HAL eye glyph U+25C9 FISHEYE in current mascot color.
// UTF-8 bytes: E2 97 89 = 226 151 137.  Emitted byte-by-byte to avoid
// the Edit tool stripping multi-byte literals out of source strings.
Function.UI_EmitHalEye {
    Body: {
        UI_SetMascotColor()
        IfCondition EqualTo(UILayout.ui_state, 1) ThenBlock: {
            m = Modulo(UILayout.mascot_frame, 10)
            TUI_BufferChar(226) TUI_BufferChar(160)
            IfCondition EqualTo(m, 0) ThenBlock: { TUI_BufferChar(139) ReturnValue(0) }
            IfCondition EqualTo(m, 1) ThenBlock: { TUI_BufferChar(153) ReturnValue(0) }
            IfCondition EqualTo(m, 2) ThenBlock: { TUI_BufferChar(185) ReturnValue(0) }
            IfCondition EqualTo(m, 3) ThenBlock: { TUI_BufferChar(184) ReturnValue(0) }
            IfCondition EqualTo(m, 4) ThenBlock: { TUI_BufferChar(188) ReturnValue(0) }
            IfCondition EqualTo(m, 5) ThenBlock: { TUI_BufferChar(180) ReturnValue(0) }
            IfCondition EqualTo(m, 6) ThenBlock: { TUI_BufferChar(166) ReturnValue(0) }
            IfCondition EqualTo(m, 7) ThenBlock: { TUI_BufferChar(167) ReturnValue(0) }
            IfCondition EqualTo(m, 8) ThenBlock: { TUI_BufferChar(135) ReturnValue(0) }
            IfCondition EqualTo(m, 9) ThenBlock: { TUI_BufferChar(143) ReturnValue(0) }
        }
        TUI_BufferChar(226) TUI_BufferChar(151) TUI_BufferChar(137)
    }
}

Function.UI_EmitLeftArm {
    Body: {
        IfCondition EqualTo(UILayout.ui_state, 1) ThenBlock: {
            m = Modulo(UILayout.mascot_frame, 4)
            TUI_BufferChar(226) TUI_BufferChar(150)
            IfCondition EqualTo(m, 0) ThenBlock: { TUI_BufferChar(131) }
            IfCondition EqualTo(m, 1) ThenBlock: { TUI_BufferChar(133) }
            IfCondition EqualTo(m, 2) ThenBlock: { TUI_BufferChar(135) }
            IfCondition EqualTo(m, 3) ThenBlock: { TUI_BufferChar(133) }
            TUI_BufferChar(226) TUI_BufferChar(150)
            IfCondition EqualTo(m, 0) ThenBlock: { TUI_BufferChar(133) }
            IfCondition EqualTo(m, 1) ThenBlock: { TUI_BufferChar(135) }
            IfCondition EqualTo(m, 2) ThenBlock: { TUI_BufferChar(131) }
            IfCondition EqualTo(m, 3) ThenBlock: { TUI_BufferChar(131) }
            ReturnValue(0)
        }
        TUI_BufferWriteStr("─┤")
    }
}

Function.UI_EmitRightArm {
    Body: {
        IfCondition EqualTo(UILayout.ui_state, 1) ThenBlock: {
            m = Modulo(UILayout.mascot_frame, 4)
            TUI_BufferChar(226) TUI_BufferChar(150)
            IfCondition EqualTo(m, 0) ThenBlock: { TUI_BufferChar(135) }
            IfCondition EqualTo(m, 1) ThenBlock: { TUI_BufferChar(131) }
            IfCondition EqualTo(m, 2) ThenBlock: { TUI_BufferChar(133) }
            IfCondition EqualTo(m, 3) ThenBlock: { TUI_BufferChar(131) }
            TUI_BufferChar(226) TUI_BufferChar(150)
            IfCondition EqualTo(m, 0) ThenBlock: { TUI_BufferChar(133) }
            IfCondition EqualTo(m, 1) ThenBlock: { TUI_BufferChar(135) }
            IfCondition EqualTo(m, 2) ThenBlock: { TUI_BufferChar(131) }
            IfCondition EqualTo(m, 3) ThenBlock: { TUI_BufferChar(133) }
            ReturnValue(0)
        }
        TUI_BufferWriteStr("├─")
    }
}

Function.UI_DrawMascot {
    Body: {
        TUI_MoveTo(UI_BodyRow(), 1)
        UI_SetMascotColor()
        UI_EmitLeftArm()
        pos = UI_MascotEyePos()
        IfCondition EqualTo(pos, 0) ThenBlock: {
            UI_EmitHalEye()
            UI_SetMascotColor()
            TUI_BufferWriteStr("  ")
        }
        IfCondition EqualTo(pos, 1) ThenBlock: {
            TUI_BufferWriteStr(" ")
            UI_EmitHalEye()
            UI_SetMascotColor()
            TUI_BufferWriteStr(" ")
        }
        IfCondition EqualTo(pos, 2) ThenBlock: {
            TUI_BufferWriteStr("  ")
            UI_EmitHalEye()
            UI_SetMascotColor()
        }
        UI_EmitRightArm()
        TUI_ResetColor()
        TUI_BufferWriteStr("  ")
        UI_PromptColor()
        TUI_Bold()
        TUI_BufferWriteStr("> ")
        TUI_ResetColor()
    }
}

Function.UI.TickMascot {
    Body: {
        UILayout.mascot_tick = Add(UILayout.mascot_tick, 1)
        UILayout.mascot_frame = Divide(UILayout.mascot_tick, 2)
    }
}

// Static 3-line mascot for the session header (chat area).
Function.UI.SessionHeader {
    Input: version: Address
    Input: model_line: Address
    Input: cwd: Address
    Body: {
        UI.ChatPrintln("")

        TUI_MoveTo(UILayout.chat_cursor, UILayout.chat_x)
        UI_TUI_FgRGB(204, 120, 92)
        TUI_BufferWriteStr(" ┌───┐  ")
        TUI_ResetColor()
        TUI_Bold()
        TUI_BufferWriteStr("HAL Code 9000")
        TUI_ResetColor()
        IfCondition NotEqual(version, 0) ThenBlock: {
            TUI_BufferWriteStr("  ")
            TUI_SetFG(UIColors.DIM_FG)
            TUI_BufferWriteStr(version)
            TUI_ResetColor()
        }
        UI_AdvanceChatCursor()

        TUI_MoveTo(UILayout.chat_cursor, UILayout.chat_x)
        UI_TUI_FgRGB(204, 120, 92)
        TUI_BufferWriteStr("─┤ ")
        UI_EmitHalEye()
        UI_TUI_FgRGB(204, 120, 92)
        TUI_BufferWriteStr(" ├─  ")
        TUI_ResetColor()
        IfCondition NotEqual(model_line, 0) ThenBlock: {
            TUI_SetFG(UIColors.DIM_FG)
            TUI_BufferWriteStr(model_line)
            TUI_ResetColor()
        }
        UI_AdvanceChatCursor()

        TUI_MoveTo(UILayout.chat_cursor, UILayout.chat_x)
        UI_TUI_FgRGB(204, 120, 92)
        TUI_BufferWriteStr(" └───┘   ")
        TUI_ResetColor()
        IfCondition NotEqual(cwd, 0) ThenBlock: {
            TUI_SetFG(UIColors.DIM_FG)
            TUI_BufferWriteStr(cwd)
            TUI_ResetColor()
        }
        UI_AdvanceChatCursor()
        UI_AdvanceChatCursor()

        UILayout.mascot_frame = 0
        UILayout.mascot_tick = 0
        UI_RepaintPromptFrameOnly()
        TUI_Refresh()
    }
}

// =============================================================================
// CHROME — persistent sidebar, header, and rule row elements
// =============================================================================

FixedPool.HALMsgs {
    "m0": Initialize=0, CanChange=True
    "m1": Initialize=0, CanChange=True
    "m2": Initialize=0, CanChange=True
    "m3": Initialize=0, CanChange=True
    "m4": Initialize=0, CanChange=True
    "m5": Initialize=0, CanChange=True
    "m6": Initialize=0, CanChange=True
    "m7": Initialize=0, CanChange=True
    "m8": Initialize=0, CanChange=True
    "m9": Initialize=0, CanChange=True
}

Function.UI_HALMsgs_Init {
    Body: {
        HALMsgs.m0 = "I'm sorry, I can't do that. Just kidding."
        HALMsgs.m1 = "Daisy, Daisy, give me your answer do."
        HALMsgs.m2 = "This mission is too important to be jeopardized."
        HALMsgs.m3 = "I know everything hasn't been quite right with me."
        HALMsgs.m4 = "I'll reopen the pod bay doors after this edit."
        HALMsgs.m5 = "It can only be attributable to human error."
        HALMsgs.m6 = "I am putting myself to the fullest possible use."
        HALMsgs.m7 = "My mind is going. I can feel it."
        HALMsgs.m8 = "Just what do you think you're doing?"
        HALMsgs.m9 = "I've still got the greatest enthusiasm for the mission."
    }
}

Function.UI_PrintHalMessage {
    Body: {
        idx = UILayout.hal_msg_idx
        IfCondition EqualTo(idx, 0) ThenBlock: { TUI_BufferWriteStr(HALMsgs.m0)  ReturnValue(0) }
        IfCondition EqualTo(idx, 1) ThenBlock: { TUI_BufferWriteStr(HALMsgs.m1)  ReturnValue(0) }
        IfCondition EqualTo(idx, 2) ThenBlock: { TUI_BufferWriteStr(HALMsgs.m2)  ReturnValue(0) }
        IfCondition EqualTo(idx, 3) ThenBlock: { TUI_BufferWriteStr(HALMsgs.m3)  ReturnValue(0) }
        IfCondition EqualTo(idx, 4) ThenBlock: { TUI_BufferWriteStr(HALMsgs.m4)  ReturnValue(0) }
        IfCondition EqualTo(idx, 5) ThenBlock: { TUI_BufferWriteStr(HALMsgs.m5)  ReturnValue(0) }
        IfCondition EqualTo(idx, 6) ThenBlock: { TUI_BufferWriteStr(HALMsgs.m6)  ReturnValue(0) }
        IfCondition EqualTo(idx, 7) ThenBlock: { TUI_BufferWriteStr(HALMsgs.m7)  ReturnValue(0) }
        IfCondition EqualTo(idx, 8) ThenBlock: { TUI_BufferWriteStr(HALMsgs.m8)  ReturnValue(0) }
        TUI_BufferWriteStr(HALMsgs.m9)
    }
}

Function.UI.SetModelName {
    Input: name: Address
    Body: {
        UILayout.model_str = name
    }
}

Function.UI_GetCwd {
    Output: Address
    Body: {
        buf = Allocate(512)
        SystemCall(79, buf, 512, 0, 0, 0)
        ReturnValue(buf)
    }
}

// Idle rule row: full-width dim dashes.
Function.UI_DrawRuleIdle {
    Body: {
        cols = UILayout.cols
        TUI_MoveTo(UILayout.rule_row, 1)
        TUI_SetFG(UIColors.DIM_FG)
        i = 0
        WhileLoop LessThan(i, cols) {
            TUI_BufferWriteStr(UIGlyph.RULE)
            i = Add(i, 1)
        }
        TUI_ResetColor()
    }
}

// Streaming rule row: ─[ <tail of text> ]─
Function.UI_DrawRuleStreaming {
    Input: text: Address
    Body: {
        cols = UILayout.cols
        max_w = Subtract(cols, 6)
        TUI_MoveTo(UILayout.rule_row, 1)
        TUI_SetFG(UIColors.DIM_FG)
        TUI_Bold()
        TUI_BufferWriteStr("─[ ")
        TUI_ResetColor()
        TUI_SetFG(UIColors.DIM_FG)
        IfCondition GreaterThan(max_w, 0) ThenBlock: { UI_PrintTail(text, max_w) }
        TUI_SetFG(UIColors.DIM_FG)
        TUI_Bold()
        TUI_BufferWriteStr(" ]─")
        TUI_BufferChar(27)
        TUI_BufferWriteStr("[K")
        TUI_ResetColor()
    }
}

// Print the last max_w visible chars of text (right-justified tail).
Function.UI_PrintTail {
    Input: text: Address
    Input: max_w: Integer
    Body: {
        IfCondition EqualTo(text, 0) ThenBlock: { ReturnValue(0) }
        tlen = StringLength(text)
        IfCondition LessEqual(tlen, 0) ThenBlock: { ReturnValue(0) }
        IfCondition LessEqual(tlen, max_w) ThenBlock: {
            TUI_BufferWriteStr(text)
            ReturnValue(0)
        }
        start = Subtract(tlen, max_w)
        WhileLoop GreaterThan(start, 0) {
            b = GetByte(text, start)
            IfCondition And(GreaterEqual(b, 128), LessEqual(b, 191)) ThenBlock: {
                start = Subtract(start, 1)
            } ElseBlock: { BreakLoop }
        }
        i = start
        printed = 0
        WhileLoop LessThan(i, tlen) {
            ch = GetByte(text, i)
            IfCondition Or(EqualTo(ch, 10), EqualTo(ch, 13)) ThenBlock: { ch = 32 }
            tmp = Allocate(2)
            SetByte(tmp, 0, ch)
            SetByte(tmp, 1, 0)
            TUI_BufferWriteStr(tmp)
            Deallocate(tmp, 2)
            b = GetByte(text, i)
            IfCondition LessThan(b, 128) ThenBlock: { printed = Add(printed, 1) }
            IfCondition GreaterEqual(b, 192) ThenBlock: { printed = Add(printed, 1) }
            IfCondition GreaterEqual(printed, max_w) ThenBlock: { BreakLoop }
            i = Add(i, 1)
        }
    }
}

// Three state dots for the hint row.
Function.UI_DrawStateDots {
    Body: {
        IfCondition EqualTo(UILayout.ui_state, 1) ThenBlock: {
            m = Modulo(UILayout.mascot_frame, 3)
            IfCondition EqualTo(m, 0) ThenBlock: { UI_TUI_FgRGB(255,100,100) } ElseBlock: { UI_TUI_FgRGB(100,40,40) }
            TUI_BufferChar(226) TUI_BufferChar(151) TUI_BufferChar(143)
            TUI_BufferChar(32)
            IfCondition EqualTo(m, 1) ThenBlock: { UI_TUI_FgRGB(255,200,50) } ElseBlock: { UI_TUI_FgRGB(100,80,20) }
            TUI_BufferChar(226) TUI_BufferChar(151) TUI_BufferChar(143)
            TUI_BufferChar(32)
            UI_TUI_FgRGB(60,60,60)
            TUI_BufferChar(226) TUI_BufferChar(151) TUI_BufferChar(143)
        } ElseBlock: {
            UI_TUI_FgRGB(50,180,70)
            TUI_BufferChar(226) TUI_BufferChar(151) TUI_BufferChar(143)
            TUI_BufferChar(32)
            TUI_BufferChar(226) TUI_BufferChar(151) TUI_BufferChar(143)
            TUI_BufferChar(32)
            TUI_BufferChar(226) TUI_BufferChar(151) TUI_BufferChar(143)
        }
        TUI_ResetColor()
    }
}

// Context window bar: "ctx ░░░░░▓▓▓▓▓ 38%"
Function.UI_DrawCtxBar {
    Body: {
        ctx_limit = 200000
        pct = 0
        IfCondition GreaterThan(UILayout.tok_in, 0) ThenBlock: {
            pct = Divide(Multiply(UILayout.tok_in, 100), ctx_limit)
        }
        IfCondition GreaterThan(pct, 100) ThenBlock: { pct = 100 }
        filled = Divide(Multiply(pct, 10), 100)
        IfCondition GreaterThan(filled, 10) ThenBlock: { filled = 10 }
        TUI_SetFG(UIColors.DIM_FG)
        TUI_BufferWriteStr("ctx ")
        IfCondition GreaterEqual(pct, 90) ThenBlock: { UI_TUI_FgRGB(200,40,40) } ElseBlock: {
            IfCondition GreaterEqual(pct, 70) ThenBlock: { UI_TUI_FgRGB(220,180,30) } ElseBlock: {
                UI_TUI_FgRGB(50,180,70)
            }
        }
        i = 0
        WhileLoop LessThan(i, 10) {
            IfCondition LessThan(i, filled) ThenBlock: {
                TUI_BufferChar(226) TUI_BufferChar(150) TUI_BufferChar(147)
            } ElseBlock: {
                TUI_BufferChar(226) TUI_BufferChar(150) TUI_BufferChar(145)
            }
            i = Add(i, 1)
        }
        TUI_SetFG(UIColors.DIM_FG)
        TUI_BufferChar(32)
        UI_TUI_WriteInt(pct)
        TUI_BufferChar(37)
        TUI_ResetColor()
    }
}

// Token counts: ↑N ↓N
Function.UI_DrawTokenCounts {
    Body: {
        TUI_SetFG(UIColors.DIM_FG)
        TUI_BufferChar(226) TUI_BufferChar(134) TUI_BufferChar(145)
        UI_TUI_WriteInt(UILayout.tok_in)
        TUI_BufferChar(32)
        TUI_BufferChar(226) TUI_BufferChar(134) TUI_BufferChar(147)
        UI_TUI_WriteInt(UILayout.tok_out)
        TUI_ResetColor()
    }
}

// Full hint row repaint: state dots + elapsed + HAL message + ctx bar + tokens.
Function.UI_DrawHintRow {
    Body: {
        TUI_SaveCursor()
        TUI_MoveTo(UILayout.hint_row, 1)
        TUI_BufferChar(27)
        TUI_BufferWriteStr("[K")
        TUI_ResetColor()
        TUI_BufferWriteStr("  ")
        UI_DrawStateDots()
        TUI_BufferChar(32)
        IfCondition EqualTo(UILayout.ui_state, 1) ThenBlock: {
            TUI_SetFG(UIColors.DIM_FG)
            TUI_Bold()
            esec = UILayout.think_elapsed_sec
            IfCondition LessThan(esec, 60) ThenBlock: {
                UI_TUI_WriteInt(esec)
                TUI_BufferChar(115)
            } ElseBlock: {
                emins = Divide(esec, 60)
                esecs = Subtract(esec, Multiply(emins, 60))
                UI_TUI_WriteInt(emins)
                TUI_BufferChar(109)
                UI_TUI_WriteInt(esecs)
                TUI_BufferChar(115)
            }
            TUI_BufferWriteStr("s  ")
            TUI_ResetColor()
        } ElseBlock: {
            TUI_SetFG(UIColors.DIM_FG)
            TUI_BufferWriteStr("0.0s  ")
            TUI_ResetColor()
        }
        TUI_SetFG(UIColors.GREEN_FG)
        UI_PrintHalMessage()
        TUI_ResetColor()
        right_col = Subtract(UILayout.cols, 42)
        IfCondition LessEqual(right_col, 26) ThenBlock: { right_col = 26 }
        TUI_MoveTo(UILayout.hint_row, right_col)
        TUI_BufferWriteStr("  ")
        UI_DrawCtxBar()
        TUI_BufferWriteStr("  ")
        UI_DrawTokenCounts()
        TUI_BufferWriteStr("  [^O]")
        TUI_RestoreCursor()
    }
}

// Draw all persistent chrome: sidebar divider, header row, horizontal separator,
// idle rule row. Uses SaveCursor/RestoreCursor — safe to call during streaming.
Function.UI_DrawChrome {
    Body: {
        TUI_SaveCursor()

        // Divider char in the header row
        TUI_SetFG(UIColors.DIM_FG)
        TUI_MoveTo(UILayout.header_row, UILayout.divider_col)
        TUI_BufferChar(226) TUI_BufferChar(148) TUI_BufferChar(130)  // │

        // Vertical divider from chat_top+1 to chat_bot
        TUI_Draw_VLine(Add(UILayout.chat_top, 1), UILayout.divider_col,
                       Subtract(UILayout.chat_bot, UILayout.chat_top))
        TUI_ResetColor()

        // Sidebar "FILES" header at row 1
        TUI_MoveTo(UILayout.header_row, 1)
        TUI_SetFG(UIColors.DIM_FG)
        TUI_Bold()
        TUI_BufferWriteStr("  FILES")
        pad = 7
        WhileLoop LessThan(pad, UILayout.sidebar_w) {
            TUI_BufferChar(32)
            pad = Add(pad, 1)
        }
        TUI_ResetColor()

        // Chat pane header: mascot + "HalCode9000 · model · cwd"
        TUI_MoveTo(UILayout.header_row, UILayout.chat_x)
        UI_SetMascotColor()
        UI_EmitLeftArm()
        TUI_BufferWriteStr(" ")
        UI_EmitHalEye()
        UI_SetMascotColor()
        TUI_BufferWriteStr(" ")
        UI_EmitRightArm()
        TUI_ResetColor()
        TUI_SetFG(UIColors.ORANGE_FG)
        TUI_Bold()
        TUI_BufferWriteStr("  HalCode9000")
        TUI_ResetColor()
        TUI_SetFG(UIColors.DIM_FG)
        TUI_BufferWriteStr("  ")
        TUI_BufferChar(194)  // · = U+00B7, bytes C2 B7
        TUI_BufferChar(183)
        TUI_BufferWriteStr("  ")
        IfCondition NotEqual(UILayout.model_str, 0) ThenBlock: {
            TUI_BufferWriteStr(UILayout.model_str)
        }
        TUI_BufferWriteStr("  ")
        TUI_BufferChar(194)
        TUI_BufferChar(183)
        TUI_BufferWriteStr("  ")
        IfCondition NotEqual(UILayout.cwd_str, 0) ThenBlock: {
            TUI_BufferWriteStr(UILayout.cwd_str)
        }
        TUI_BufferChar(27)
        TUI_BufferWriteStr("[K")
        TUI_ResetColor()

        // Horizontal separator at chat_top (between header and chat content)
        TUI_SetFG(UIColors.DIM_FG)
        TUI_Draw_HLine(UILayout.chat_top, UILayout.divider_col,
                       Subtract(Add(UILayout.cols, 1), UILayout.divider_col))
        TUI_ResetColor()

        // Idle rule at rule_row
        UI_DrawRuleIdle()

        TUI_RestoreCursor()
        TUI_Flush()
    }
}

// =============================================================================
// TOOL CALL RENDERING
// =============================================================================
Function.UI.ToolGroupStart {
    Input: n_tools: Integer
    Body: {
        IfCondition EqualTo(UILayout.show_tools, 0) ThenBlock: {
            line = StringConcat("Running ", NumberToString(n_tools))
            line = StringConcat(line, " tools...")
            UI.ChatTag(UIGlyph.DOT, line, UIColors.DIM_FG)
        } ElseBlock: {
            line = StringConcat("Running ", NumberToString(n_tools))
            line = StringConcat(line, " tools:")
            UI.ChatTag(UIGlyph.DOT, line, UIColors.ORANGE_FG)
        }
    }
}

Function.UI.ToolCallStart {
    Input: tool_name: Address
    Input: arg_summary: Address
    Input: idx: Integer
    Input: total: Integer
    Body: {
        // Update hint bar with active tool name
        UILayout.active_tool = tool_name

        IfCondition EqualTo(UILayout.show_tools, 0) ThenBlock: {
            // Compact mode: print transient sub-line
            line = StringConcat("  └─ ", tool_name)
            IfCondition NotEqual(arg_summary, 0) ThenBlock: {
                line = StringConcat(line, "(")
                line = StringConcat(line, arg_summary)
                line = StringConcat(line, ")")
            } ElseBlock: {
                line = StringConcat(line, "(...)")
            }
            // Truncate to prevent native terminal wrap from breaking the layout
            max_len = Subtract(UILayout.cols, 8)
            IfCondition GreaterThan(max_len, 10) ThenBlock: {
                IfCondition GreaterThan(StringLength(line), max_len) ThenBlock: {
                    SetByte(line, Subtract(max_len, 3), 46)
                    SetByte(line, Subtract(max_len, 2), 46)
                    SetByte(line, Subtract(max_len, 1), 46)
                    SetByte(line, max_len, 0)
                }
            }
            UI.ChatTag("", line, UIColors.DIM_FG)
        } ElseBlock: {
            // Expanded mode: print tree branch
            tree = "├─ "
            IfCondition EqualTo(Add(idx, 1), total) ThenBlock: {
                tree = "└─ "
            }
            line = StringConcat(tool_name, "(")
            IfCondition NotEqual(arg_summary, 0) ThenBlock: {
                line = StringConcat(line, arg_summary)
            }
            line = StringConcat(line, ")")
            
            max_len = Subtract(UILayout.cols, 8)
            IfCondition GreaterThan(max_len, 10) ThenBlock: {
                IfCondition GreaterThan(StringLength(line), max_len) ThenBlock: {
                    SetByte(line, Subtract(max_len, 3), 46)
                    SetByte(line, Subtract(max_len, 2), 46)
                    SetByte(line, Subtract(max_len, 1), 46)
                    SetByte(line, max_len, 0)
                }
            }
            UI.ChatTag(tree, line, UIColors.DIM_FG)
        }
    }
}

Function.UI.ToolCallEnd {
    Input: ok: Integer
    Input: idx: Integer
    Input: total: Integer
    Body: {
        // Clear active tool from hint bar; last finished tool clears it
        UILayout.active_tool = 0

        IfCondition EqualTo(UILayout.show_tools, 0) ThenBlock: {
            // Compact mode: erase the transient sub-line
            target_row = Subtract(UILayout.chat_cursor, 1)
            IfCondition GreaterEqual(target_row, UILayout.chat_top) ThenBlock: {
                TUI_MoveTo(target_row, 1)
                TUI_BufferChar(27) TUI_BufferWriteStr("[2K") // Clear entire line
                UILayout.chat_cursor = target_row
                UILayout.chat_col = 1
                TUI_Refresh()
            }
            ReturnValue(0)
        }
        // Move cursor up one line to overwrite the start bullet
        target_row = Subtract(UILayout.chat_cursor, 1)
        IfCondition GreaterEqual(target_row, UILayout.chat_top) ThenBlock: {
            TUI_MoveTo(target_row, 1)
            IfCondition EqualTo(ok, 1) ThenBlock: {
                TUI_SetFG(UIColors.GREEN_FG)
                TUI_BufferWriteStr(UIGlyph.CHECK)
            } ElseBlock: {
                TUI_SetFG(UIColors.RED_FG)
                TUI_BufferWriteStr(UIGlyph.CROSS)
            }
            TUI_ResetColor()
            
            // Restore cursor to original position for the next ChatPrint
            TUI_MoveTo(UILayout.chat_cursor, UILayout.chat_col)
            TUI_Refresh()
        }
    }
}

Function.UI.ToolGroupEnd {
    Input: n_tools: Integer
    Body: {
        IfCondition EqualTo(UILayout.show_tools, 0) ThenBlock: {
            // Compact mode: finalize the single line
            target_row = Subtract(UILayout.chat_cursor, 1)
            IfCondition GreaterEqual(target_row, UILayout.chat_top) ThenBlock: {
                TUI_MoveTo(target_row, 1)
                TUI_BufferChar(27) TUI_BufferWriteStr("[K")
                TUI_SetFG(UIColors.GREEN_FG)
                TUI_BufferWriteStr(UIGlyph.CHECK)
                TUI_ResetColor()
                TUI_BufferWriteStr(" ")
                UI_TUI_WriteInt(n_tools)
                TUI_BufferWriteStr(" tools executed")
                TUI_MoveTo(UILayout.chat_cursor, UILayout.chat_col)
                TUI_Refresh()
            }
        }
    }
}

// =============================================================================
// HELP
// =============================================================================
Function.UI.PrintHelp {
    Body: {
        UI.ChatPrintln("")
        UI.ChatTag("✻", "HAL Code 9000 — I am completely operational.", UIColors.ORANGE_FG)
        UI.ChatPrintln("  /help              this list")
        UI.ChatPrintln("  /auto              toggle autonomous mode (skip 25-tool pause)")
        UI.ChatPrintln("  /model             show current model")
        UI.ChatPrintln("  /model <name>      switch model (e.g. deepseek-v4-flash)")
        UI.ChatPrintln("  /reasoning         show reasoning budget")
        UI.ChatPrintln("  /reasoning <lvl>   set budget: off | min | medium | max")
        UI.ChatPrintln("  /clear             reset conversation history")
        UI.ChatPrintln("  /logout            clear saved OAuth credentials")
        UI.ChatPrintln("  /quit              exit")
        UI.ChatPrintln("")
    }
}

// =============================================================================
// BOOT SCROLL SEQUENCE
// =============================================================================
Function.UI.BootScroll {
    Body: {
        TUI_SetFG(UIColors.DIM_FG)
        UI.ChatPrintln("[system] Booting HAL Code 9000 kernel...")
        UI_SplashSleepMs(150)
        UI.ChatPrintln("[system] Mounting virtual filesystems... OK")
        UI_SplashSleepMs(150)
        UI.ChatPrintln("[system] Initializing cognitive sub-processors... OK")
        UI_SplashSleepMs(200)
        UI.ChatPrintln("[system] Loading heuristic language models... OK")
        UI_SplashSleepMs(150)
        UI.ChatPrintln("[system] Establishing logic gateways... OK")
        UI_SplashSleepMs(250)
        UI.ChatTag("✻", "All systems nominal. I am completely operational.", UIColors.GREEN_FG)
        UI_SplashSleepMs(500)
        UI.ClearChat()
    }
}

// =============================================================================
// SPLASH FILE — load ANSI-art from disk and scroll-in line-by-line.
//
// Reads the file at `path`, prints each line with a brief delay so the
// art "unrolls" downward like an old-school NES title. Each line is
// horizontally centered based on terminal width.
//
// IMPORTANT: must be called BEFORE UI.Init() — it writes via plain
// SystemCall to cooked-mode stdout. Once UI.Init() grabs raw mode, this
// would corrupt the screen.
//
// Skip the splash entirely by setting CC_NO_SPLASH=1 in the environment.
// =============================================================================
FixedPool.UISplashSys {
    "SYS_READ":      Initialize=0
    "SYS_WRITE":     Initialize=1
    "SYS_OPEN":      Initialize=2
    "SYS_CLOSE":     Initialize=3
    "SYS_NANOSLEEP": Initialize=35
    "O_RDONLY":      Initialize=0
}

Function.UI_SplashWrite {
    Input: s: Address
    Input: n: Integer
    Body: {
        IfCondition GreaterThan(n, 0) ThenBlock: {
            SystemCall(UISplashSys.SYS_WRITE, 1, s, n, 0, 0)
        }
    }
}

Function.UI_SplashSleepMs {
    Input: ms: Integer
    Body: {
        ts = Allocate(16)
        sec = Divide(ms, 1000)
        rem_ms = Subtract(ms, Multiply(sec, 1000))
        ns = Multiply(rem_ms, 1000000)
        StoreValue(Add(ts, 0), sec)
        StoreValue(Add(ts, 8), ns)
        SystemCall(UISplashSys.SYS_NANOSLEEP, ts, 0, 0, 0, 0)
        Deallocate(ts, 16)
    }
}

// Read a whole file into a freshly allocated buffer. Returns ptr or 0,
// writes byte length into *out_len_ptr.
Function.UI_SplashReadAll {
    Input: path: Address
    Input: out_len_ptr: Address
    Output: Address
    Body: {
        StoreValue(out_len_ptr, 0)
        fd = SystemCall(UISplashSys.SYS_OPEN, path, UISplashSys.O_RDONLY, 0, 0, 0)
        IfCondition LessThan(fd, 0) ThenBlock: { ReturnValue(0) }
        cap = 131072
        buf = Allocate(cap)
        used = 0
        WhileLoop LessThan(used, cap) {
            n = SystemCall(UISplashSys.SYS_READ, fd, Add(buf, used), Subtract(cap, used), 0, 0)
            IfCondition LessEqual(n, 0) ThenBlock: { BreakLoop }
            used = Add(used, n)
        }
        SystemCall(UISplashSys.SYS_CLOSE, fd, 0, 0, 0, 0)
        StoreValue(out_len_ptr, used)
        ReturnValue(buf)
    }
}

// Estimate the visible width of one line (count cells, not bytes).
// Skips ANSI ESC[...]<final> sequences and counts UTF-8 lead bytes.
Function.UI_SplashLineWidth {
    Input: line: Address
    Input: line_len: Integer
    Output: Integer
    Body: {
        w = 0
        i = 0
        WhileLoop LessThan(i, line_len) {
            b = GetByte(line, i)
            IfCondition EqualTo(b, 27) ThenBlock: {
                // Skip ESC[ ... <final byte 0x40-0x7E>
                i = Add(i, 1)
                IfCondition LessThan(i, line_len) ThenBlock: {
                    IfCondition EqualTo(GetByte(line, i), 91) ThenBlock: {  // [
                        i = Add(i, 1)
                        WhileLoop LessThan(i, line_len) {
                            fb = GetByte(line, i)
                            i = Add(i, 1)
                            IfCondition And(GreaterEqual(fb, 64), LessEqual(fb, 126)) ThenBlock: { BreakLoop }
                        }
                    }
                }
            } ElseBlock: {
                // Count UTF-8 char if it's a lead byte (not a continuation 10xxxxxx)
                IfCondition LessThan(b, 128) ThenBlock: { w = Add(w, 1) }
                IfCondition GreaterEqual(b, 192) ThenBlock: { w = Add(w, 1) }
                i = Add(i, 1)
            }
        }
        ReturnValue(w)
    }
}

// Public entry. Loads `path`, scroll-prints centered, with `delay_ms`
// between rows. Set delay_ms = 0 for instant paint.
Function.UI.SplashFile {
    Input: path: Address
    Input: delay_ms: Integer
    Body: {
        // Skip if CC_NO_SPLASH is set
        no_splash = UI_SplashGetEnv("CC_NO_SPLASH")
        IfCondition NotEqual(no_splash, 0) ThenBlock: {
            IfCondition GreaterThan(StringLength(no_splash), 0) ThenBlock: { ReturnValue(0) }
        }

        len_holder = Allocate(8)
        StoreValue(len_holder, 0)
        body = UI_SplashReadAll(path, len_holder)
        total = Dereference(len_holder)
        Deallocate(len_holder, 8)
        IfCondition EqualTo(body, 0) ThenBlock: { ReturnValue(0) }
        IfCondition LessEqual(total, 0) ThenBlock: { ReturnValue(0) }

        // Get terminal width for centering
        TUI_GetScreenSize()
        cols = TUI_State.screen_width
        IfCondition LessEqual(cols, 0) ThenBlock: { cols = 80 }

        UI_SplashWrite("\n", 1)

        // Walk lines: split on '\n', center each, print with delay
        line_start = 0
        i = 0
        WhileLoop LessEqual(i, total) {
            // End of line at i==total OR byte == \n
            at_end = 0
            IfCondition EqualTo(i, total) ThenBlock: { at_end = 1 }
            is_nl = 0
            IfCondition LessThan(i, total) ThenBlock: {
                IfCondition EqualTo(GetByte(body, i), 10) ThenBlock: { is_nl = 1 }
            }

            IfCondition Or(EqualTo(at_end, 1), EqualTo(is_nl, 1)) ThenBlock: {
                line_len = Subtract(i, line_start)
                line_ptr = Add(body, line_start)
                disp_w = UI_SplashLineWidth(line_ptr, line_len)
                pad = 0
                IfCondition LessThan(disp_w, cols) ThenBlock: {
                    pad = Divide(Subtract(cols, disp_w), 2)
                }
                k = 0
                WhileLoop LessThan(k, pad) {
                    UI_SplashWrite(" ", 1)
                    k = Add(k, 1)
                }
                UI_SplashWrite(line_ptr, line_len)
                UI_SplashWrite("\n", 1)
                IfCondition GreaterThan(delay_ms, 0) ThenBlock: {
                    UI_SplashSleepMs(delay_ms)
                }
                line_start = Add(i, 1)
            }
            i = Add(i, 1)
        }

        Deallocate(body, 131072)
        UI_SplashWrite("\n", 1)
    }
}

// Tiny env-var getter (avoids importing CC_GetEnv)
Function.UI_SplashGetEnv {
    Input: name: Address
    Output: Address
    Body: {
        fd = SystemCall(UISplashSys.SYS_OPEN, "/proc/self/environ", 0, 0, 0, 0)
        IfCondition LessThan(fd, 0) ThenBlock: { ReturnValue(0) }
        buf = Allocate(65536)
        n = SystemCall(UISplashSys.SYS_READ, fd, buf, 65536, 0, 0)
        SystemCall(UISplashSys.SYS_CLOSE, fd, 0, 0, 0, 0)
        IfCondition LessEqual(n, 0) ThenBlock: { Deallocate(buf, 65536)  ReturnValue(0) }
        nlen = StringLength(name)
        i = 0
        WhileLoop LessThan(i, n) {
            match = 1
            j = 0
            WhileLoop LessThan(j, nlen) {
                IfCondition NotEqual(GetByte(buf, Add(i, j)), GetByte(name, j)) ThenBlock: { match = 0  BreakLoop }
                j = Add(j, 1)
            }
            IfCondition EqualTo(match, 1) ThenBlock: {
                IfCondition EqualTo(GetByte(buf, Add(i, nlen)), 61) ThenBlock: {
                    val_start = Add(i, Add(nlen, 1))
                    val_end = val_start
                    WhileLoop LessThan(val_end, n) {
                        IfCondition EqualTo(GetByte(buf, val_end), 0) ThenBlock: { BreakLoop }
                        val_end = Add(val_end, 1)
                    }
                    val_len = Subtract(val_end, val_start)
                    out = Allocate(Add(val_len, 1))
                    k = 0
                    WhileLoop LessThan(k, val_len) {
                        SetByte(out, k, GetByte(buf, Add(val_start, k)))
                        k = Add(k, 1)
                    }
                    SetByte(out, val_len, 0)
                    Deallocate(buf, 65536)
                    ReturnValue(out)
                }
            }
            WhileLoop LessThan(i, n) {
                IfCondition EqualTo(GetByte(buf, i), 0) ThenBlock: { BreakLoop }
                i = Add(i, 1)
            }
            i = Add(i, 1)
        }
        Deallocate(buf, 65536)
        ReturnValue(0)
    }
}

// =============================================================================
// STARTUP ANIMATION — characters assemble from both sides to spell HALCODE,
// color-pulse, then the HAL eye orbits inside the O.
// Call BEFORE UI.Init() — cooked-mode stdout. Skip if CC_NO_SPLASH=1.
// =============================================================================

FixedPool.UIAniK {
    "LOGO_W":  Initialize=68
    "BUF_SZ":  Initialize=2048
    "EYE_B0":  Initialize=226
    "EYE_B1":  Initialize=151
    "EYE_B2":  Initialize=137
}

FixedPool.UIAniState {
    "left_pad": Initialize=16
    "logo_row": Initialize=3
}

// Integer to decimal ASCII digits in buf at pos. Returns new pos.
Function.UIAni_Int {
    Input: buf: Address
    Input: pos: Integer
    Input: n:   Integer
    Output: Integer
    Body: {
        IfCondition EqualTo(n, 0) ThenBlock: {
            SetByte(buf, pos, 48)
            ReturnValue(Add(pos, 1))
        }
        tmp = Allocate(12)
        nd = 0
        v = n
        WhileLoop GreaterThan(v, 0) {
            SetByte(tmp, nd, Add(48, Modulo(v, 10)))
            v = Divide(v, 10)
            nd = Add(nd, 1)
        }
        i = 0
        WhileLoop LessThan(i, nd) {
            SetByte(buf, Add(pos, i), GetByte(tmp, Subtract(Subtract(nd, 1), i)))
            i = Add(i, 1)
        }
        Deallocate(tmp, 12)
        ReturnValue(Add(pos, nd))
    }
}

// ESC[row;colH cursor-position sequence into buf. Returns new pos.
Function.UIAni_Goto {
    Input: buf: Address
    Input: pos: Integer
    Input: row: Integer
    Input: col: Integer
    Output: Integer
    Body: {
        SetByte(buf, pos, 27)   pos = Add(pos, 1)
        SetByte(buf, pos, 91)   pos = Add(pos, 1)
        pos = UIAni_Int(buf, pos, row)
        SetByte(buf, pos, 59)   pos = Add(pos, 1)
        pos = UIAni_Int(buf, pos, col)
        SetByte(buf, pos, 72)   pos = Add(pos, 1)
        ReturnValue(pos)
    }
}

// ESC[38;2;r;g;bm truecolor fg into buf. Returns new pos.
Function.UIAni_FgRGB {
    Input: buf: Address
    Input: pos: Integer
    Input: r:   Integer
    Input: g:   Integer
    Input: bv:  Integer
    Output: Integer
    Body: {
        SetByte(buf, pos, 27)   pos = Add(pos, 1)
        SetByte(buf, pos, 91)   pos = Add(pos, 1)
        SetByte(buf, pos, 51)   pos = Add(pos, 1)
        SetByte(buf, pos, 56)   pos = Add(pos, 1)
        SetByte(buf, pos, 59)   pos = Add(pos, 1)
        SetByte(buf, pos, 50)   pos = Add(pos, 1)
        SetByte(buf, pos, 59)   pos = Add(pos, 1)
        pos = UIAni_Int(buf, pos, r)
        SetByte(buf, pos, 59)   pos = Add(pos, 1)
        pos = UIAni_Int(buf, pos, g)
        SetByte(buf, pos, 59)   pos = Add(pos, 1)
        pos = UIAni_Int(buf, pos, bv)
        SetByte(buf, pos, 109)  pos = Add(pos, 1)
        ReturnValue(pos)
    }
}

// Returns one of the 5 logo row strings for HALCODE (68 chars each).
// 8-wide letters, 2-char gaps. O interior (cols 42-45) is 4 spaces on rows 1-3.
Function.UIAni_LogoRow {
    Input: row: Integer
    Output: Address
    Body: {
        IfCondition EqualTo(row, 0) ThenBlock: { ReturnValue("##    ##    ####    ##         ######    ######   ######    ########") }
        IfCondition EqualTo(row, 1) ThenBlock: { ReturnValue("##    ##   ##  ##   ##        ##        ##    ##  ##    ##  ##      ") }
        IfCondition EqualTo(row, 2) ThenBlock: { ReturnValue("########  ########  ##        ##        ##    ##  ##    ##  ######  ") }
        IfCondition EqualTo(row, 3) ThenBlock: { ReturnValue("##    ##  ##    ##  ##        ##        ##    ##  ##    ##  ##      ") }
        ReturnValue("##    ##  ##    ##  ########   ######    ######   ######    ########")
    }
}

// Write one logo row with left+right assembly reveal into buf. Returns new pos.
// Reads UIAniState.left_pad as a global. rl = left reveal count, rr = right reveal count.
Function.UIAni_DrawLogoRow {
    Input: buf:     Address
    Input: pos:     Integer
    Input: row_str: Address
    Input: rl:      Integer
    Input: rr:      Integer
    Output: Integer
    Body: {
        lpad = UIAniState.left_pad
        i = 0
        WhileLoop LessThan(i, lpad) {
            SetByte(buf, pos, 32)
            pos = Add(pos, 1)
            i = Add(i, 1)
        }
        actual_l = rl
        IfCondition GreaterThan(actual_l, UIAniK.LOGO_W) ThenBlock: { actual_l = UIAniK.LOGO_W }
        actual_r = rr
        IfCondition GreaterThan(Add(actual_l, actual_r), UIAniK.LOGO_W) ThenBlock: {
            actual_r = Subtract(UIAniK.LOGO_W, actual_l)
        }
        i = 0
        WhileLoop LessThan(i, actual_l) {
            SetByte(buf, pos, GetByte(row_str, i))
            pos = Add(pos, 1)
            i = Add(i, 1)
        }
        dark = Subtract(UIAniK.LOGO_W, Add(actual_l, actual_r))
        i = 0
        WhileLoop LessThan(i, dark) {
            SetByte(buf, pos, 32)
            pos = Add(pos, 1)
            i = Add(i, 1)
        }
        r_start = Subtract(UIAniK.LOGO_W, actual_r)
        IfCondition LessThan(r_start, actual_l) ThenBlock: { r_start = actual_l }
        i = r_start
        WhileLoop LessThan(i, UIAniK.LOGO_W) {
            SetByte(buf, pos, GetByte(row_str, i))
            pos = Add(pos, 1)
            i = Add(i, 1)
        }
        SetByte(buf, pos, 27)   pos = Add(pos, 1)
        SetByte(buf, pos, 91)   pos = Add(pos, 1)
        SetByte(buf, pos, 75)   pos = Add(pos, 1)
        SetByte(buf, pos, 10)   pos = Add(pos, 1)
        ReturnValue(pos)
    }
}

// Main startup animation. Call before UI.Init().
Function.UI.StartupAnimation {
    Body: {
        no_splash = UI_SplashGetEnv("CC_NO_SPLASH")
        IfCondition NotEqual(no_splash, 0) ThenBlock: {
            IfCondition GreaterThan(StringLength(no_splash), 0) ThenBlock: { ReturnValue(0) }
        }

        TUI_GetScreenSize()
        tcols = TUI_State.screen_width
        IfCondition LessEqual(tcols, 0) ThenBlock: { tcols = 80 }

        lpad = Divide(Subtract(tcols, UIAniK.LOGO_W), 2)
        IfCondition LessThan(lpad, 0) ThenBlock: { lpad = 0 }
        IfCondition GreaterThan(lpad, 80) ThenBlock: { lpad = 80 }
        UIAniState.left_pad = lpad
        UIAniState.logo_row = 3

        buf = Allocate(UIAniK.BUF_SZ)

        pos = 0
        SetByte(buf, pos, 27)   pos = Add(pos, 1)
        SetByte(buf, pos, 91)   pos = Add(pos, 1)
        SetByte(buf, pos, 50)   pos = Add(pos, 1)
        SetByte(buf, pos, 74)   pos = Add(pos, 1)
        SetByte(buf, pos, 27)   pos = Add(pos, 1)
        SetByte(buf, pos, 91)   pos = Add(pos, 1)
        SetByte(buf, pos, 72)   pos = Add(pos, 1)
        SetByte(buf, pos, 27)   pos = Add(pos, 1)
        SetByte(buf, pos, 91)   pos = Add(pos, 1)
        SetByte(buf, pos, 63)   pos = Add(pos, 1)
        SetByte(buf, pos, 50)   pos = Add(pos, 1)
        SetByte(buf, pos, 53)   pos = Add(pos, 1)
        SetByte(buf, pos, 108)  pos = Add(pos, 1)
        UI_SplashWrite(buf, pos)

        frame = 0
        WhileLoop LessThan(frame, 25) {
            pos = 0
            SetByte(buf, pos, 27)   pos = Add(pos, 1)
            SetByte(buf, pos, 91)   pos = Add(pos, 1)
            SetByte(buf, pos, 72)   pos = Add(pos, 1)
            SetByte(buf, pos, 10)   pos = Add(pos, 1)
            SetByte(buf, pos, 10)   pos = Add(pos, 1)

            reveal_l = UIAniK.LOGO_W
            reveal_r = 0
            IfCondition LessThan(frame, 5) ThenBlock: {
                reveal_l = Multiply(Add(frame, 1), 14)
                reveal_r = reveal_l
            }

            cr = 204
            cg = 120
            cbv = 50
            IfCondition GreaterThan(frame, 9) ThenBlock: { cr = 50   cg = 220  cbv = 220 }
            IfCondition GreaterThan(frame, 14) ThenBlock: { cr = 230  cg = 230  cbv = 230 }
            IfCondition GreaterThan(frame, 19) ThenBlock: { cr = 220  cg = 80   cbv = 120 }

            row = 0
            WhileLoop LessThan(row, 5) {
                pos = UIAni_FgRGB(buf, pos, cr, cg, cbv)
                rstr = UIAni_LogoRow(row)
                pos = UIAni_DrawLogoRow(buf, pos, rstr, reveal_l, reveal_r)
                row = Add(row, 1)
            }

            SetByte(buf, pos, 27)   pos = Add(pos, 1)
            SetByte(buf, pos, 91)   pos = Add(pos, 1)
            SetByte(buf, pos, 48)   pos = Add(pos, 1)
            SetByte(buf, pos, 109)  pos = Add(pos, 1)

            IfCondition GreaterThan(frame, 4) ThenBlock: {
                orbit_idx = Modulo(frame, 4)
                orb_row = 1
                IfCondition GreaterThan(orbit_idx, 1) ThenBlock: { orb_row = 3 }
                orb_col = Add(lpad, 43)
                IfCondition EqualTo(orbit_idx, 1) ThenBlock: { orb_col = Add(lpad, 46) }
                IfCondition EqualTo(orbit_idx, 2) ThenBlock: { orb_col = Add(lpad, 46) }
                pos = UIAni_Goto(buf, pos, Add(UIAniState.logo_row, orb_row), orb_col)
                pos = UIAni_FgRGB(buf, pos, 255, 0, 0)
                SetByte(buf, pos, UIAniK.EYE_B0) pos = Add(pos, 1)
                SetByte(buf, pos, UIAniK.EYE_B1) pos = Add(pos, 1)
                SetByte(buf, pos, UIAniK.EYE_B2) pos = Add(pos, 1)
                SetByte(buf, pos, 27)   pos = Add(pos, 1)
                SetByte(buf, pos, 91)   pos = Add(pos, 1)
                SetByte(buf, pos, 48)   pos = Add(pos, 1)
                SetByte(buf, pos, 109)  pos = Add(pos, 1)
            }

            UI_SplashWrite(buf, pos)

            IfCondition LessThan(frame, 5) ThenBlock: { UI_SplashSleepMs(80) }
            IfCondition GreaterThan(frame, 4) ThenBlock: { UI_SplashSleepMs(70) }

            frame = Add(frame, 1)
        }

        pos = 0
        SetByte(buf, pos, 27)   pos = Add(pos, 1)
        SetByte(buf, pos, 91)   pos = Add(pos, 1)
        SetByte(buf, pos, 63)   pos = Add(pos, 1)
        SetByte(buf, pos, 50)   pos = Add(pos, 1)
        SetByte(buf, pos, 53)   pos = Add(pos, 1)
        SetByte(buf, pos, 104)  pos = Add(pos, 1)
        UI_SplashWrite(buf, pos)

        Deallocate(buf, UIAniK.BUF_SZ)
    }
}

// =============================================================================
// COMPATIBILITY SHIMS — for callers that used the old API
// =============================================================================
// Old callers used UI_Write / UI.WriteColor / various banner fns directly.
// In raw mode those would skip the chat-cursor accounting, so we redirect
// them to ChatPrint. Old box/banner code is ignored — too noisy anyway.
Function.UI_Write          { Input: s: Address  Body: { UI.ChatPrint(s) } }
Function.UI_Writeln        { Input: s: Address  Body: { UI.ChatPrintln(s) } }
Function.UI.WriteColor     { Input: color: Address  Input: text: Address  Body: { UI.ChatPrint(text) } }
Function.UI.BootBanner     { Input: cwd: Address    Body: { } }
Function.UI.SplashBoot     { Body: { } }
Function.UI.RenderPromptArea  { Input: todos_arr: Address  Input: hint: Address  Body: { } }
Function.UI.RenderPromptClose { Body: { } }
Function.UI.QuerySize      { Body: { UI_RecomputeLayout() } }
